{
  "id": "shards-of-mana",
  "title": "Shards of Mana",
  "description": "An original TTRPG system built for Foundry VTT. Explore a world of crystallized magic, master Jobs, bond with allies, and rise through the ranks of the Adventuring Guild.",
  "version": "0.1.2",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "EikoSakura"
    }
  ],
  "esmodules": ["shards-of-mana.mjs"],
  "styles": [
    "styles/shards-of-mana.css",
    "styles/actor-shared.css",
    "styles/actor-adventurer.css",
    "styles/item-job.css",
    "styles/app-jobs.css",
    "styles/app-item-browser.css",
    "styles/app-codex-hub.css",
    "styles/active-effect-sheet.css",
    "styles/effect-creator.css",
    "styles/item-skill.css",
    "styles/item-equipment.css",
    "styles/item-manacite.css",

    "styles/chat-cards.css",
    "styles/effects-shared.css",
    "styles/app-chargen.css",
    "styles/app-levelup.css",
    "styles/actor-party.css",
    "styles/app-preroll.css",
    "styles/combat-tracker.css",
    "styles/app-loot.css",
    "styles/app-quest-creator.css",
    "styles/app-encounter-builder.css",
    "styles/item-effect.css",
    "styles/item-lineage.css",
    "styles/app-party-hud.css",
    "styles/app-enemy-hud.css",
    "styles/app-token-hud.css",
    "styles/app-choice-dialog.css",
    "styles/mana-grid.css"
  ],
  "packs": [
    {
      "name": "jobs",
      "label": "Shards of Mana - Jobs",
      "type": "Item",
      "path": "packs/jobs",
      "system": "shards-of-mana"
    },
    {
      "name": "equipment",
      "label": "Shards of Mana - Equipment",
      "type": "Item",
      "path": "packs/equipment",
      "system": "shards-of-mana"
    },
    {
      "name": "manacite",
      "label": "Shards of Mana - Manacite",
      "type": "Item",
      "path": "packs/manacite",
      "system": "shards-of-mana"
    },

    {
      "name": "skills",
      "label": "Shards of Mana - Skills",
      "type": "Item",
      "path": "packs/skills",
      "system": "shards-of-mana"
    },
    {
      "name": "monsters",
      "label": "Shards of Mana - Monsters",
      "type": "Actor",
      "path": "packs/monsters",
      "system": "shards-of-mana"
    },
    {
      "name": "rules",
      "label": "Shards of Mana - Rulebook",
      "type": "JournalEntry",
      "path": "packs/rules",
      "system": "shards-of-mana"
    },
    {
      "name": "effects",
      "label": "Shards of Mana - Effects",
      "type": "Item",
      "path": "packs/effects",
      "system": "shards-of-mana"
    },
    {
      "name": "lineages",
      "label": "Shards of Mana - Lineages",
      "type": "Item",
      "path": "packs/lineages",
      "system": "shards-of-mana"
    }
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "adventurer": {
        "htmlFields": ["biography", "appearance", "personality"]
      },
      "monster": {
        "htmlFields": ["biography"]
      },
      "npc": {
        "htmlFields": ["biography"]
      },
      "merchant": {
        "htmlFields": ["biography"]
      },
      "party": {
        "htmlFields": ["biography"]
      }
    },
    "Item": {
      "job": {
        "htmlFields": ["description"]
      },
      "manacite": {
        "htmlFields": ["description"]
      },
      "equipment": {
        "htmlFields": ["description"]
      },

      "skill": {
        "htmlFields": ["description"]
      },
      "effect": {
        "htmlFields": ["description"]
      },
      "lineage": {
        "htmlFields": ["description"]
      }
    }
  },
  "grid": {
    "distance": 1,
    "units": "sq"
  },
  "primaryTokenAttribute": "health",
  "secondaryTokenAttribute": "mana",
  "socket": false
}
