{{!-- One Archive entry detail BOOK (slide-in drawer). Rendered both as a partial inside archive.hbs
      (per openable entry) AND standalone via renderTemplate when a single entry's book is spliced into
      the live DOM with no pane re-render (new entry, image/banner pick, stat-block toggle…). `isGM` is
      passed in (archive.hbs: `isGM=@root.isGM`; standalone: merged into ctx), so this template never
      reaches for @root — it behaves identically in both call sites. --}}
<aside class="section-drawer{{#if isOpen}} open{{/if}}" data-drawer="{{id}}">
  <div class="drawer-backdrop" data-action="closeArchiveEntry"></div>
  <div class="hq-book ab" style="--acc:{{accent}}">
    <a class="hq-book-close" data-action="closeArchiveEntry"><i class="fa-solid fa-xmark"></i></a>

    {{!-- LEFT PAGE — authored content (GM edits inline; players read) --}}
    <div class="hq-page left">
      <div class="hq-bk-banner" style="{{bannerStyle}}">
        <div class="ab-banner-scrim"></div>
        {{#if isGM}}
        <input class="ab-title-edit" data-arc-id="{{id}}" data-arc-field="name" value="{{name}}" placeholder="{{localize 'PROJECTANIME.Archive.namePlaceholder'}}">
        {{else}}
        <span class="ab-title">{{#if name}}{{name}}{{else}}{{localize "PROJECTANIME.Archive.untitled"}}{{/if}}</span>
        {{/if}}
      </div>

      <div class="hq-bk-body ab-body">
        {{#if isGM}}
        <div class="ab-row2">
          <input class="ab-sub-edit" data-arc-id="{{id}}" data-arc-field="subtitle" value="{{subtitle}}" placeholder="{{localize 'PROJECTANIME.Archive.subtitlePlaceholder'}}">
          <select class="ab-cat-sel" data-arc-id="{{id}}" data-arc-field="category">{{#each catOptions}}<option value="{{id}}" {{#if sel}}selected{{/if}}>{{label}}</option>{{/each}}</select>
        </div>
        <div class="ab-row2">
          <select class="ab-tier-sel" data-arc-id="{{id}}" data-arc-field="tier">{{#each tierOptions}}<option value="{{key}}" {{#if sel}}selected{{/if}}>{{label}}</option>{{/each}}</select>
          <label class="ab-reveal {{#if revealed}}on{{/if}}" data-action="toggleReveal" data-arc-id="{{id}}"><i class="fas {{#if revealed}}fa-eye{{else}}fa-eye-slash{{/if}}"></i> {{revealLabel}}</label>
        </div>
        <input class="ab-tags-edit" data-arc-id="{{id}}" data-arc-field="tags" value="{{tagStr}}" placeholder="{{localize 'PROJECTANIME.Archive.tagsPlaceholder'}}">
        {{else}}
        {{#if subtitle}}<div class="ab-subtitle">{{subtitle}}</div>{{/if}}
        {{#if tags.length}}<div class="ab-tags">{{#each tags}}<span class="ab-tag">{{this}}</span>{{/each}}</div>{{/if}}
        {{/if}}

        {{#unless isGM}}{{#if quote}}<blockquote class="ab-quote">{{quote}}</blockquote>{{/if}}{{/unless}}
        {{#if isGM}}<input class="ab-quote-edit" data-arc-id="{{id}}" data-arc-field="quote" value="{{quote}}" placeholder="{{localize 'PROJECTANIME.Archive.quotePlaceholder'}}">{{/if}}

        <div class="hq-bk-sec">{{localize "PROJECTANIME.Archive.dossier"}}</div>
        {{#if isGM}}
        <textarea class="ab-dossier-edit" data-arc-id="{{id}}" data-arc-field="dossier" placeholder="{{localize 'PROJECTANIME.Archive.dossierPlaceholder'}}">{{dossierRaw}}</textarea>
        {{else}}
        {{#if dossier}}<div class="ab-dossier">{{{dossier}}}</div>{{else}}<div class="ab-dossier empty">{{localize "PROJECTANIME.Archive.noDossier"}}</div>{{/if}}
        {{/if}}

        {{!-- VITALS — free-form k/v rows (GM authored, shown to all on a revealed entry) --}}
        <div class="hq-bk-sec">{{localize "PROJECTANIME.Archive.vitals"}}
          {{#if isGM}}<a class="ab-add" data-action="addEntryVital" data-arc-id="{{id}}"><i class="fas fa-plus"></i></a>{{/if}}
        </div>
        {{#if isGM}}
        <div class="ab-vitals edit">
          {{#each vitals}}
          <div class="ab-vrow">
            <input data-arc-id="{{../id}}" data-arc-vital="{{id}}" data-vital-field="k" value="{{k}}" placeholder="{{localize 'PROJECTANIME.Archive.vitalKey'}}">
            <input data-arc-id="{{../id}}" data-arc-vital="{{id}}" data-vital-field="v" value="{{v}}" placeholder="{{localize 'PROJECTANIME.Archive.vitalVal'}}">
            <a class="ab-vdel" data-action="removeEntryVital" data-arc-id="{{../id}}" data-vital="{{id}}"><i class="fas fa-xmark"></i></a>
          </div>
          {{/each}}
        </div>
        {{else}}
        {{#if vitals.length}}<div class="ab-vitals">{{#each vitals}}<div class="ab-vrow"><span class="k">{{k}}</span><span class="v">{{v}}</span></div>{{/each}}</div>{{/if}}
        {{/if}}

        {{#if isGM}}
        <div class="hq-bk-sec">{{localize "PROJECTANIME.Archive.gmNotes"}}</div>
        <textarea class="ab-gmnotes-edit" data-arc-id="{{id}}" data-arc-field="gmNotes" placeholder="{{localize 'PROJECTANIME.Archive.gmNotesPlaceholder'}}">{{gmNotesRaw}}</textarea>
        {{/if}}

        <div class="hq-drawer-foot">
          {{#if hasActor}}<button type="button" class="rec-btn ghost" data-action="openEntryActor" data-arc-id="{{id}}"><i class="fas fa-up-right-from-square"></i> {{localize "PROJECTANIME.Covenant.openSheet"}}</button>{{/if}}
          {{#if isGM}}<a class="hq-drawer-del" data-action="deleteArchiveEntry" data-arc-id="{{id}}" title="{{localize 'PROJECTANIME.Covenant.delete'}}"><i class="fas fa-trash"></i> {{localize "PROJECTANIME.Covenant.delete"}}</a>{{/if}}
        </div>
      </div>
    </div>

    {{!-- RIGHT PAGE — portrait + live (reveal-gated) stat block / item readout --}}
    <div class="hq-page right ab-right">
      <div class="ab-portrait{{#if isGM}} pickable{{/if}}"{{#if isGM}} data-action="pickEntryImage" data-arc-id="{{id}}" title="{{localize 'PROJECTANIME.Archive.pickImage'}}"{{/if}}>
        {{#if img}}<img src="{{img}}" alt="">{{else}}<span class="ph">{{initial}}</span>{{/if}}
      </div>
      {{#if subtitle}}<div class="ab-rsub">{{subtitle}}</div>{{/if}}
      {{#if tier}}<div class="ab-tier-badge" style="--tc:{{tier.color}}"><i class="{{tier.icon}}"></i> {{tier.label}}</div>{{/if}}

      {{#if isGM}}
      <div class="ab-gm-imgtools">
        <button type="button" class="rec-btn ghost sm" data-action="pickEntryImage" data-arc-id="{{id}}"><i class="fas fa-image-portrait"></i> {{localize "PROJECTANIME.Archive.portrait"}}</button>
        <button type="button" class="rec-btn ghost sm" data-action="pickEntryBanner" data-arc-id="{{id}}"><i class="fas fa-panorama"></i> {{localize "PROJECTANIME.Archive.banner"}}</button>
        {{#if hasActor}}<label class="ab-sb-toggle"><input type="checkbox" data-arc-id="{{id}}" data-arc-field="showStatBlock" {{#if showStatBlock}}checked{{/if}}> {{localize "PROJECTANIME.Archive.showStatBlock"}}</label>{{/if}}
      </div>
      {{/if}}

      {{#if hasStatBlock}}
      <div class="ab-stat">
        {{#if vit}}
        <div class="ab-vitbars">
          <div class="ab-vb"><span class="k">{{localize "PROJECTANIME.Stat.hp"}}</span><span class="v">{{vit.hp.value}} / {{vit.hp.max}}</span></div>
          <div class="ab-vb"><span class="k">{{localize "PROJECTANIME.Stat.energy"}}</span><span class="v">{{vit.energy.value}} / {{vit.energy.max}}</span></div>
        </div>
        {{/if}}
        {{#if stat.attributes}}
        <div class="ab-st-title">{{localize "PROJECTANIME.Effect.reveal.attributes"}}</div>
        <div class="ab-attrs">{{#each stat.attributes}}<div class="ab-attr"><span class="k">{{label}}</span><span class="v">{{die}}</span></div>{{/each}}</div>
        {{/if}}
        {{#if stat.combat}}
        <div class="ab-st-title">{{localize "PROJECTANIME.Effect.reveal.combatStats"}}</div>
        <div class="ab-combat">
          <div class="ab-stat-cell"><span class="k">{{localize "PROJECTANIME.Stat.evasion"}}</span><span class="v">{{stat.combat.evasion}}</span></div>
          <div class="ab-stat-cell"><span class="k">{{localize "PROJECTANIME.Stat.defense"}}</span><span class="v">{{stat.combat.defense}}</span></div>
          <div class="ab-stat-cell"><span class="k">{{localize "PROJECTANIME.Stat.movement"}}</span><span class="v">{{stat.combat.movement}}</span></div>
        </div>
        {{/if}}
        {{#if stat.affinities.length}}
        <div class="ab-st-title">{{localize "PROJECTANIME.Effect.reveal.affinities"}}</div>
        <div class="ab-affs">{{#each stat.affinities}}<span class="ab-aff aff-{{level}}">{{label}} · {{levelLabel}}</span>{{/each}}</div>
        {{/if}}
        {{#if stat.customFields.length}}
        <div class="ab-fields">{{#each stat.customFields}}<div class="ab-vrow"><span class="k">{{label}}</span><span class="v">{{value}}</span></div>{{/each}}</div>
        {{/if}}
      </div>
      {{/if}}

      {{#if hasItem}}
      <div class="ab-item">
        <div class="ab-st-title">{{itemName}}</div>
        {{#if itemDescription}}<div class="ab-item-desc">{{{itemDescription}}}</div>{{/if}}
      </div>
      {{/if}}
    </div>

  </div>
</aside>
