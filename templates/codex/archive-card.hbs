{{!-- One Archive entry card (grid tile). Rendered both as a partial inside archive.hbs (per category
      card) AND standalone via renderTemplate when a single entry is spliced into the live DOM with no
      pane re-render. `isGM` is passed in (archive.hbs: `isGM=@root.isGM`; standalone: merged into ctx),
      so this template never reaches for @root — it works identically in both call sites. --}}
{{#if locked}}
<div class="hq-tcard arc-card locked" style="--acc:#6b6478">
  <div class="r-frame"></div>
  <div class="r-face"><span class="r-ph">?</span><div class="r-scrim"></div><div class="r-name">???</div></div>
  <span class="cstud tl"></span><span class="cstud tr"></span><span class="cstud bl"></span><span class="cstud br"></span>
  <span class="arc-lock"><i class="fas fa-lock"></i></span>
</div>
{{else}}
<div class="hq-tcard arc-card{{#unless revealed}} unrevealed{{/unless}}" data-action="openArchiveEntry" data-arc-id="{{id}}" style="--acc:{{accent}}">
  <div class="r-frame"></div>
  <div class="r-face">{{#if img}}<img class="r-img" src="{{img}}" alt="">{{else}}<span class="r-ph">{{initial}}</span>{{/if}}<div class="r-scrim"></div><div class="r-name">{{name}}</div></div>
  <span class="cstud tl"></span><span class="cstud tr"></span><span class="cstud bl"></span><span class="cstud br"></span>
  {{#if tier}}<span class="hq-tcrest arc-tier" title="{{tier.label}}" style="color:{{tier.color}}"><i class="{{tier.icon}}"></i></span>{{/if}}
  {{#if isGM}}<span class="arc-reveal-pip{{#if revealed}} on{{/if}}" title="{{revealLabel}}"><i class="fas {{#if revealed}}fa-eye{{else}}fa-eye-slash{{/if}}"></i></span>{{/if}}
</div>
{{/if}}
