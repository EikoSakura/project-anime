{{!-- Codex HOME pane — the Headquarters (v0.03). Renown = facilities + resident Followers; Rank C→S.
      Three tabs: Facilities (build / steward / upgrade) · Residents (move in / favored / steward) ·
      Missions (the Mission Board, open at rank B). Engine: helpers/hq.mjs. --}}
<section class="codex-pane pa-hq{{#if onHq}} active{{/if}}" data-pane="hq">
  <div class="hq-scroll">

    {{!-- ===================== IDENTITY (flat header — no image banner) ===================== --}}
    <header class="hq-header{{#if isGM}} hq-edit{{/if}}" style="--acc:{{hq.identity.accent}}">
      <div class="hq-crest{{#if hq.identity.crest}} has-img{{/if}}"{{#if isGM}} data-action="pickHqCrest" title="{{localize 'PROJECTANIME.HQ.crestPick'}}"{{/if}}>
        <div class="hq-crest-inner">
          {{#if hq.identity.crest}}<img src="{{hq.identity.crest}}" alt="">{{else}}<span class="hq-crest-fallback">{{hq.identity.initial}}</span>{{/if}}
          {{#if isGM}}<span class="hq-crest-pick"><i class="fas fa-camera"></i></span>{{/if}}
        </div>
      </div>
      <div class="hq-id">
        {{#if isGM}}
        <input class="hq-name-edit" data-hq-field="name" value="{{hq.identity.name}}" placeholder="{{localize 'PROJECTANIME.HQ.namePlaceholder'}}">
        <input class="hq-motto-edit" data-hq-field="motto" value="{{hq.identity.motto}}" placeholder="{{localize 'PROJECTANIME.HQ.mottoPlaceholder'}}">
        {{else}}
        <h3 class="hq-name">{{#if hq.identity.name}}{{hq.identity.name}}{{else}}{{localize "PROJECTANIME.HQ.title"}}{{/if}}</h3>
        {{#if hq.identity.motto}}<div class="hq-motto">{{hq.identity.motto}}</div>{{/if}}
        {{/if}}
        <div class="hq-rankrow">
          <span class="hq-rankbadge" title="{{hq.status.rankName}}">
            <span class="rk">{{hq.status.rankKey}}</span>
            <span class="rn">{{hq.status.rankName}}</span>
          </span>
        </div>
      </div>
      <div class="hq-side">
        <div class="hq-treasury" title="{{localize 'PROJECTANIME.HQ.treasury'}}">
          <div class="t-lbl">{{localize "PROJECTANIME.HQ.treasury"}}</div>
          <div class="t-amt"><i class="fas fa-coins"></i><b>{{hq.treasury.gold}}</b><span class="g">{{localize "PROJECTANIME.HQ.gold"}}</span>{{#if isGM}}<button type="button" class="t-edit" data-action="hqEditTreasury" title="{{localize 'PROJECTANIME.HQ.treasuryTitle'}}"><i class="fas fa-plus"></i></button>{{/if}}</div>
          {{#if hq.treasury.hasFlow}}<div class="t-sub"><span class="t-flow"><b>+{{hq.treasury.workGold}} G</b> {{localize "PROJECTANIME.HQ.perRest"}}</span></div>{{/if}}
        </div>
        {{#if isGM}}
        <div class="hq-tools">
          <input type="color" class="hq-color-edit" data-hq-field="accent" value="{{hq.identity.accent}}" title="{{localize 'PROJECTANIME.HQ.accentPick'}}">
          {{#unless hq.established}}<button type="button" class="gbtn hq-advance" data-action="establishHQ"><i class="fas fa-map-pin"></i> {{localize "PROJECTANIME.HQ.establish"}}</button>{{/unless}}
          <button type="button" class="gbtn hq-io" data-action="exportHQ" title="{{localize 'PROJECTANIME.HQ.export'}}"><i class="fas fa-file-export"></i></button>
          <button type="button" class="gbtn hq-io" data-action="importHQ" title="{{localize 'PROJECTANIME.HQ.import'}}"><i class="fas fa-file-import"></i></button>
        </div>
        {{/if}}
      </div>
    </header>

    {{#unless hq.established}}
    <div class="hq-empty"><i class="fas fa-map-location-dot"></i><p>{{localize "PROJECTANIME.HQ.noBase"}}</p></div>
    {{else}}

    {{!-- ===================== RENOWN → NEXT RANK ===================== --}}
    <div class="hq-renown">
      <div class="hq-ren-seal {{#if hq.renownMeter.ready}}ready{{else}}cur{{/if}}">
        <span class="s-l">{{hq.renownMeter.curKey}}</span>
        <span class="s-n">{{hq.renownMeter.curName}}</span>
      </div>
      <div class="hq-ren-mid">
        <div class="hq-ren-top">
          <span class="hq-ren-lbl">{{localize "PROJECTANIME.HQ.renown"}}{{#unless hq.renownMeter.isMax}} → {{localize "PROJECTANIME.HQ.toNextRank"}}{{/unless}}</span>
          {{#unless hq.renownMeter.isMax}}<span class="hq-ren-num"><b>{{hq.renownMeter.renown}}</b> / {{hq.renownMeter.nextRenown}} · {{hq.renownMeter.toGo}} {{localize "PROJECTANIME.HQ.toGo"}}</span>{{/unless}}
        </div>
        <div class="hq-segs">
          {{#each hq.renownMeter.segments}}<span class="hq-seg{{#if on}} on{{/if}}"></span>{{/each}}
        </div>
        <div class="hq-uchips">
          {{#if hq.renownMeter.ready}}<span class="hq-uchip ready"><i class="fas fa-bed"></i> {{localize "PROJECTANIME.HQ.readyRankUp"}}</span>{{/if}}
          {{#if hq.renownMeter.slotsGain}}<span class="hq-uchip"><i class="fas fa-square-plus"></i> +{{hq.renownMeter.slotsGain}} {{localize "PROJECTANIME.HQ.slots"}}</span>{{/if}}
          {{#if hq.renownMeter.boardUnlock}}<span class="hq-uchip"><i class="fas fa-scroll"></i> {{localize "PROJECTANIME.HQ.missionBoard"}}</span>{{/if}}
          {{#if hq.renownMeter.isMax}}<span class="hq-uchip ready"><i class="fas fa-crown"></i> {{localize "PROJECTANIME.HQ.maxRank"}}</span>{{/if}}
        </div>
      </div>
      {{#unless hq.renownMeter.isMax}}
      <div class="hq-ren-seal next{{#if hq.renownMeter.ready}} ready{{/if}}">
        <span class="s-l">{{hq.renownMeter.nextKey}}</span>
        <span class="s-n">{{hq.renownMeter.nextName}}</span>
      </div>
      {{/unless}}
    </div>

    {{!-- ===================== NEEDS ATTENTION ===================== --}}
    {{#if hq.hasAttention}}
    <div class="hq-attn">
      {{#each hq.attention}}
      <button type="button" class="hq-callout {{tone}}" data-action="selectHqTab" data-hqtab="{{tab}}">
        <span class="cico"><i class="{{icon}}"></i></span>
        <span class="cbody"><span class="ct">{{title}}</span>{{#if sub}}<span class="cs">{{sub}}</span>{{/if}}</span>
        <span class="cgo"><i class="fas fa-chevron-right"></i></span>
      </button>
      {{/each}}
    </div>
    {{/if}}

    {{!-- ===================== NEXT-REST YIELD ===================== --}}
    {{#if hq.hasYields}}
    <div class="hq-yield">
      <div class="hq-yield-h"><i class="fas fa-hand-holding-heart"></i> {{localize "PROJECTANIME.HQ.nextRestHere"}}</div>
      <div class="hq-ychips">
        {{#each hq.yields}}<span class="hq-ychip"><span class="yi {{cls}}"></span> {{label}}{{#if sub}} <small>· {{sub}}</small>{{/if}}</span>{{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- ===================== TABS ===================== --}}
    <nav class="hq-tabs">
      <button type="button" class="hq-tab{{#if hq.hqTabIs.facilities}} active{{/if}}" data-action="selectHqTab" data-hqtab="facilities"><i class="fas fa-chess-rook"></i> {{localize "PROJECTANIME.HQ.facilities"}}{{#if hq.badges.facilities}} <span class="hq-badge g">{{hq.badges.facilities}}</span>{{/if}}</button>
      <button type="button" class="hq-tab{{#if hq.hqTabIs.residents}} active{{/if}}" data-action="selectHqTab" data-hqtab="residents"><i class="fas fa-users"></i> {{localize "PROJECTANIME.HQ.residents"}}{{#if hq.badges.residents}} <span class="hq-badge g">{{hq.badges.residents}}</span>{{/if}}</button>
      <button type="button" class="hq-tab{{#if hq.hqTabIs.missions}} active{{/if}}" data-action="selectHqTab" data-hqtab="missions"><i class="fas fa-scroll"></i> {{localize "PROJECTANIME.HQ.missionBoard"}}{{#if hq.badges.missions}} <span class="hq-badge">{{hq.badges.missions}}</span>{{/if}}</button>
    </nav>

    {{!-- ===================== FACILITIES ===================== --}}
    <div class="hq-tabpane{{#if hq.hqTabIs.facilities}} active{{/if}}" data-hqtab="facilities">
      {{#if isGM}}
      <div class="hq-shop-row">
        <button type="button" class="gbtn" data-action="hqVisitShop" data-vendor="gear"><i class="fas fa-hammer"></i> {{localize "PROJECTANIME.HQ.forgeShop"}}</button>
        <button type="button" class="gbtn" data-action="hqVisitShop" data-vendor="consumable"><i class="fas fa-mortar-pestle"></i> {{localize "PROJECTANIME.HQ.apothShop"}}</button>
        <button type="button" class="gbtn hq-structures-btn" data-action="openHqDrawer" data-hq-drawer="structures"><i class="fas fa-chess-rook"></i> {{localize "PROJECTANIME.HQ.structures"}}</button>
      </div>
      {{/if}}

      {{#if hq.hasFacilities}}
      <div class="hq-fac-grid">
        {{#each hq.facilities}}
        <div class="hq-fac{{#if stewarded}} staffed{{/if}}{{#if favorActive}} favor{{/if}}" data-fac-id="{{id}}" data-fac-name="{{name}}" data-fac-icon="{{icon}}">
          <div class="hq-fac-head">
            <span class="hq-fac-ic"><i class="{{icon}}"></i></span>
            <span class="hq-fac-name">{{name}}</span>
            {{#if upgraded}}<span class="hq-fac-badge up" title="{{localize 'PROJECTANIME.HQ.upgraded'}}"><i class="fas fa-star"></i></span>{{/if}}
            {{#if favorActive}}<span class="hq-fac-badge fav" title="{{localize 'PROJECTANIME.HQ.favorActive'}}"><i class="fas fa-heart"></i></span>{{/if}}
          </div>

          {{!-- Steward slot: portrait + (GM select / player name) + Bond rank; an empty seat is the CTA. --}}
          <div class="hq-steward{{#unless stewarded}} empty{{/unless}}">
            <span class="hq-av{{#unless stewarded}} empty{{/unless}}">
              {{#if stewarded}}{{#if stewardImg}}<img src="{{stewardImg}}" alt="">{{else}}{{stewardInitial}}{{/if}}{{else}}<i class="fas fa-plus"></i>{{/if}}
            </span>
            {{#if @root.isGM}}
            <select data-hq-steward="{{id}}">
              <option value="">{{localize "PROJECTANIME.HQ.unstaffed"}}</option>
              {{#each stewardOpts}}<option value="{{uuid}}"{{#if sel}} selected{{/if}}>{{name}}</option>{{/each}}
            </select>
            {{else}}
            <span class="hq-st-nm{{#unless stewarded}} cta{{/unless}}">{{#if stewarded}}{{stewardName}}{{else}}{{localize "PROJECTANIME.HQ.assignSteward"}}{{/if}}</span>
            {{/if}}
            {{#if stewarded}}<span class="hq-st-rank">{{stewardRankLetter}}</span>{{/if}}
          </div>

          {{#if activeLine}}<div class="hq-fac-yield"><i class="fas fa-caret-right"></i> {{activeLine}}</div>{{/if}}

          {{#if gathers}}
          <label class="hq-fac-gather">{{localize "PROJECTANIME.HQ.gatherType"}}
            <input type="text" data-hq-gather="{{id}}" data-slot="1" value="{{gatherType}}" placeholder="Ore, Herb…"{{#unless @root.isGM}} disabled{{/unless}}>
            {{#if upgraded}}<input type="text" data-hq-gather="{{id}}" data-slot="2" value="{{gatherType2}}" placeholder="…"{{#unless @root.isGM}} disabled{{/unless}}>{{/if}}
          </label>
          {{/if}}

          <div class="hq-fac-foot">
            {{#if upgraded}}
            <span class="hq-upg maxed"><i class="fas fa-star"></i> {{localize "PROJECTANIME.HQ.maxed"}}</span>
            {{else if @root.isGM}}
            <button type="button" class="hq-upg{{#if upgradeAffordable}} ok{{else}}{{#if canUpgrade}} poor{{else}} dis{{/if}}{{/if}}" data-action="hqUpgrade" title="{{upgradeReason}}"{{#unless canUpgrade}} disabled{{/unless}}><i class="fas fa-star"></i> {{localize "PROJECTANIME.HQ.upgrade"}} <span class="cost">{{upgradeCost}}G</span></button>
            {{else if upgradePreview}}
            <span class="hq-upg-prev"><i class="fas fa-star"></i> {{upgradePreview}}</span>
            {{/if}}
            {{#if @root.isGM}}<button type="button" class="hq-fac-x" data-action="hqDemolish" title="{{localize 'PROJECTANIME.HQ.demolish'}}"><i class="fas fa-trash"></i></button>{{/if}}
          </div>
          {{#if @root.isGM}}{{#unless upgraded}}{{#if upgradePreview}}<div class="hq-upg-prev sm"><i class="fas fa-star"></i> {{upgradePreview}}</div>{{/if}}{{/unless}}{{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="hq-empty sm"><i class="fas fa-helmet-safety"></i><p>{{localize "PROJECTANIME.HQ.noBuildings"}}</p></div>
      {{/if}}
    </div>

    {{!-- ===================== RESIDENTS ===================== --}}
    <div class="hq-tabpane{{#if hq.hqTabIs.residents}} active{{/if}}" data-hqtab="residents">
      {{#if hq.hasResidents}}
      <div class="hq-resident-list">
        {{#each hq.residents}}
        <div class="hq-resident" data-res-uuid="{{uuid}}">
          <img class="hq-resident-img" src="{{img}}" alt="">
          <div class="hq-resident-body">
            <div class="hq-resident-top"><span class="hq-resident-nm">{{name}}</span> <span class="hq-resident-rank">{{bondRank}}</span></div>
            <div class="hq-resident-ctl">
              <label class="hq-mini"><i class="fas fa-heart"></i>
                <select data-hq-favored="{{uuid}}"{{#unless @root.isGM}} disabled{{/unless}}>
                  <option value="">{{localize "PROJECTANIME.HQ.favoredNone"}}</option>
                  {{#each favoredOptions}}<option value="{{name}}" data-icon="{{icon}}"{{#if sel}} selected{{/if}}>{{name}}</option>{{/each}}
                </select>
              </label>
              <label class="hq-mini"><i class="fas fa-user-tie"></i>
                <select data-hq-res-steward="{{uuid}}"{{#unless @root.isGM}} disabled{{/unless}}>
                  <option value="">{{localize "PROJECTANIME.HQ.noPost"}}</option>
                  {{#each facilityOpts}}<option value="{{id}}"{{#if sel}} selected{{/if}}>{{name}}</option>{{/each}}
                </select>
              </label>
            </div>
          </div>
          {{#if @root.isGM}}<button type="button" class="gbtn sm danger hq-resident-out" data-action="hqMoveOut" title="{{localize 'PROJECTANIME.HQ.moveOut'}}"><i class="fas fa-door-open"></i></button>{{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="hq-empty sm"><i class="fas fa-users-slash"></i><p>{{localize "PROJECTANIME.HQ.noResidents"}}</p></div>
      {{/if}}

      {{#if hq.hasCandidates}}
      <div class="hq-cand">
        <h4>{{localize "PROJECTANIME.HQ.candidates"}}</h4>
        <div class="hq-cand-list">
          {{#each hq.candidates}}
          <div class="hq-cand-card">
            <img src="{{img}}" alt=""><span class="hq-cand-nm">{{name}}</span><span class="hq-resident-rank">{{bondRank}}</span>
            {{#if @root.isGM}}<button type="button" class="gbtn sm" data-action="hqMoveIn" data-uuid="{{uuid}}"><i class="fas fa-door-closed"></i> {{localize "PROJECTANIME.HQ.moveIn"}}</button>{{/if}}
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <details class="hq-asks">
        <summary>{{localize "PROJECTANIME.HQ.asksTitle"}}</summary>
        <ul>{{#each hq.askShapes}}<li><b>{{label}}</b> — {{hint}}</li>{{/each}}</ul>
      </details>
    </div>

    {{!-- ===================== MISSION BOARD ===================== --}}
    <div class="hq-tabpane{{#if hq.hqTabIs.missions}} active{{/if}}" data-hqtab="missions">
      {{#unless hq.missionBoardOpen}}
      <div class="hq-empty sm"><i class="fas fa-lock"></i><p>{{localize "PROJECTANIME.HQ.boardLocked"}}</p></div>
      {{else}}
      <div class="hq-board-head">
        <span class="hq-cap"><i class="fas fa-scroll"></i> {{hq.activeCount}}/{{hq.missionCap}} {{localize "PROJECTANIME.HQ.active"}}</span>
        {{#if isGM}}<button type="button" class="gbtn sm" data-action="hqNewMission"><i class="fas fa-plus"></i> {{localize "PROJECTANIME.HQ.newMission"}}</button>{{/if}}
      </div>
      {{#if hq.hasMissions}}
      <div class="hq-msn-list">
        {{#each hq.missions}}
        <div class="hq-msn status-{{status}}" data-msn-id="{{id}}">
          <div class="hq-msn-head">
            {{#if img}}<img class="hq-msn-img" src="{{img}}" alt=""{{#if @root.isGM}} data-action="hqPickMissionImage"{{/if}}>{{else}}{{#if @root.isGM}}<button type="button" class="hq-msn-img ph" data-action="hqPickMissionImage"><i class="fas fa-image"></i></button>{{/if}}{{/if}}
            {{#if @root.isGM}}
            <input class="hq-msn-title" data-hq-msn="{{id}}" data-field="title" value="{{title}}" placeholder="{{localize 'PROJECTANIME.HQ.missionUntitled'}}"{{#if isActive}} disabled{{/if}}>
            {{else}}<span class="hq-msn-title">{{title}}</span>{{/if}}
            <span class="hq-msn-status">{{#if isActive}}<i class="fas fa-hourglass-half"></i> {{restsLeft}}{{else}}{{#if isDone}}<i class="fas fa-flag-checkered"></i> {{result}}{{/if}}{{/if}}</span>
          </div>
          <div class="hq-msn-meta">
            {{#if @root.isGM}}
            <select data-hq-msn="{{id}}" data-field="type"{{#if isActive}} disabled{{/if}}>{{#each typeOptions}}<option value="{{key}}"{{#if sel}} selected{{/if}}>{{label}}</option>{{/each}}</select>
            <label class="hq-mini">{{localize "PROJECTANIME.HQ.duration"}} <select data-hq-msn="{{id}}" data-field="duration"{{#if isActive}} disabled{{/if}}>{{#each durationOptions}}<option value="{{n}}"{{#if sel}} selected{{/if}}>{{n}}</option>{{/each}}</select></label>
            <label class="hq-mini hq-hard"><input type="checkbox" data-hq-msn="{{id}}" data-field="hard"{{#if hard}} checked{{/if}}{{#if isActive}} disabled{{/if}}> {{localize "PROJECTANIME.HQ.hard"}}</label>
            {{else}}
            <span class="hq-chip">{{typeLabel}}</span><span class="hq-chip">{{duration}} {{localize "PROJECTANIME.HQ.rests"}}</span>{{#if hard}}<span class="hq-chip hard">{{localize "PROJECTANIME.HQ.hard"}}</span>{{/if}}
            {{/if}}
          </div>
          {{#if @root.isGM}}
          <div class="hq-msn-suited">
            <span class="hq-lbl">{{localize "PROJECTANIME.HQ.suited"}}:</span>
            {{#each suitedOptions}}<button type="button" class="hq-suit{{#if sel}} on{{/if}}" data-action="hqToggleSuited" data-key="{{key}}"{{#if ../isActive}} disabled{{/if}}>{{label}}</button>{{/each}}
          </div>
          <div class="hq-msn-reward">
            <label class="hq-mini">{{localize "PROJECTANIME.HQ.rewardGold"}} <input type="number" min="0" data-hq-msn="{{id}}" data-field="rewardGold" value="{{rewardGold}}"></label>
            <input class="hq-msn-rw" data-hq-msn="{{id}}" data-field="reward" value="{{reward}}" placeholder="{{rewardNote}}">
            <input class="hq-msn-rw" data-hq-msn="{{id}}" data-field="risk" value="{{risk}}" placeholder="{{localize 'PROJECTANIME.HQ.risk'}}">
          </div>
          {{else}}
          {{#if suited.length}}<div class="hq-msn-suited"><span class="hq-lbl">{{localize "PROJECTANIME.HQ.suited"}}:</span> {{#each suited}}<span class="hq-chip">{{this}}</span>{{/each}}</div>{{/if}}
          {{#if reward}}<div class="hq-msn-rwtext"><i class="fas fa-gift"></i> {{reward}}</div>{{/if}}
          {{/if}}

          {{!-- Team --}}
          <div class="hq-msn-team">
            {{#if isActive}}
            <span class="hq-lbl">{{localize "PROJECTANIME.HQ.team"}}:</span>
            {{#each team}}<span class="hq-tmember" title="{{name}}"><img src="{{img}}" alt=""> {{name}}</span>{{/each}}
            {{#if @root.isGM}}<button type="button" class="gbtn sm" data-action="hqRecall"><i class="fas fa-rotate-left"></i> {{localize "PROJECTANIME.HQ.recall"}}</button>{{/if}}
            {{else}}{{#unless isDone}}{{#if @root.isGM}}
            <div class="hq-pick-row">
              {{#each pickable}}
              <button type="button" class="hq-pick{{#if chosen}} on{{/if}}{{#if suited}} suit{{/if}}" data-action="hqToggleTeam" data-uuid="{{uuid}}" title="{{name}}{{#if suited}} · {{localize 'PROJECTANIME.HQ.suitedTip'}}{{/if}}"><img src="{{img}}" alt=""></button>
              {{/each}}
            </div>
            <button type="button" class="gbtn sm hq-dispatch" data-action="hqDispatch"{{#unless canDispatch}} disabled{{/unless}}><i class="fas fa-paper-plane"></i> {{localize "PROJECTANIME.HQ.dispatch"}}</button>
            {{/if}}{{/unless}}{{/if}}
          </div>
          {{#if @root.isGM}}{{#unless isActive}}<button type="button" class="gbtn sm danger hq-msn-del" data-action="hqDeleteMission" title="{{localize 'PROJECTANIME.HQ.deleteMission'}}"><i class="fas fa-trash"></i></button>{{/unless}}{{/if}}
        </div>
        {{/each}}
      </div>
      {{/if}}
      {{/unless}}
    </div>

    {{/unless}}
  </div>

  {{!-- ===================== STRUCTURES (build menu — slide-in drawer) ===================== --}}
  {{#if hq.established}}{{#if isGM}}
  <aside class="section-drawer{{#if hq.structuresDrawerOpen}} open{{/if}}" data-drawer="structures">
    <div class="drawer-backdrop" data-action="closeHqDrawer"></div>
    <div class="drawer-panel hq-structures-panel">
      <a class="bk-close" data-action="closeHqDrawer" title="{{localize 'PROJECTANIME.Defenses.close'}}"><i class="fa-solid fa-xmark"></i></a>
      <div class="hq-structures-head"><i class="fas fa-chess-rook"></i> {{localize "PROJECTANIME.HQ.structures"}} <span class="hq-cap">{{hq.status.facilities}}/{{hq.status.cap}}</span></div>
      {{#if hq.hasBuildable}}
      <div class="hq-build-grid">
        {{#each hq.buildable}}
        <button type="button" class="hq-build-card{{#if locked}} locked{{/if}}{{#unless affordable}} poor{{/unless}}" data-action="hqBuild" data-key="{{key}}"{{#if locked}} disabled{{/if}} title="{{#unless rankMet}}{{localize 'PROJECTANIME.HQ.rankReqShort'}} {{rank}}{{/unless}}">
          <span class="hq-build-ic"><i class="{{icon}}"></i></span>
          <span class="hq-build-nm">{{name}}</span>
          <span class="hq-build-cost">{{cost}}G · {{rank}}</span>
        </button>
        {{/each}}
      </div>
      {{else}}
      <div class="hq-empty sm"><i class="fas fa-circle-check"></i><p>{{localize "PROJECTANIME.HQ.allBuilt"}}</p></div>
      {{/if}}
      {{#if hq.canCustom}}<button type="button" class="gbtn hq-custom" data-action="hqCustom"><i class="fas fa-star"></i> {{localize "PROJECTANIME.HQ.customAdd"}} ({{hq.customCount}}/{{hq.customMax}})</button>{{/if}}
    </div>
  </aside>
  {{/if}}{{/if}}
</section>
