{{!-- Codex CODEX/ARCHIVE pane — a tabbed in-world encyclopedia (Enemies / NPCs / Locations / Items …).
      Carries BOTH `pa-hq` (so the HQ tarot-card, sub-nav and book-drawer styling applies verbatim) and
      `pa-archive` (the encyclopedia's own bits: locked "???" cards, tag chips, the stat-block readout,
      the reveal toggle, and the GM category toolbar). Mirrors templates/codex/hq.hbs. --}}
<section class="codex-pane pa-hq pa-archive{{#if onArchive}} active{{/if}}" data-pane="archive">
  <div class="arc-scroll">

    {{!-- ===================== HEADER ===================== --}}
    <div class="arc-head">
      <h3><i class="fas fa-book-skull"></i> {{localize "PROJECTANIME.Archive.title"}}</h3>
      {{#if isGM}}<button type="button" class="gbtn" data-action="newArchiveCategory"><i class="fas fa-folder-plus"></i> {{localize "PROJECTANIME.Archive.newCategory"}}</button>{{/if}}
    </div>

    {{#if archive.hasCategories}}
    {{!-- ===================== CATEGORY SUB-TABS ===================== --}}
    <div class="hq-subnav arc-subnav">
      {{#each archive.categories}}
      <button type="button" class="hq-tab{{#if active}} active{{/if}}" data-action="selectArchiveTab" data-arctab="{{id}}"><i class="fas {{icon}}"></i> <span>{{label}}</span>{{#if count}} <span class="nb">{{count}}</span>{{/if}}</button>
      {{/each}}
    </div>

    {{!-- ===================== PER-CATEGORY PANES ===================== --}}
    {{#each archive.categories}}
    <div class="hq-tabpane arc-pane{{#if active}} active{{/if}}" data-arctab="{{id}}">

      {{#if cards.length}}
      <div class="tgrid arc-grid">
        {{#each cards}}{{> "systems/project-anime/templates/codex/archive-card.hbs" isGM=@root.isGM}}{{/each}}
      </div>
      {{else}}
      <div class="hq-empty sm"><i class="fas {{icon}}"></i><p>{{localize "PROJECTANIME.Archive.empty"}}</p></div>
      {{/if}}

      {{#if @root.isGM}}
      <div class="arc-foot">
        <button type="button" class="arc-new-entry" data-action="newArchiveEntry" data-arctab="{{id}}"><i class="fas fa-plus"></i> {{localize "PROJECTANIME.Archive.newEntry"}}</button>
        <div class="rec-drop arc-drop" data-archive-drop="{{id}}"><i class="fas fa-hand-pointer"></i> <span class="frew-drop-hint">{{localize "PROJECTANIME.Archive.dropHint"}}</span></div>
      </div>
      {{/if}}

    </div>
    {{/each}}
    {{else}}
    <div class="hq-empty"><i class="fas fa-book-skull"></i><p>{{localize "PROJECTANIME.Archive.noCategories"}}</p></div>
    {{/if}}

  </div>{{!-- /.arc-scroll --}}

  {{!-- ===================== ENTRY DETAIL BOOKS (flat; one open at a time) ===================== --}}
  {{#each archive.books}}{{> "systems/project-anime/templates/codex/archive-book.hbs" isGM=@root.isGM}}{{/each}}

</section>
