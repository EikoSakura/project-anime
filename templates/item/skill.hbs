{{!-- Technique — edit pane: a read-only build summary (editing routes through the Technique
      Builder wizard) plus the fields that live outside the wizard. --}}
<section class="item-body skill-builder tab-pane{{#if tabEdit}} active{{/if}}" data-tab-pane="edit">

  <div class="build-summary">
    <span>{{localize (lookup config.actionTypes system.actionType)}}</span>
    {{#if (eq system.actionType "passive")}}<span>{{localize (lookup config.passiveModes system.passiveMode)}}</span>{{/if}}
    {{#if system.energyCost}}<span>{{localize "PROJECTANIME.Skill.field.energyCost"}}: <strong>{{system.energyCost}}</strong></span>{{/if}}
    {{#if system.passiveEnergyTax}}<span>{{localize "PROJECTANIME.Skill.field.energyLock"}}: <strong>{{system.passiveEnergyTax}}</strong></span>{{/if}}
  </div>

  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.details"}}</h4>
    <div class="form-grid">
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.effect"}}</label>
        <span>{{localize (lookup config.skillEffects system.effect)}}</span>
      </div>
      {{#if system.secondaryEffect}}
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.secondaryEffect"}}</label>
        <span>{{localize (lookup config.skillEffects system.secondaryEffect)}}</span>
      </div>
      {{/if}}
      <div class="form-group">
        <label>{{localize "PROJECTANIME.SkillBuilder.roll"}}</label>
        <span>{{#if system.talentId}}{{localize "PROJECTANIME.Skill.field.talent"}}{{else}}{{localize (lookup config.attributes system.attributes.attrA)}} + {{localize (lookup config.attributes system.attributes.attrB)}}{{/if}}</span>
      </div>
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.range"}}</label>
        <span>{{localize (lookup config.ranges system.range.scope)}}{{#if (eq system.range.scope "tiles")}} · {{system.range.tiles}} {{localize "PROJECTANIME.Skill.tiles"}}{{/if}}</span>
      </div>
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.target"}}</label>
        <span>{{localize (lookup config.skillTargets system.target)}}</span>
      </div>
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.duration"}}</label>
        <span>{{localize (lookup config.skillDurations system.duration)}}{{#if (eq system.duration "standard")}}{{#if system.effectDuration}} · {{system.effectDuration}} {{localize "PROJECTANIME.Skill.turns"}}{{/if}}{{/if}}</span>
      </div>
      {{#if system.controlElement}}
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.controlElement"}}</label>
        <span>{{system.controlElement}}</span>
      </div>
      {{/if}}
      {{#if (eq system.actionType "react")}}
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.trigger"}}</label>
        <span>{{localize (lookup config.triggers system.trigger)}}</span>
      </div>
      {{/if}}
    </div>
  </div>

  {{#if system.modifiers.length}}
  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Skill.field.modifiers"}} <span class="muted">(+{{system.modifiersUsed}})</span></h4>
    <div class="form-grid">
      <div class="form-group span-2">
        <span>{{#each system.modifiers as |m|}}{{localize (lookup ../config.skillModifiers m)}}{{#if (eq m "potent")}}{{#if (eq ../system.potentCount 2)}} ×2{{/if}}{{/if}}{{#unless @last}}, {{/unless}}{{/each}}</span>
      </div>
    </div>
  </div>
  {{/if}}

  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.properties"}}</h4>
    <div class="form-grid">
      <div class="form-group">
        <label>{{localize "PROJECTANIME.Skill.field.usesPerConflict"}}</label>
        <input type="number" name="system.usesPerConflict" value="{{system.usesPerConflict}}" min="0" step="1" />
      </div>
    </div>
  </div>

  {{!-- Optional override: when non-blank, replaces the auto-written rules on the View tab + card.
        Numbers auto-color blue; Highlight/Gold wrap the selection; Start From Auto seeds the box. --}}
  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Skill.auto.rulesOverride"}}</h4>
    <div class="rules-override-tools">
      <button type="button" class="rules-tool" data-action="rulesMark" data-mark="blue"
        title="{{localize 'PROJECTANIME.Skill.auto.markBlueHint'}}">
        <i class="fa-solid fa-highlighter"></i> {{localize "PROJECTANIME.Skill.auto.markBlue"}}
      </button>
      <button type="button" class="rules-tool rules-tool-gold" data-action="rulesMark" data-mark="gold"
        title="{{localize 'PROJECTANIME.Skill.auto.markGoldHint'}}">
        <i class="fa-solid fa-star"></i> {{localize "PROJECTANIME.Skill.auto.markGold"}}
      </button>
      <button type="button" class="rules-tool rules-tool-seed" data-action="rulesFromAuto"
        title="{{localize 'PROJECTANIME.Skill.auto.fromAutoHint'}}">
        <i class="fa-solid fa-wand-magic-sparkles"></i> {{localize "PROJECTANIME.Skill.auto.fromAuto"}}
      </button>
    </div>
    <textarea name="system.rulesOverride" class="rules-override-input" rows="3">{{system.rulesOverride}}</textarea>
  </div>
</section>
