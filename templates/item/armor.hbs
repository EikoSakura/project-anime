{{!-- Armor details --}}
<section class="item-body tab-pane{{#if tabEdit}} active{{/if}}" data-tab-pane="edit">
  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.defense"}}</h4>
    <div class="form-grid">
      <div class="form-group span-2 style-picker"><label>{{localize "PROJECTANIME.Field.style"}}</label>
        <div class="style-tiles">
          {{#each styleTiles as |s|}}
          <button type="button" class="style-tile{{#if s.selected}} on{{/if}}" data-action="setStyle" data-style="{{s.key}}" data-tooltip="{{s.tooltip}}" data-tooltip-class="pa-tooltip" aria-label="{{s.label}}">
            <img src="{{s.icon}}" alt="{{s.label}}" />
          </button>
          {{/each}}
        </div>
      </div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Stat.guard"}}</label>
        <input type="number" name="system.guardBonus" value="{{system.guardBonus}}" min="0" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Stat.movement"}}</label>
        <input type="number" name="system.movement" value="{{system.movement}}" min="0" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.energyRegen"}}</label>
        <input type="number" name="system.energyRegen" value="{{system.energyRegen}}" min="0" /></div>
    </div>
  </div>

  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.equipment"}}</h4>
    <div class="form-grid">
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.cost"}}</label>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" /></div>
      <div class="form-group checkbox"><label>{{localize "PROJECTANIME.Field.equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} /></div>
    </div>
  </div>
</section>
