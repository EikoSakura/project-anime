{{!-- Material details (v0.03 Crafting) — grade × Tier × type; the name is free flavor. --}}
<section class="item-body tab-pane{{#if tabEdit}} active{{/if}}" data-tab-pane="edit">
  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Material.label"}}</h4>
    <div class="form-grid">
      <div class="form-group"><label>{{localize "PROJECTANIME.Material.gradeLabel"}}</label>
        <select name="system.grade">{{selectOptions config.materialGrades selected=system.grade localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Material.typeLabel"}}</label>
        <select name="system.category">{{selectOptions config.materialTypes selected=system.category localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Material.tier"}}</label>
        <select name="system.tier">{{selectOptions materialTierChoices selected=system.tier}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Material.quantity"}}</label>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" /></div>
    </div>
  </div>
</section>
