{{!-- Weapon details --}}
<section class="item-body tab-pane{{#if tabEdit}} active{{/if}}" data-tab-pane="edit">
  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.attack"}}</h4>
    <div class="form-grid">
      <div class="form-group span-2 style-picker"><label>{{localize "PROJECTANIME.Field.style"}}</label>
        <div class="style-tiles">
          {{#each styleTiles as |s|}}
          <button type="button" class="style-tile{{#if s.selected}} on{{/if}}" data-action="setStyle" data-style="{{s.key}}" data-tooltip="{{s.tooltip}}" data-tooltip-class="pa-tooltip" aria-label="{{s.label}}">
            <img src="{{s.icon}}" alt="{{s.label}}" />
          </button>
          {{/each}}
        </div>
      </div>
      <div class="form-group span-2"><label>{{localize "PROJECTANIME.Field.weaponType"}}</label>
        <input type="text" name="system.weaponType" value="{{system.weaponType}}" /></div>
      {{!-- The Paired Attribute + the fallback second Attribute (rolled when no Talent applies). --}}
      <div class="form-group span-2 accuracy-pair"><label>{{localize "PROJECTANIME.Field.accuracy"}}</label>
        <div class="acc-attrs">
          <select name="system.accuracy.attrA">{{selectOptions config.attributes selected=system.accuracy.attrA localize=true}}</select>
          <span class="acc-plus">+</span>
          <select name="system.accuracy.attrB">{{selectOptions config.attributes selected=system.accuracy.attrB localize=true}}</select>
        </div>
      </div>
      {{#if talentChoices}}
      <div class="form-group span-2"><label>{{localize "PROJECTANIME.Field.talent"}}</label>
        <select name="system.talentId">
          <option value=""></option>
          {{#each talentChoices as |t|}}
          <option value="{{t.id}}" {{#if t.selected}}selected{{/if}}>{{t.name}} (d{{t.die}})</option>
          {{/each}}
        </select></div>
      {{/if}}
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.accuracyMod"}}</label>
        <input type="number" name="system.accuracy.mod" value="{{system.accuracy.mod}}" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.weaponDmg"}}</label>
        <input type="number" name="system.damage.value" value="{{system.damage.value}}" min="0" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.threshold"}}</label>
        <input type="number" name="system.threshold" value="{{system.threshold}}" min="0" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.rangeMin"}}</label>
        <input type="number" name="system.range.minTiles" value="{{system.range.minTiles}}" min="0" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.range"}}</label>
        <input type="number" name="system.range.tiles" value="{{system.range.tiles}}" min="0" /></div>
    </div>
  </div>

  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.properties"}}</h4>
    <div class="form-grid">
      <div class="form-group span-2 fg-center"><label>{{localize "PROJECTANIME.Field.handedness"}}</label>
        <div class="pa-seg-toggle" role="group" aria-label="{{localize 'PROJECTANIME.Field.handedness'}}">
          <button type="button" class="seg-opt{{#unless system.twoHandedOnly}} on{{/unless}}" data-action="setTwoHanded" data-two="false">{{localize "PROJECTANIME.Grip.one"}}</button>
          <button type="button" class="seg-opt{{#if system.twoHandedOnly}} on{{/if}}" data-action="setTwoHanded" data-two="true">{{localize "PROJECTANIME.Grip.two"}}</button>
        </div>
      </div>
      <div class="form-group fg-center"><label>{{localize "PROJECTANIME.Field.dualWield"}}</label>
        <input type="checkbox" name="system.dual" {{checked system.dual}} /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.cost"}}</label>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" /></div>
    </div>
  </div>
</section>
