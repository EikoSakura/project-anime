{{!-- Weapon details --}}
<section class="item-body tab-pane{{#if tabEdit}} active{{/if}}" data-tab-pane="edit">
  <p class="formula-preview">{{localize "PROJECTANIME.Field.accuracy"}}: <strong>{{accuracyFormula}}</strong></p>

  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.attack"}}</h4>
    <div class="form-grid">
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.accuracyA"}}</label>
        <select name="system.accuracy.attrA">{{selectOptions config.attributes selected=system.accuracy.attrA localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.accuracyB"}}</label>
        <select name="system.accuracy.attrB">{{selectOptions config.attributes selected=system.accuracy.attrB localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.accuracyMod"}}</label>
        <input type="number" name="system.accuracy.mod" value="{{system.accuracy.mod}}" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.damageMod"}}</label>
        <input type="number" name="system.damage.mod" value="{{system.damage.mod}}" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.damageType"}}</label>
        <select name="system.damage.type">{{selectOptions damageTypeChoices selected=system.damage.type}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.rangeType"}}</label>
        <select name="system.range.type">{{selectOptions config.rangeTypes selected=system.range.type localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.rangeTiles"}}</label>
        <input type="number" name="system.range.tiles" value="{{system.range.tiles}}" min="0" /></div>
    </div>
  </div>

  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.equipment"}}</h4>
    <div class="form-grid">
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.hand"}}</label>
        <select name="system.hand">{{selectOptions config.hands selected=system.hand localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.grip"}}</label>
        <select name="system.grip">{{selectOptions config.grips selected=system.grip localize=true}}</select></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.size"}}</label>
        <input type="number" name="system.size" value="{{system.size}}" min="0" /></div>
      <div class="form-group"><label>{{localize "PROJECTANIME.Field.cost"}}</label>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" /></div>
      <div class="form-group checkbox"><label>{{localize "PROJECTANIME.Field.equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} /></div>
    </div>
  </div>
</section>
