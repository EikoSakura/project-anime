{{!-- Accessory details (effect goes in the description) — compact label—field rows. --}}
<section class="item-body tab-pane{{#if tabDetails}} active{{/if}}" data-tab-pane="details">
  <div class="form-section">
    <h4 class="form-section-title">{{localize "PROJECTANIME.Section.details"}}</h4>
    <div class="detail-rows">
      <div class="detail-row"><label>{{localize "PROJECTANIME.Field.size"}}</label>
        <input type="number" name="system.size" value="{{system.size}}" min="0" /></div>
      <div class="detail-row"><label>{{localize "PROJECTANIME.Field.cost"}}</label>
        <input type="number" name="system.cost" value="{{system.cost}}" min="0" /></div>
      <div class="detail-row"><label>{{localize "PROJECTANIME.Field.equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}} /></div>
    </div>
  </div>
</section>
