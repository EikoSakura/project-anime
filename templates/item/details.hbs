{{!-- View tab: read-only display. Skills show the auto-written (or overridden) rules summary;
      every other item type shows its stat-row table. The typed description is FLAVOR shown below. --}}
<section class="item-details tab-pane{{#if tabView}} active{{/if}}" data-tab-pane="view">
  {{#if skillRules}}
  <div class="skill-rules-view">{{{skillRules}}}</div>
  {{#if enrichedDescription}}
  <div class="skill-flavor">
    <div class="pa-rules-h">{{localize "PROJECTANIME.Field.description"}}</div>
    <div class="detail-desc">{{{enrichedDescription}}}</div>
  </div>
  {{/if}}
  {{else}}
  <dl class="detail-list">
    {{#each displayStats as |row|}}
    <div class="detail-row">
      <dt>{{localize row.label}}</dt>
      <dd>{{row.value}}</dd>
    </div>
    {{/each}}
    {{#if enrichedDescription}}
    <div class="detail-row detail-desc-row">
      <dt>{{localize "PROJECTANIME.Field.description"}}</dt>
      <div class="detail-desc">{{{enrichedDescription}}}</div>
    </div>
    {{/if}}
  </dl>
  {{/if}}
</section>
