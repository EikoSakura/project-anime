{{!-- Persistent side panel (Character & NPC) — Log Horizon-style status panel --}}
<header class="sheet-header">
  <div class="portrait portrait-card">
    <div class="portrait-frame">
      <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img"
           title="{{actor.name}}" alt="{{actor.name}}" />
    </div>
    <i class="stud stud-n"></i>
    <i class="stud stud-e"></i>
    <i class="stud stud-s"></i>
    <i class="stud stud-w"></i>
  </div>

  <input class="char-name" type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'Name'}}" />

  {{#if isCharacter}}
  <div class="header-actions">
    <button type="button" class="advance-btn create-btn" data-action="openCreator" title="{{localize 'PROJECTANIME.Creator.title'}}">
      <i class="fas fa-user-plus"></i><span>{{localize "PROJECTANIME.Creator.open"}}</span>
    </button>
    <button type="button" class="advance-btn" data-action="openAdvancement" title="{{localize 'PROJECTANIME.Advancement.title'}}">
      <i class="fas fa-arrow-up-right-dots"></i><span>{{localize "PROJECTANIME.Advancement.open"}}</span>
    </button>
    <button type="button" class="advance-btn rest-btn" data-action="openRest" title="{{localize 'PROJECTANIME.Rest.title'}}">
      <i class="fas fa-campground"></i><span>{{localize "PROJECTANIME.Rest.open"}}</span>
    </button>
  </div>
  {{/if}}

  {{#if isNPC}}
  <div class="header-actions">
    <button type="button" class="advance-btn create-btn" data-action="openCreator" title="{{localize 'PROJECTANIME.MonsterCreator.title'}}">
      <i class="fas fa-dragon"></i><span>{{localize "PROJECTANIME.MonsterCreator.open"}}</span>
    </button>
    <select name="system.disposition">{{selectOptions config.dispositions selected=system.disposition localize=true}}</select>
  </div>
  {{/if}}

  <div class="header-sub">
    {{#if isCharacter}}
    <input class="pronouns" type="text" name="system.pronouns" value="{{system.pronouns}}"
           placeholder="{{localize 'PROJECTANIME.Field.pronouns'}}" />
    {{/if}}
    {{#if isNPC}}
    {{#if tierBadge}}
    <span class="tier-badge" style="--tier-color: {{tierBadge.color}}" title="{{tierBadge.label}}">
      <i class="{{tierBadge.icon}}"></i><span>{{tierBadge.label}}</span>
    </span>
    {{#if tierBadge.rival}}<span class="enemy-chip rival" title="{{localize 'PROJECTANIME.Rival.badgeHint'}}"><i class="fas fa-chess-king"></i>{{localize "PROJECTANIME.Rival.badge"}}</span>{{/if}}
    {{#if tierBadge.boss}}<span class="enemy-chip boss" title="{{localize 'PROJECTANIME.Boss.badgeHint'}}"><i class="fas fa-crown"></i>{{localize "PROJECTANIME.Boss.badge"}}</span>{{/if}}
    <span class="enemy-threat" title="{{localize 'PROJECTANIME.Threat.hint'}}"><i class="fas fa-skull"></i>{{tierBadge.threat}}</span>
    {{/if}}
    {{/if}}
  </div>

  {{#if isCharacter}}
  <div class="panel-rule"></div>
  <div class="panel-attrs">
    {{#each attributeList as |attr|}}
    <div class="pattr" data-attribute="{{attr.key}}">
      <div class="pattr-die rollable" data-action="rollCheck" data-attribute="{{attr.key}}" title="{{localize 'PROJECTANIME.Roll.checkHint'}}"><span>{{attr.die}}</span></div>
      <label class="pattr-base" title="{{localize 'PROJECTANIME.Field.base'}}"><input class="attr-base" type="number" name="system.attributes.{{attr.key}}.base" value="{{attr.base}}" min="4" max="12" step="2" /></label>
      <span class="pattr-name">{{#if attr.icon}}<i class="attr-icon {{attr.icon}}"></i>{{/if}}<span>{{attr.short}}</span></span>
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if bossBars}}
  <div class="boss-bars" title="{{localize 'PROJECTANIME.Boss.barsHint'}}">
    <span class="boss-bars-label">{{localize "PROJECTANIME.Boss.bars"}}</span>
    <span class="boss-bars-pips">{{#each bossBars.pips}}<i class="boss-pip{{#if this.full}} full{{/if}}"></i>{{/each}}</span>
    <span class="boss-bars-count">{{bossBars.remaining}}/{{bossBars.total}}</span>
  </div>
  {{/if}}

  <div class="panel-rule"></div>

  <div class="panel-resources">
    <div class="resource hp">
      <div class="resource-top">
        <label>{{localize "PROJECTANIME.Stat.hp"}}</label>
        <span class="resource-vals">
          {{!-- Reads in MARKS (0 = untouched), not remaining — no `name`, persisted by #bindMarkedInputs. --}}
          <input type="number" data-marked="hp" value="{{hpMarked}}" min="0" max="{{system.hp.max}}" />
          <span class="sep">/</span>
          {{!-- Shows the EFFECTIVE maximum (authored − Wound locks; a Boss shows its Bar HP). NO
                `name`: the form's submitOnChange would write this derived number back into the
                authored max on every edit, compounding one box away per Wound. #bindHpMax persists
                the AUTHORED max instead (entered + current Wound locks). --}}
          <input type="number" data-hp-max value="{{system.hp.max}}" min="0" />
        </span>
      </div>
      <div class="boxes">{{#each hpBoxes as |b|}}{{#if b.locked}}<span class="mark-box locked"><i class="fa-solid fa-lock"></i></span>{{else}}<button type="button" class="mark-box{{#if b.marked}} marked{{/if}}" data-action="setResourceBox" data-resource="hp" data-n="{{b.n}}" aria-label="{{localize 'PROJECTANIME.Stat.hp'}} {{b.n}}" aria-pressed="{{b.marked}}"></button>{{/if}}{{/each}}</div>
      {{#if woundCount}}
      <div class="squad-line muted" title="{{localize 'PROJECTANIME.Wound.hint'}}"><i class="fas fa-heart-crack"></i> {{woundCount}} {{localize "PROJECTANIME.Wound.plural"}}</div>
      {{/if}}
    </div>
    <div class="resource energy">
      <div class="resource-top">
        <label>{{localize "PROJECTANIME.Stat.energy"}}</label>
        <span class="resource-vals">
          {{!-- Reads in MARKS (0 = untouched), not remaining — no `name`, persisted by #bindMarkedInputs. --}}
          <input type="number" data-marked="energy" value="{{energyMarked}}" min="0" max="{{system.energy.max}}" />
          <span class="sep">/</span>
          {{!-- The Max field shows the EFFECTIVE maximum (authored − passive/servant tax) so it visibly
                drops as passives are added. It carries data-energy-max and NO `name`, so the sheet's
                submitOnChange never collects it — otherwise editing Current would write this taxed
                number back into storage and the next prepare would re-tax it (compounding). Edits are
                persisted by #bindEnergyMax, which stores the AUTHORED max (entered + current tax) so the
                tax is re-derived rather than baked in. --}}
          <input type="number" data-energy-max value="{{system.energy.max}}" min="0" />
        </span>
      </div>
      <div class="boxes">{{#each energyBoxes as |b|}}{{#if b.locked}}<span class="mark-box locked"><i class="fa-solid fa-lock"></i></span>{{else}}<button type="button" class="mark-box{{#if b.marked}} marked{{/if}}" data-action="setResourceBox" data-resource="energy" data-n="{{b.n}}" aria-label="{{localize 'PROJECTANIME.Stat.energy'}} {{b.n}}" aria-pressed="{{b.marked}}"></button>{{/if}}{{/each}}</div>
    </div>
  </div>

  <div class="panel-rule"></div>

  <div class="panel-vitals">
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.guardShort"}}</span><span class="v-val">{{system.guard.value}}</span></div>
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.movShort"}}</span><span class="v-val">{{system.movement.value}}</span></div>
  </div>

  {{#if isCharacter}}
  <div class="panel-rule"></div>
  <div class="panel-luck">
    <span class="panel-luck-label">{{localize "PROJECTANIME.Stat.luckDice"}}</span>
    <div class="luck-dice">
      {{#each system.luckDice as |d|}}<span class="luck-die">{{d}}</span>{{else}}<em class="muted">—</em>{{/each}}
    </div>
  </div>
  {{/if}}

  {{#if showTalents}}
  <div class="panel-talents">
    <div class="panel-talents-title">
      <span class="pt-line"></span>
      <span class="panel-talents-label">{{localize "PROJECTANIME.Item.talents"}}</span>
      {{#if editable}}<a class="talent-add" data-action="addTalent" title="{{localize 'PROJECTANIME.Talent.add'}}"><i class="fas fa-plus"></i></a>{{/if}}
      <span class="pt-line"></span>
    </div>
    <div class="talent-rows">
      {{#each talents as |t|}}
      <div class="talent-row" data-talent-id="{{t.id}}">
        <button type="button" class="tr-main" data-action="editTalent" title="{{t.attribute}}">
          <span class="tr-die">{{t.die}}</span>
          <span class="tr-name">{{t.name}}</span>
        </button>
        <a class="tr-chat" data-action="postTalent" title="{{localize 'PROJECTANIME.Talent.toChat'}}"><i class="fa-regular fa-message"></i></a>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  <div class="panel-foot">
    <span class="status-label">STATUS</span>
  </div>
</header>
