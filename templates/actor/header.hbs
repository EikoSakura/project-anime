{{!-- Persistent side panel (Character & NPC) — Log Horizon-style status panel --}}
<header class="sheet-header">
  <div class="portrait portrait-card">
    <div class="portrait-frame">
      <img class="profile-img" src="{{actor.img}}" data-action="editImage" data-edit="img"
           title="{{actor.name}}" alt="{{actor.name}}" />
    </div>
    <i class="stud stud-n"></i>
    <i class="stud stud-e"></i>
    <i class="stud stud-s"></i>
    <i class="stud stud-w"></i>
    {{#if isNPC}}
    <button type="button" class="role-crest nested{{#if isNpcRole}} npc{{/if}}" data-action="toggleRole" title="{{localize 'PROJECTANIME.NpcRole.toggle'}}" aria-label="{{localize 'PROJECTANIME.NpcRole.toggle'}}">
      <span class="dia"><span class="face">{{#if isNpcRole}}<i class="fas fa-user"></i>{{else}}<i class="fas fa-dragon"></i>{{/if}}</span></span>
    </button>
    {{/if}}
  </div>

  <input class="char-name" type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'Name'}}" />

  {{#if isCharacter}}
  <div class="header-actions">
    <button type="button" class="advance-btn create-btn" data-action="openCreator" title="{{localize 'PROJECTANIME.Creator.title'}}">
      <i class="fas fa-user-plus"></i><span>{{localize "PROJECTANIME.Creator.open"}}</span>
    </button>
    <button type="button" class="advance-btn" data-action="openAdvancement" title="{{localize 'PROJECTANIME.Advancement.title'}}">
      <i class="fas fa-arrow-up-right-dots"></i><span>{{localize "PROJECTANIME.Advancement.open"}}</span>
    </button>
    <button type="button" class="advance-btn rest-btn" data-action="openRest" title="{{localize 'PROJECTANIME.Rest.title'}}">
      <i class="fas fa-campground"></i><span>{{localize "PROJECTANIME.Rest.open"}}</span>
    </button>
  </div>
  {{/if}}

  {{#if isNPC}}
  <div class="header-actions">
    {{#if isMonster}}<button type="button" class="advance-btn create-btn" data-action="openCreator" title="{{localize 'PROJECTANIME.MonsterCreator.title'}}">
      <i class="fas fa-dragon"></i><span>{{localize "PROJECTANIME.MonsterCreator.open"}}</span>
    </button>{{/if}}
    <button type="button" class="advance-btn" data-action="openAdvancement" title="{{localize 'PROJECTANIME.Advancement.title'}}">
      <i class="fas fa-arrow-up-right-dots"></i><span>{{localize "PROJECTANIME.Advancement.open"}}</span>
    </button>
  </div>
  {{/if}}

  <div class="header-sub">
    {{#if isCharacter}}
    <input class="pronouns" type="text" name="system.pronouns" value="{{system.pronouns}}"
           placeholder="{{localize 'PROJECTANIME.Field.pronouns'}}" />
    {{/if}}
    {{#if isNPC}}
    <select name="system.disposition">{{selectOptions config.dispositions selected=system.disposition localize=true}}</select>
    {{#if tierBadge}}
    <span class="tier-badge{{#if tierBadge.apex}} apex{{/if}}" style="--tier-color: {{tierBadge.color}}" title="{{tierBadge.label}}">
      {{#if tierBadge.stars}}<span class="tier-stars">{{#each tierBadge.stars}}<i class="fas fa-star"></i>{{/each}}</span>{{/if}}
      <i class="{{tierBadge.icon}}"></i><span>{{tierBadge.label}}</span>
    </span>
    {{/if}}
    {{/if}}
  </div>

  <div class="panel-rule"></div>

  <div class="panel-resources">
    <div class="resource hp">
      <div class="resource-top">
        <label>{{localize "PROJECTANIME.Stat.hp"}}</label>
        {{#if system.squad.isSquad}}
        {{!-- Minion Squad: HP is pooled (per-member × members, derived) — the max is read-only here so
              a sheet edit can't be silently overwritten; size it in the Monster Creator / Encounter Builder. --}}
        <span class="resource-vals">
          <input type="number" name="system.hp.value" value="{{system.hp.value}}" min="0" />
          <span class="sep">/</span>
          <span class="num" data-tooltip="{{localize 'PROJECTANIME.MonsterCreator.squadNote'}}">{{system.hp.max}}</span>
        </span>
        {{else}}
        <span class="resource-vals">
          <input type="number" name="system.hp.value" value="{{system.hp.value}}" min="0" />
          <span class="sep">/</span>
          <input type="number" name="system.hp.max" value="{{system.hp.max}}" min="0" />
        </span>
        {{/if}}
      </div>
      <div class="bar"><div class="fill hp-fill" style="width: {{hpPct}}%"></div></div>
      {{#if system.squad.isSquad}}
      <div class="squad-line muted"><i class="fas fa-people-group"></i> {{system.squad.members}} / {{system.squad.maxMembers}} {{localize "PROJECTANIME.Party.squadMembers"}}</div>
      {{/if}}
    </div>
    <div class="resource energy">
      <div class="resource-top">
        <label>{{localize "PROJECTANIME.Stat.energy"}}</label>
        <span class="resource-vals">
          <input type="number" name="system.energy.value" value="{{system.energy.value}}" min="0" />
          <span class="sep">/</span>
          {{!-- The Max field shows the EFFECTIVE maximum (authored − passive/servant tax) so it visibly
                drops as passives are added. It carries data-energy-max and NO `name`, so the sheet's
                submitOnChange never collects it — otherwise editing Current would write this taxed
                number back into storage and the next prepare would re-tax it (compounding). Edits are
                persisted by #bindEnergyMax, which stores the AUTHORED max (entered + current tax) so the
                tax is re-derived rather than baked in. --}}
          <input type="number" data-energy-max value="{{system.energy.max}}" min="0" />
        </span>
      </div>
      <div class="bar"><div class="fill energy-fill" style="width: {{energyPct}}%"></div></div>
    </div>
  </div>

  <div class="panel-rule"></div>

  <div class="panel-vitals">
    {{#if system.atk.value}}<div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.atkShort"}}</span><span class="v-val">{{system.atk.value}}</span></div>{{/if}}
    {{#if system.matk.value}}<div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.matkShort"}}</span><span class="v-val">{{system.matk.value}}</span></div>{{/if}}
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.defShort"}}</span><span class="v-val">{{system.defense.value}}</span></div>
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.resShort"}}</span><span class="v-val">{{system.res.value}}</span></div>
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.evaShort"}}</span><span class="v-val">{{system.evasion.value}}</span></div>
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.asShort"}}</span><span class="v-val">{{system.as.value}}</span></div>
    <div class="vital"><span class="v-label">{{localize "PROJECTANIME.Stat.movShort"}}</span><span class="v-val">{{system.movement.value}}</span></div>
  </div>

  {{#if isCharacter}}
  <div class="panel-rule"></div>
  <div class="panel-luck">
    <span class="panel-luck-label">{{localize "PROJECTANIME.Stat.luckDice"}}</span>
    <div class="luck-dice">
      {{#each system.luckDice as |d|}}<span class="luck-die">{{d}}</span>{{else}}<em class="muted">—</em>{{/each}}
    </div>
  </div>
  {{/if}}

  <div class="panel-foot">
    <span class="status-label">STATUS</span>
  </div>
</header>
