{{!-- Defenses drawer: slides in from the right over the content. Single root <aside>. --}}
<aside class="section-drawer{{#if open.defenses}} open{{/if}}" data-section="defenses">
  <div class="drawer-backdrop" data-action="closeDrawer"></div>
  <div class="drawer-panel">
    <div class="drawer-headbar">
      <h3>{{localize "PROJECTANIME.Defenses.title"}}</h3>
      <a class="drawer-close" data-action="closeDrawer" title="{{localize 'PROJECTANIME.Defenses.close'}}"><i class="fa-solid fa-xmark"></i></a>
    </div>

    <div class="status-screen">
      <section class="status-block">
        <div class="section-controls"><h3>{{localize "PROJECTANIME.Status.title"}}</h3></div>
        <div class="status-grid">
          {{#each conditions as |c|}}
          <a class="status-cell {{#if c.active}}active{{/if}}" data-action="toggleCondition"
             data-condition="{{c.id}}" title="{{c.label}}">
            <img src="{{c.img}}" width="22" height="22" alt="{{c.label}}" />
            <span class="status-name">{{c.label}}</span>
          </a>
          {{/each}}
        </div>
      </section>

      {{#if isCharacter}}
      <section class="status-block wound-block">
        <div class="section-controls">
          <h3>{{localize "PROJECTANIME.Wound.plural"}}</h3>
          {{#if @root.editable}}
          <a class="item-create" data-action="addWound" title="{{localize 'PROJECTANIME.Wound.add'}}"><i class="fas fa-plus"></i></a>
          {{/if}}
        </div>
        {{#each wounds as |w|}}
        <div class="wound-row" data-wound-id="{{w.id}}">
          <i class="fas fa-heart-crack"></i>
          <input type="text" class="wound-note" data-wound-id="{{w.id}}" value="{{w.note}}" placeholder="{{localize 'PROJECTANIME.Wound.notePlaceholder'}}" {{#unless @root.editable}}disabled{{/unless}} />
          {{#if @root.editable}}
          <a data-action="removeWound" data-wound-id="{{w.id}}" title="{{localize 'PROJECTANIME.Wound.clear'}}"><i class="fas fa-xmark"></i></a>
          {{/if}}
        </div>
        {{else}}
        <div class="tile-empty muted">—</div>
        {{/each}}
      </section>
      {{/if}}
    </div>
  </div>
</aside>
