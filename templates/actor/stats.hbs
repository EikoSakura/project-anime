{{!-- Stats: the always-visible main view (attributes + equipment). Other sections open as drawers. --}}
<section class="stats-main">

  <nav class="section-nav">
    {{#unless isNpcRole}}
    <button type="button" data-action="openDrawer" data-section="skills"><i class="fas fa-bolt"></i><span>{{localize "PROJECTANIME.Tab.skills"}}</span></button>
    <button type="button" data-action="openDrawer" data-section="gear"><i class="fas fa-box-open"></i><span>{{localize "PROJECTANIME.Tab.gear"}}</span></button>
    <button type="button" data-action="openDrawer" data-section="defenses"><i class="fas fa-shield-halved"></i><span>{{localize "PROJECTANIME.Defenses.title"}}</span></button>
    <button type="button" data-action="openDrawer" data-section="effects"><i class="fas fa-wand-magic-sparkles"></i><span>{{localize "PROJECTANIME.Effect.title"}}</span></button>
    {{/unless}}
    {{#if isCharacter}}<button type="button" data-action="openDrawer" data-section="bonds"><i class="fas fa-hand-holding-heart"></i><span>{{localize "PROJECTANIME.Tab.bonds"}}</span></button>{{/if}}
    <button type="button" data-action="openDrawer" data-section="biography"><i class="fas fa-feather"></i><span>{{localize "PROJECTANIME.Tab.biography"}}</span></button>
  </nav>

  {{#if isNpcRole}}
  {{!-- NPC identity dossier — leads with who they are; combat stats fold below. --}}
  <section class="npc-dossier">
    {{!-- Identity fields live on the Biography tab. This dossier is the HQ work profile:
          Talents (work dice) + Unique Trait + Trait Bonuses. --}}
    <div class="nd-talents">
      <div class="nd-thead"><i class="fas fa-dice-d20"></i> {{localize "PROJECTANIME.Talent.title"}}</div>
      <div class="attributes nd-talents-grid">
        {{#each talentList as |t|}}
        <div class="attribute-card" data-attribute="{{t.key}}">
          <div class="attr-head"><i class="attr-icon {{t.icon}}"></i><span class="attr-name">{{t.label}}</span></div>
          <div class="attr-die rollable" data-action="rollTalent" data-talent="{{t.key}}" title="{{localize 'PROJECTANIME.Roll.checkHint'}}"><span class="die-face">{{t.die}}</span></div>
          <label class="attr-base-edit" title="{{localize 'PROJECTANIME.Field.base'}}">
            <span class="abe-label">{{localize "PROJECTANIME.Field.base"}}</span>
            <input class="attr-base" type="number" name="system.talents.{{t.key}}.base" value="{{t.base}}" min="4" max="12" step="2" />
          </label>
        </div>
        {{/each}}
      </div>
      {{!-- Signature Trait — the NPC's one defining ability, as a skill-style card (click to author). --}}
      <div class="nd-sig">
        <div class="nd-thead"><i class="fas fa-fire-flame-curved"></i> {{localize "PROJECTANIME.Talent.signature"}}{{#if editable}}{{#if signature.empty}} <a class="nd-tadd" data-action="editSignature"><i class="fas fa-plus"></i></a>{{/if}}{{/if}}</div>
        {{#unless signature.empty}}
        <div class="nd-card sig"{{#if editable}} data-action="editSignature"{{/if}}>
          <div class="nd-card-ico"><img src="{{signature.img}}" alt="" /></div>
          <div class="nd-card-body">
            <div class="nd-card-name">{{#if signature.name}}{{signature.name}}{{else}}{{localize "PROJECTANIME.Talent.traitUntitled"}}{{/if}}</div>
            {{#if signature.descHTML}}<div class="nd-card-desc">{{{signature.descHTML}}}</div>{{/if}}
          </div>
          {{#if editable}}
          <span class="nd-card-edit"><i class="fas fa-pen"></i></span>
          <a class="nd-card-clear" data-action="clearSignature" title="{{localize 'PROJECTANIME.Talent.signatureClear'}}"><i class="fas fa-xmark"></i></a>
          {{/if}}
        </div>
        {{/unless}}
      </div>

      <div class="nd-traits">
        <div class="nd-thead"><i class="fas fa-layer-group"></i> {{localize "PROJECTANIME.Talent.traits"}}{{#if editable}} <a class="nd-tadd" data-action="addTrait" title="{{localize 'PROJECTANIME.Talent.addTrait'}}"><i class="fas fa-plus"></i></a>{{/if}}</div>
        {{#each traitsList as |t|}}
        <div class="nd-card trait" data-trait-id="{{t.id}}"{{#if @root.editable}} data-action="editTrait"{{/if}}>
          <div class="nd-card-ico sm"><img src="{{t.img}}" alt="" /></div>
          <div class="nd-card-body">
            <div class="nd-card-name">{{#if t.name}}{{t.name}}{{else}}{{localize "PROJECTANIME.Talent.traitUntitled"}}{{/if}}</div>
            {{#if t.descHTML}}<div class="nd-card-desc">{{{t.descHTML}}}</div>{{/if}}
          </div>
          {{#if @root.editable}}
          <span class="nd-card-edit"><i class="fas fa-pen"></i></span>
          <a class="nd-card-clear" data-action="removeTrait" title="{{localize 'PROJECTANIME.Talent.removeTrait'}}"><i class="fas fa-xmark"></i></a>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- Combat statblock — shown for Characters and Monster-mode NPCs; a social NPC stays a clean
        dossier (flip the header role toggle to Monster to reveal the statblock). --}}
  {{#unless isNpcRole}}
  <div class="statblock">
    <div class="statblock-body">

  {{#unless isCharacter}}
  <div class="attributes">
    {{#each attributeList as |attr|}}
    <div class="attribute-card" data-attribute="{{attr.key}}">
      <div class="attr-head">
        {{#if attr.icon}}<i class="attr-icon {{attr.icon}}"></i>{{/if}}
        <span class="attr-name">{{attr.label}}</span>
      </div>
      <div class="attr-die rollable" data-action="rollCheck" data-attribute="{{attr.key}}"
           title="{{localize 'PROJECTANIME.Roll.checkHint'}}"><span class="die-face">{{attr.die}}</span></div>
      {{!-- Base value: kept wired (same data path) but tucked away — reveals on hover/focus to edit. A
            Monster's dice derive from its Role × Tier (Strong/Weak), so its base is not hand-edited here. --}}
      {{#unless @root.isMonster}}
      <label class="attr-base-edit" title="{{localize 'PROJECTANIME.Field.base'}}">
        <span class="abe-label">{{localize "PROJECTANIME.Field.base"}}</span>
        <input class="attr-base" type="number" name="system.attributes.{{attr.key}}.base"
               value="{{attr.base}}" min="4" max="12" step="2" />
      </label>
      {{else}}
      <span class="attr-sw {{#if attr.strong}}strong{{else}}weak{{/if}}">{{#if attr.strong}}{{localize "PROJECTANIME.EnemyRole.strongShort"}}{{else}}{{localize "PROJECTANIME.EnemyRole.weakShort"}}{{/if}}</span>
      {{/unless}}
    </div>
    {{/each}}
  </div>
  {{/unless}}

  <div class="quickbar cmd-wrap">
    <section class="cmd-sec cmd-equip">
      <div class="cmd-sechead"><h3>{{localize "PROJECTANIME.Quick.weapons"}}</h3><span class="cmd-ln"></span></div>
      <div class="cmd-list">
        {{#each quickWeapons as |w|}}
        <div class="cmd-row eq{{#if w.natural}} natural{{/if}}" data-item-id="{{w.id}}" data-readied-type="weapon">
          <div class="cmd-head">
            <span class="cmd-ico" data-action="rollItem"><img src="{{w.img}}" alt="{{w.name}}" /></span>
            <div class="cmd-mid">
              <span class="cmd-name" data-action="rollItem">{{w.name}}</span>
              <span class="cmd-tag">{{w.typeLabel}}</span>
            </div>
            <div class="cmd-right">
              {{#if w.hasMeta}}<span class="cmd-caret">›</span>{{/if}}
            </div>
          </div>
          {{#if w.hasMeta}}
          <div class="cmd-desc">
            <div class="eq-card">
              <div class="eq-card-strip"></div>
              <div class="eq-body">
                <div class="eq-rows">
                  {{#if w.accHTML}}<div class="eq-row"><span class="k"><i class="fas fa-crosshairs"></i>{{localize "PROJECTANIME.Field.accuracy"}}</span><span class="v">{{{w.accHTML}}}</span></div>{{/if}}
                  {{#if w.dmgLabel}}<div class="eq-row"><span class="k"><i class="fas fa-burst"></i>{{localize "PROJECTANIME.Roll.damage"}}</span><span class="v">{{w.dmgLabel}}</span></div>{{/if}}
                  {{#if w.rangeText}}<div class="eq-row"><span class="k"><i class="fas fa-arrows-left-right-to-line"></i>{{localize "PROJECTANIME.Field.range"}}</span><span class="v">{{w.rangeText}}</span></div>{{/if}}
                </div>
                {{#if w.descHTML}}<div class="eq-desc">{{{w.descHTML}}}</div>{{/if}}
                {{#if w.natural}}<div class="eq-tags"><span class="eq-tag"><i class="fas fa-hand-fist"></i>{{localize "PROJECTANIME.NaturalAttack.tag"}}</span></div>{{/if}}
                {{#if w.shield}}<div class="eq-tags"><span class="eq-tag"><i class="fas fa-shield-halved"></i>{{localize "PROJECTANIME.Quick.shieldBash"}}</span></div>{{/if}}
              </div>
            </div>
          </div>
          {{/if}}
        </div>
        {{else}}
        <div class="cmd-empty muted">—</div>
        {{/each}}
      </div>
    </section>

    <section class="cmd-sec cmd-skills">
      <div class="cmd-sechead">
        <h3>{{localize "PROJECTANIME.Quick.skills"}}</h3><span class="cmd-ln"></span>
        {{#if @root.editable}}<a class="cmd-add" data-action="buildSkill" title="{{localize 'PROJECTANIME.SkillBuilder.title'}}"><i class="fas fa-plus"></i></a>{{/if}}
      </div>
      {{#each skillGroups as |g|}}
      <div class="cmd-group">◆ {{g.label}} <span class="cmd-gc">{{g.skills.length}}</span></div>
      <div class="cmd-list" data-reorder data-group="{{g.key}}">
        {{#each g.skills as |s|}}
        <div class="cmd-row sk{{#if s.pinned}} pinned{{/if}}" data-item-id="{{s.id}}" data-readied-type="skill">
          <div class="cmd-head">
            {{#if @root.editable}}<span class="cmd-grip" title="{{localize 'PROJECTANIME.Quick.reorder'}}">⠿</span>{{/if}}
            <span class="cmd-ico" data-action="rollItem"><img src="{{s.img}}" alt="{{s.name}}" /></span>
            <div class="cmd-mid">
              <span class="cmd-name" data-action="rollItem">{{s.name}}</span>
              {{#if s.granted}}<span class="cmd-tag granted" title="{{s.grantedTip}}"><i class="fas fa-gift"></i></span>{{/if}}
            </div>
            <div class="cmd-right">
              {{#if s.energyCost}}<span class="cmd-cost{{#unless s.affordable}} short{{/unless}}" title="{{localize 'PROJECTANIME.Skill.field.energyCost'}}"><i class="fas fa-bolt"></i>{{s.energyCost}}</span>{{/if}}
              {{#if s.descHTML}}<span class="cmd-caret">›</span>{{/if}}
            </div>
          </div>
          {{#if s.descHTML}}<div class="cmd-desc"><div class="cmd-desc-in">{{{s.descHTML}}}</div></div>{{/if}}
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="cmd-empty muted">{{localize "PROJECTANIME.Empty"}}</div>
      {{/each}}
    </section>

    {{#if quickItems.length}}
    <section class="cmd-sec cmd-items">
      <div class="cmd-sechead"><h3>{{localize "PROJECTANIME.Quick.items"}}</h3><span class="cmd-ln"></span></div>
      <div class="cmd-list">
        {{#each quickItems as |it|}}
        <div class="cmd-row eq" data-item-id="{{it.id}}" data-readied-type="item">
          <div class="cmd-head">
            <span class="cmd-ico" data-action="rollItem"><img src="{{it.img}}" alt="{{it.name}}" /></span>
            <div class="cmd-mid"><span class="cmd-name" data-action="rollItem">{{it.name}}</span></div>
            <div class="cmd-right">
              {{#if it.qty}}<span class="cmd-mini">×{{it.qty}}</span>{{/if}}
              {{#if @root.editable}}<a class="cmd-pin on" data-action="unreadySkill" title="{{localize 'PROJECTANIME.Quick.unpinItem'}}"><i class="fas fa-xmark"></i></a>{{/if}}
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </section>
    {{/if}}
  </div>
    </div>
  </div>
  {{/unless}}

</section>
