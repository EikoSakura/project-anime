<section class="tab details" data-group="primary" data-tab="details">

  {{!-- Classification Panel (weapon group / armor category — moved from header) --}}
  {{#if (or showWeaponGroup showArmorCategory showHandedness)}}
  <div class="equip-panel equip-panel--classification">
    <h3 class="equip-panel__heading">
      <i class="fa-solid fa-tags"></i>
      {{localize "SHARDS.Equipment.Classification"}}
    </h3>
    <div class="equip-classification-grid">
      {{#if showWeaponGroup}}
      <div class="form-group form-group--compact">
        <label>{{localize "SHARDS.Equipment.Group"}}</label>
        <select name="system.weaponGroup" class="equip-sub-select">
          <option value="">—</option>
          {{#each weaponGroupOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
      {{#if showHandedness}}
      <div class="form-group form-group--compact">
        <label>{{localize "SHARDS.Equipment.Handedness"}}</label>
        <select name="system.handedness" class="equip-sub-select">
          {{#each handednessOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
      {{#if showArmorCategory}}
      <div class="form-group form-group--compact">
        <label>{{localize "SHARDS.Equipment.Category"}}</label>
        <select name="system.armorCategory" class="equip-sub-select">
          <option value="">—</option>
          {{#each armorCategoryOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
    </div>
  </div>
  {{/if}}

  {{!-- Oversized Weapon Panel (STR requirement + penalties) --}}
  {{#if showOversizedFields}}
  <div class="equip-panel equip-panel--oversized">
    <h3 class="equip-panel__heading">
      <i class="fa-solid fa-weight-hanging"></i>
      {{localize "SHARDS.Equipment.Oversized"}}
    </h3>
    <div class="equip-oversized-grid">
      <div class="form-group form-group--compact">
        <label>{{localize "SHARDS.Equipment.StrRequirement"}}</label>
        <input type="number" name="system.strRequirement" value="{{system.strRequirement}}"
               data-dtype="Number" class="equip-stat-input" />
      </div>
    </div>
    <h4 class="equip-panel__subheading">{{localize "SHARDS.Equipment.OversizedPenalties"}}</h4>
    <div class="equip-oversized-penalties-grid">
      <div class="equip-combat-field">
        <label class="equip-combat-label">{{localize "SHARDS.Derived.Acc"}}</label>
        <input type="number" name="system.oversizedPenalties.acc" value="{{system.oversizedPenalties.acc}}"
               data-dtype="Number" />
      </div>
      <div class="equip-combat-field">
        <label class="equip-combat-label">{{localize "SHARDS.Derived.Eva"}}</label>
        <input type="number" name="system.oversizedPenalties.eva" value="{{system.oversizedPenalties.eva}}"
               data-dtype="Number" />
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- Properties Panel --}}
  <div class="equip-panel equip-panel--properties">
    <h3 class="equip-panel__heading">
      <i class="fa-solid fa-gem"></i>
      {{localize "SHARDS.Equipment.Properties"}}
      {{#if propertyArray.length}}
      <span class="count-badge">{{propertyArray.length}}</span>
      {{/if}}
    </h3>
    <div class="equip-properties-container">
      {{#each propertyArray}}
      <span class="equip-property-chip">
        {{this}}
        <button type="button" class="equip-property-remove" data-action="removeProperty" data-index="{{@index}}"
                title="{{localize 'SHARDS.Delete'}}">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </span>
      {{/each}}
      <input type="text" class="equip-property-input"
             placeholder="{{localize 'SHARDS.Equipment.AddProperty'}}"
             autocomplete="off" />
    </div>
  </div>

  {{!-- Combat Stats Panel (weapons/offhand only) --}}
  {{#if showWeaponFields}}
  <div class="equip-panel equip-panel--combat">
    <h3 class="equip-panel__heading">
      <i class="fa-solid fa-crosshairs"></i>
      {{localize "SHARDS.Equipment.CombatStats"}}
    </h3>
    <div class="equip-combat-grid">
      <div class="equip-combat-field">
        <label class="equip-combat-label equip-combat-label--acc">{{localize "SHARDS.Equipment.BaseAccuracy"}}</label>
        <input type="number" name="system.baseAccuracy" value="{{system.baseAccuracy}}"
               data-dtype="Number" min="0" max="99" />
      </div>
      <div class="equip-combat-field">
        <label class="equip-combat-label equip-combat-label--phys">{{localize "SHARDS.Equipment.PDmg"}}</label>
        <input type="number" name="system.pDmg" value="{{system.pDmg}}"
               data-dtype="Number" />
      </div>
      <div class="equip-combat-field">
        <label class="equip-combat-label equip-combat-label--mag">{{localize "SHARDS.Equipment.MDmg"}}</label>
        <input type="number" name="system.mDmg" value="{{system.mDmg}}"
               data-dtype="Number" />
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- Stat Bonuses Panel --}}
  <div class="equip-panel equip-panel--stats">
    <h3 class="equip-panel__heading">
      <i class="fa-solid fa-chart-simple"></i>
      {{localize "SHARDS.Equipment.Stats"}}
      {{#if totalStatBonus}}
      <span class="equip-stat-total {{totalStatBonusSign}}">
        {{totalStatBonusDisplay}}
      </span>
      {{/if}}
    </h3>
    <div class="equip-stat-grid">
      {{#each statBonusRows}}
      <div class="equip-stat-row">
        <span class="equip-stat-row__abbrev">{{this.abbrev}}</span>
        <span class="equip-stat-row__label">{{this.label}}</span>
        <input type="number" name="system.statBonuses.{{this.key}}" value="{{this.value}}"
               data-dtype="Number" class="equip-stat-input {{this.sign}}" />
      </div>
      {{/each}}
    </div>
  </div>

</section>
