<div class="manacite-header-wrapper">
  <div class="crystal-card manacite-header">
    <div class="manacite-header__portrait">
      <img class="manacite-portrait-img" src="{{item.img}}" data-action="editImage"
           data-edit="img" title="{{item.name}}" width="96" height="96" />
    </div>

    <div class="manacite-header__fields">

      {{!-- Row 1: Name --}}
      <div class="manacite-header__name">
        <input name="name" type="text" value="{{item.name}}"
               placeholder="{{localize 'SHARDS.ItemName'}}" />
      </div>

      {{!-- Row 2: Type dropdown + School dropdown + Rank badge --}}
      <div class="manacite-header__meta">
        <select name="system.manaciteType" class="manacite-type-select">
          {{#each manaciteTypeOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
        <select name="system.school" class="manacite-school-select">
          {{#each schoolOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
        <span class="rank-badge" data-rank="{{system.rank}}"
              data-action="cycleRank"
              title="Rank {{system.rank}} — SL {{system.skillLevel}}">
          {{system.rank}}
        </span>
      </div>

      {{!-- Row 3: Skill granted + SL display --}}
      {{#if system.skillGranted}}
      <div class="manacite-header__skill">
        <i class="fa-solid fa-book-sparkles"></i>
        <span class="manacite-skill-name">{{system.skillGranted}}</span>
        <span class="manacite-skill-sl">SL {{system.skillLevel}}</span>
      </div>
      {{/if}}

      {{!-- Row 4: XP Siphon Progress --}}
      <div class="manacite-header__xp">
        {{#if system.isMaxLevel}}
          <span class="manacite-xp-label manacite-xp-label--max">MAX</span>
        {{else}}
          <span class="manacite-xp-label">{{system.manaciteXp}} / {{xpNextThreshold}} XP</span>
        {{/if}}
        <div class="manacite-xp-bar">
          <div class="manacite-xp-bar__fill" style="width: {{system.xpProgress}}%"></div>
        </div>
      </div>

    </div>
  </div>
</div>
