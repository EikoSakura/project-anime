<section class="tab growth" data-group="primary" data-tab="growth">

  {{!-- Base Resources (moved from header) --}}
  <div class="crystal-panel" style="margin-bottom: 8px;">
    <h3 class="crystal-heading">{{localize "SHARDS.Job.BaseResources"}}</h3>
    <div class="job-header__formulas">
      <div class="form-group form-group--compact">
        <label class="formula-label formula-label--hp">{{localize "SHARDS.Job.BaseHP"}}</label>
        <input type="number" name="system.baseHp" value="{{system.baseHp}}" data-dtype="Number" />
      </div>
      <div class="form-group form-group--compact">
        <label class="formula-label formula-label--mp">{{localize "SHARDS.Job.BaseMP"}}</label>
        <input type="number" name="system.baseMp" value="{{system.baseMp}}" data-dtype="Number" />
      </div>
    </div>
  </div>

  <div class="crystal-panel">

    <h3 class="crystal-heading">{{localize "SHARDS.Job.GrowthModifiers"}}</h3>
    <p class="job-panel-hint">{{localize "SHARDS.Job.GrowthModifiersHint"}}</p>

    <div class="job-growth-grid">
      {{#each growthModRows}}
      <div class="job-growth-row">
        <span class="job-growth-row__abbrev">{{this.abbrev}}</span>
        <span class="job-growth-row__label">{{this.label}}</span>
        <div class="job-growth-bar-wrap">
          <div class="job-growth-bar {{this.sign}}">
            <div class="job-growth-bar__fill" style="width: {{this.barWidth}}%"></div>
          </div>
        </div>
        <input type="number" name="system.growthRateModifiers.{{this.key}}"
               value="{{this.value}}" class="job-growth-input {{this.sign}}"
               data-dtype="Number" />
        <span class="job-growth-row__sign-label">%</span>
      </div>
      {{/each}}
    </div>

  </div>
</section>
