<section class="tab details {{tab.cssClass}}" data-group="primary" data-tab="details">

  {{!-- Template Picker (GM only, shown at top) --}}
  {{#if canEditDetails}}
  <div class="crystal-panel skill-panel">
    <h3 class="crystal-heading skill-panel__heading">
      <i class="fa-solid fa-clipboard-list"></i>
      {{localize "SHARDS.Skill.ApplyTemplate"}}
    </h3>
    <div class="skill-stat-grid">
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.TemplateLabel"}}</label>
        <select class="template-picker-select">
          <option value="">— {{localize "SHARDS.Skill.ChooseTemplate"}} —</option>
          {{#each skillTemplateOptions}}
          <option value="{{this.key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- Panel 1: Identity --}}
  <div class="crystal-panel skill-panel">
    <h3 class="crystal-heading skill-panel__heading">
      <i class="fa-solid fa-id-card"></i>
      {{localize "SHARDS.Skill.Identity"}}
    </h3>
    <div class="skill-stat-grid">
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.TimingLabel"}}</label>
        <select name="system.timing">
          {{#each timingOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.DefenseType"}}</label>
        <select name="system.defenseType">
          {{#each defenseTypeOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.DamageType.Label"}}</label>
        <select name="system.damageType">
          <option value="">—</option>
          {{#each damageTypeOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.Tier"}}</label>
        <input type="number" name="system.tier" value="{{system.tier}}"
               data-dtype="Number" min="1" max="5" />
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.Stackable"}}</label>
        <input type="checkbox" name="system.stackable" {{#if system.stackable}}checked{{/if}} />
      </div>
    </div>
  </div>

  {{!-- Panel 2: Usage --}}
  <div class="crystal-panel skill-panel">
    <h3 class="crystal-heading skill-panel__heading">
      <i class="fa-solid fa-crosshairs"></i>
      {{localize "SHARDS.Skill.UsageLabel"}}
    </h3>
    <div class="skill-stat-grid">
      {{#unless isPassive}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.PipCost"}}</label>
        <input type="text" name="system.pipCost" value="{{system.pipCost}}"
               placeholder="e.g. 2 or SL / 2" />
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.MpCost"}}</label>
        <input type="text" name="system.mpCost" value="{{system.mpCost}}"
               placeholder="e.g. 5 or SL * 3" />
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.BuffDuration"}}</label>
        <input type="text" name="system.buffDuration" value="{{system.buffDuration}}"
               placeholder="e.g. SL or SL * 2" />
      </div>
      {{/unless}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Target.Label"}}</label>
        <select name="system.target">
          {{#each targetOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{#if showAreaFields}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.AreaShape"}}</label>
        <select name="system.areaShape">
          {{#each areaShapeOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.AreaSize"}}</label>
        <div class="skill-inline-display">
          <input type="number" name="system.areaSize" value="{{system.areaSize}}"
                 data-dtype="Number" min="0" />
          <span class="skill-unit">sq</span>
        </div>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.AoE.FilterLabel"}}</label>
        <select name="system.aoeFilter">
          {{#each aoeFilterOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.Range"}}</label>
        <div class="skill-inline-display">
          <input type="text" name="system.range" value="{{system.range}}"
                 data-dtype="String" placeholder="0" />
          <span class="skill-unit">sq</span>
        </div>
      </div>
    </div>
  </div>

  {{!-- Panel 3: Combat --}}
  <div class="crystal-panel skill-panel">
    <h3 class="crystal-heading skill-panel__heading">
      <i class="fa-solid fa-swords"></i>
      {{localize "SHARDS.Skill.CombatLabel"}}
    </h3>
    <div class="skill-stat-grid">
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Equipment.BaseAccuracy"}}</label>
        <input type="number" name="system.baseAccuracy" value="{{system.baseAccuracy}}"
               data-dtype="Number" min="0" max="99" placeholder="50" />
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.SkillBase"}}</label>
        <input type="number" name="system.skillBase" value="{{system.skillBase}}"
               data-dtype="Number" min="0" />
      </div>
      <div class="skill-stat-row skill-stat-row--full">
        <label>{{localize "SHARDS.Skill.SkillStatsLabel"}}</label>
        <div class="skill-stat-chips">
          {{#each statChips}}
          <button type="button" class="skill-stat-chip {{#if this.selected}}selected{{/if}}"
                  data-action="toggleSkillStat" data-stat="{{this.key}}">
            {{this.label}}
          </button>
          {{/each}}
        </div>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.PowerTier.Label"}}</label>
        <select name="system.powerTier">
          {{#each powerTierOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.AutoFormula"}}</label>
        <input type="checkbox" name="system.autoFormula" {{#if autoFormula}}checked{{/if}} />
      </div>
      {{#if autoFormula}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.EffectiveFormula"}}</label>
        <span class="skill-stat-value">{{effectiveFormula}}</span>
      </div>
      {{else}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.DamageFormula"}}</label>
        <input type="text" name="system.damageFormula" value="{{system.damageFormula}}"
               placeholder="e.g. SL * 2 + MAG" />
      </div>
      {{/if}}
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.Pierce"}}</label>
        <input type="checkbox" name="system.pierce" {{#if system.pierce}}checked{{/if}} />
      </div>
    </div>
  </div>

  {{!-- Panel 4: Condition --}}
  <div class="crystal-panel skill-panel">
    <h3 class="crystal-heading skill-panel__heading">
      <i class="fa-solid fa-bolt"></i>
      {{localize "SHARDS.Skill.ConditionPanel"}}
    </h3>
    <div class="skill-stat-grid">
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.ConditionApplied"}}</label>
        <select name="system.conditionApplied">
          <option value="">— {{localize "SHARDS.Skill.NoCondition"}} —</option>
          {{#each conditionOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="skill-stat-row">
        <label>{{localize "SHARDS.Skill.ConditionChance"}}</label>
        <div class="skill-inline-display">
          <input type="text" name="system.conditionChance" value="{{system.conditionChance}}"
                 placeholder="0" />
          <span class="skill-unit">%</span>
        </div>
      </div>
    </div>
  </div>

  {{!-- Description Editor --}}
  <div class="crystal-panel skill-panel">
    <h3 class="crystal-heading skill-panel__heading">
      <i class="fa-solid fa-feather-pointed"></i>
      {{localize "SHARDS.Skill.Description"}}
    </h3>
    <div class="skill-description-editor">
      {{formInput systemFields.description value=system.description}}
    </div>
  </div>

</section>
