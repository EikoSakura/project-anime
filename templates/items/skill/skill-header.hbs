<div class="skill-header-wrapper">
  <div class="crystal-card skill-header">
    <div class="skill-header__portrait">
      <img class="skill-portrait-img" src="{{item.img}}" data-action="editImage"
           data-edit="img" title="{{item.name}}" width="96" height="96" />
    </div>

    <div class="skill-header__fields">

      {{!-- Row 1: Name --}}
      <div class="skill-header__name">
        <input name="name" type="text" value="{{item.name}}"
               placeholder="{{localize 'SHARDS.ItemName'}}" />
      </div>

      {{!-- Row 2: Type label + Tier badge + Skill Type select --}}
      <div class="skill-header__meta">
        <span class="item-type-label">{{localize "SHARDS.ItemType.skill"}}</span>
        <span class="skill-tier-badge" data-tier="{{system.tier}}"
              title="{{localize 'SHARDS.Skill.Tier'}} {{system.tier}}">
          {{#each tierStars}}<i class="fa-solid fa-star"></i>{{/each}}
        </span>
        <select name="system.skillType" class="skill-type-select">
          {{#each skillTypeOptions}}
          <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      {{!-- Row 3: Tags --}}
      <div class="skill-header__tags">
        <div class="skill-tags-container">
          {{#each tagArray}}
          <span class="tag-chip skill-tag-chip">
            {{this}}
            <button type="button" class="skill-tag-remove" data-action="removeTag" data-tag="{{this}}"
                    title="{{localize 'SHARDS.Delete'}}">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </span>
          {{/each}}
          <input type="text" class="skill-tag-input"
                 placeholder="{{localize 'SHARDS.Skill.AddTag'}}"
                 autocomplete="off" />
        </div>
      </div>

    </div>
  </div>
</div>
