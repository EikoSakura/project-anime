{{!-- Party tab: an Eiyuden/Suikoden status screen — a party band over a grid of six member cards.
      Each card is a scannable readout (diamond portrait, name, Hit + Energy box bars, Guard +
      Movement) that opens an in-place detail drawer (attribute dice, equipped gear). No formation
      rows — this combat has none. --}}
<section class="party-pane{{#if onParty}} active{{/if}}" data-pane="party">

  {{!-- Party band — Tier crest · Members · Gold · Party Power · Rest --}}
  <div class="party-band">
    <div class="pt-crest">
      <div class="pt-diamond"><span>{{tier}}</span></div>
      <div class="pt-crest-label">
        <span class="k">{{localize "PROJECTANIME.Party.tier"}}</span>
        {{#if isGM}}
        <select class="party-tier-select" title="{{localize 'PROJECTANIME.Party.tier'}}">
          {{#each tierOptions}}<option value="{{v}}" {{#if sel}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
        {{/if}}
      </div>
    </div>
    <div class="pt-spacer"></div>
    <div class="pt-counter">
      <span class="n"><b>{{memberCount}}</b> / 6</span>
      <span class="l">{{localize "PROJECTANIME.Party.members"}}</span>
    </div>
    <span class="pt-pill"><i class="fas fa-coins"></i> {{gold}}</span>
    {{#if isGM}}
    <button type="button" class="pt-rest" data-action="restParty"><i class="fas fa-campground"></i> {{localize "PROJECTANIME.Rest.title"}}</button>
    {{/if}}
  </div>

  {{!-- The party grid (drag Characters onto it / onto a ghost slot to add). --}}
  <div class="party-drop party-cards" data-drop="members">
    {{#each members as |m|}}
    <div class="pcard{{#if m.crit}} crit{{/if}}{{#if m.me}} me{{/if}}{{#if m.expanded}} expanded{{/if}}" data-ref="{{m.ref}}">
      <div class="pcard-row">
        <div class="pcard-dia" data-action="toggleMember" title="{{m.name}}">
          <div class="pd-frame"></div>
          <img class="pd-img" src="{{m.img}}" alt="" />
          <div class="pd-gloss"></div>
        </div>

        <div class="pcard-mid">
          <div class="pcard-top">
            <span class="pcard-name" data-action="toggleMember">{{m.name}}</span>
            {{#if m.me}}<span class="pcard-you">{{localize "PROJECTANIME.Party.you"}}</span>{{/if}}
            {{#if @root.editable}}
            <button type="button" class="pcard-x" data-action="removeMember" title="{{localize 'PROJECTANIME.Party.remove'}}"><i class="fas fa-xmark"></i></button>
            {{/if}}
          </div>
          <div class="pres resource hp">
            <i class="fas fa-heart"></i>
            <div class="boxes">{{#each m.hpBoxes as |b|}}{{#if b.locked}}<span class="mark-box locked"><i class="fa-solid fa-lock"></i></span>{{else}}<button type="button" class="mark-box{{#if b.marked}} marked{{/if}}" data-action="setMemberBox" data-resource="hp" data-n="{{b.n}}" {{#unless m.editable}}disabled{{/unless}} aria-label="{{localize 'PROJECTANIME.Stat.hp'}} {{b.n}}" aria-pressed="{{b.marked}}"></button>{{/if}}{{/each}}</div>
          </div>
          <div class="pres resource energy">
            <i class="fas fa-bolt"></i>
            <div class="boxes">{{#each m.energyBoxes as |b|}}{{#if b.locked}}<span class="mark-box locked"><i class="fa-solid fa-lock"></i></span>{{else}}<button type="button" class="mark-box{{#if b.marked}} marked{{/if}}" data-action="setMemberBox" data-resource="energy" data-n="{{b.n}}" {{#unless m.editable}}disabled{{/unless}} aria-label="{{localize 'PROJECTANIME.Stat.energy'}} {{b.n}}" aria-pressed="{{b.marked}}"></button>{{/if}}{{/each}}</div>
          </div>
        </div>

        <div class="pcard-stats">
          <span class="pstat" title="{{localize 'PROJECTANIME.Stat.guard'}}"><i class="fas fa-shield-halved"></i><b>{{m.guard}}</b></span>
          <span class="pstat" title="{{localize 'PROJECTANIME.Stat.movement'}}"><i class="fas fa-shoe-prints"></i><b>{{m.mov}}</b></span>
        </div>
      </div>

      {{!-- Detail drawer — attribute dice, equipped gear. Revealed on card click. --}}
      <div class="pcard-drawer">
        <div class="pdrawer-h"><i class="fas fa-dice-d20"></i> {{localize "PROJECTANIME.Party.drawerAttributes"}}<span class="rule"></span></div>
        <div class="pdrawer-attrs">
          {{#each m.attrs}}
          <div class="pattr{{#if big}} big{{/if}}"><span class="pd-die">{{die}}</span><span class="pd-lab"><i class="{{icon}}"></i> {{label}}</span></div>
          {{/each}}
        </div>

        <div class="pdrawer-h"><i class="fas fa-shield-halved"></i> {{localize "PROJECTANIME.Party.drawerEquipped"}}<span class="rule"></span></div>
        <div class="pdrawer-gear">
          <div class="pg-slot">
            <span class="pg-ic">{{#if m.gear.weapon}}<img src="{{m.gear.weapon.img}}" alt="" />{{else}}<i class="fas fa-khanda"></i>{{/if}}</span>
            <span class="pg-t"><small>{{localize "PROJECTANIME.Party.slotWeapon"}}</small>{{#if m.gear.weapon}}<b>{{m.gear.weapon.name}}</b>{{else}}<b class="muted">{{localize "PROJECTANIME.Party.slotEmpty"}}</b>{{/if}}</span>
          </div>
          <div class="pg-slot">
            <span class="pg-ic">{{#if m.gear.offhand}}<img src="{{m.gear.offhand.img}}" alt="" />{{else}}<i class="fas fa-shield"></i>{{/if}}</span>
            <span class="pg-t"><small>{{localize "PROJECTANIME.Party.slotOffhand"}}</small>{{#if m.gear.offhand}}<b>{{m.gear.offhand.name}}</b>{{else}}<b class="muted">{{localize "PROJECTANIME.Party.slotEmpty"}}</b>{{/if}}</span>
          </div>
          <div class="pg-slot">
            <span class="pg-ic">{{#if m.gear.armor}}<img src="{{m.gear.armor.img}}" alt="" />{{else}}<i class="fas fa-shirt"></i>{{/if}}</span>
            <span class="pg-t"><small>{{localize "PROJECTANIME.Party.slotArmor"}}</small>{{#if m.gear.armor}}<b>{{m.gear.armor.name}}</b>{{else}}<b class="muted">{{localize "PROJECTANIME.Party.slotEmpty"}}</b>{{/if}}</span>
          </div>
          <div class="pg-slot">
            <span class="pg-ic">{{#if m.gear.accessory}}<img src="{{m.gear.accessory.img}}" alt="" />{{else}}<i class="fas fa-ring"></i>{{/if}}</span>
            <span class="pg-t"><small>{{localize "PROJECTANIME.Party.slotAccessory"}}</small>{{#if m.gear.accessory}}<b>{{m.gear.accessory.name}}</b>{{else}}<b class="muted">{{localize "PROJECTANIME.Party.slotEmpty"}}</b>{{/if}}</span>
          </div>
        </div>

        <div class="pdrawer-foot">
          <a data-action="openActor"><i class="fas fa-up-right-from-square"></i> {{localize "PROJECTANIME.Party.viewSheet"}}</a>
        </div>
      </div>
    </div>
    {{/each}}

    {{#each ghosts}}
    <div class="pcard ghost">
      <div class="pg-dia"><i class="fas fa-plus"></i></div>
      <span class="pg-lab">{{localize "PROJECTANIME.Party.addMember"}}</span>
    </div>
    {{/each}}
  </div>

  {{!-- Companions strip — the party's bonded Companions; only rendered when there are any. --}}
  {{#if companions.length}}
  <div class="pcomp-head"><i class="fas fa-paw"></i> {{localize "PROJECTANIME.Party.companions"}}<span class="rule"></span></div>
  <div class="pcomp-rows">
    {{#each companions as |c|}}
    <div class="pcomp" data-ref="{{c.ref}}">
      <img class="pcomp-img" src="{{c.img}}" alt="" data-action="openActor" />
      <div class="pcomp-mid">
        <div class="pcomp-top">
          <span class="pcomp-name" data-action="openActor">{{c.name}}</span>
          {{#if c.master}}<span class="pcomp-bond" title="{{localize 'PROJECTANIME.Party.companionBond'}}"><i class="fas fa-link"></i> {{c.master}}</span>{{/if}}
        </div>
        <div class="pres resource hp">
          <i class="fas fa-heart"></i>
          <div class="boxes">{{#each c.hpBoxes as |b|}}{{#if b.locked}}<span class="mark-box locked"><i class="fa-solid fa-lock"></i></span>{{else}}<button type="button" class="mark-box{{#if b.marked}} marked{{/if}}" data-action="setMemberBox" data-resource="hp" data-n="{{b.n}}" {{#unless c.editable}}disabled{{/unless}} aria-label="{{localize 'PROJECTANIME.Stat.hp'}} {{b.n}}" aria-pressed="{{b.marked}}"></button>{{/if}}{{/each}}</div>
        </div>
        <div class="pres resource energy">
          <i class="fas fa-bolt"></i>
          <div class="boxes">{{#each c.energyBoxes as |b|}}{{#if b.locked}}<span class="mark-box locked"><i class="fa-solid fa-lock"></i></span>{{else}}<button type="button" class="mark-box{{#if b.marked}} marked{{/if}}" data-action="setMemberBox" data-resource="energy" data-n="{{b.n}}" {{#unless c.editable}}disabled{{/unless}} aria-label="{{localize 'PROJECTANIME.Stat.energy'}} {{b.n}}" aria-pressed="{{b.marked}}"></button>{{/if}}{{/each}}</div>
        </div>
      </div>
      {{#if c.adv}}<span class="pcomp-adv" title="{{localize 'PROJECTANIME.Advance.xp'}}"><i class="fas fa-arrow-up-right-dots"></i><b>{{c.adv}}</b></span>{{/if}}
      {{#if c.canAdvance}}
      <button type="button" class="pcomp-btn" data-action="advanceCompanion" title="{{localize 'PROJECTANIME.Advancement.title'}}"><i class="fas fa-arrow-up-right-dots"></i></button>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}

</section>
