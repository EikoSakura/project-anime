{{!-- Encounter tab (GM-only part): difficulty → Threat budget, read on one gauge, and the planned
      enemies — each one line, costing its Type's Threat (Minion ½ · Standard 1 · Bruiser 1½ ·
      Skirmisher 1 · Support 1 · Elite 2 · Rival 2 · Boss = party). Minions may not exceed half the
      budget. --}}
<section class="party-pane{{#if onEncounter}} active{{/if}}" data-pane="encounter">
  <div class="party-section party-budget">
    <label class="party-manual-toggle">
      <input type="checkbox" name="system.encounterManual" {{#if encounterManual}}checked{{/if}} />
      <span>{{localize "PROJECTANIME.Party.manualEstimate"}}</span>
    </label>

    {{#if encounterManual}}
    <div class="party-manual-fields">
      <label class="party-field">
        <span class="party-label">{{localize "PROJECTANIME.Party.players"}}</span>
        <input type="number" name="system.encounterPlayers" value="{{encounterPlayers}}" min="1" step="1" />
      </label>
      <button type="button" class="party-pull" data-action="pullRoster">
        <i class="fas fa-rotate"></i> {{localize "PROJECTANIME.Party.pullRoster"}} <span class="party-pull-n">{{rosterPlayers}}</span>
      </button>
    </div>
    {{/if}}

    <div class="party-budget-head">
      <label class="party-diff">
        <span class="party-label">{{localize "PROJECTANIME.Party.difficulty"}}</span>
        <select name="system.difficulty">{{selectOptions difficultyChoices selected=difficulty}}</select>
      </label>
      <div class="party-budget-val">
        <span class="party-label">{{localize "PROJECTANIME.Party.budget"}}</span>
        <strong>{{budget}}</strong>
      </div>
    </div>
    <div class="party-thresholds">
      {{#each thresholds as |t|}}
      <span class="party-th{{#if t.active}} active{{/if}}">{{t.label}} <strong>{{t.value}}</strong></span>
      {{/each}}
    </div>
  </div>

  <div class="party-section">
    <h3 class="party-title">
      <i class="fas fa-skull"></i> {{localize "PROJECTANIME.Party.encounter"}}
    </h3>

    {{!-- One gauge: Threat spent vs the budget. --}}
    <div class="party-gauges">
      <div class="party-gauge">
        <div class="party-gauge-head">
          <span class="party-gauge-label"><i class="fas fa-skull"></i> {{localize "PROJECTANIME.Threat.label"}}</span>
          <span class="party-gauge-val{{#if over}} over{{/if}}">{{spent}} / {{budget}}</span>
        </div>
        <div class="party-meter"><div class="party-meter-fill{{#if over}} over{{/if}}" style="width: {{usePct}}%"></div></div>
      </div>
    </div>
    {{#if minionOver}}<p class="party-warn"><i class="fas fa-triangle-exclamation"></i> {{localize "PROJECTANIME.Threat.minionHalf"}}</p>{{/if}}

    <div class="party-drop" data-drop="encounter">
      {{#each encounter as |m|}}
      <div class="party-row{{#if m.missing}} missing{{/if}}{{#if m.boss}} is-boss{{/if}}{{#if m.rival}} is-rival{{/if}}" data-line-id="{{m.id}}" data-uuid="{{m.uuid}}" style="--tier-color: {{m.color}}">
        <img src="{{m.img}}" alt="" data-action="openActor" />
        <span class="party-row-name" data-action="openActor">{{m.name}}{{#if m.typeLabel}} <span class="party-row-tier">{{#if m.icon}}<i class="{{m.icon}}"></i> {{/if}}{{m.typeLabel}}</span>{{/if}}</span>
        <span class="party-row-cost"><i class="fas fa-skull"></i> {{m.threatLabel}}</span>
        {{#if @root.editable}}
        <button type="button" class="party-x" data-action="removeMonster" title="{{localize 'PROJECTANIME.Party.remove'}}"><i class="fas fa-xmark"></i></button>
        {{/if}}
      </div>
      {{else}}
      <p class="party-empty muted">{{localize "PROJECTANIME.Party.dropMonsters"}}</p>
      {{/each}}
    </div>
  </div>
</section>
