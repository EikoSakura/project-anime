<div class="shards-chat-card shards-skill-card" data-theme="{{actorTheme}}">
  <header class="shards-chat-card__header">
    <img class="shards-chat-card__portrait" src="{{actorImg}}" alt="{{actorName}}" width="36" height="36" />
    <div class="shards-chat-card__title">
      <img class="shards-chat-card__skill-icon" src="{{skillImg}}" alt="" width="20" height="20" />
      <span class="shards-chat-card__actor-name">{{actorName}}</span>
      <span class="shards-chat-card__subtitle">{{skillName}}</span>
    </div>
    <span class="shards-skill-card__sl-badge">SL {{skillLevel}}</span>
  </header>

  <div class="shards-chat-card__body">
    {{!-- Type Bar --}}
    <div class="shards-skill-card__typebar">
      <span class="shards-skill-card__type">{{skillTypeLabel}}</span>
      {{#if damageTypeLabel}}
      <span class="shards-skill-card__element">{{damageTypeLabel}}</span>
      {{/if}}
      {{#if defenseTypeLabel}}
      <span class="shards-skill-card__defense">{{defenseTypeLabel}}</span>
      {{/if}}
    </div>

    {{!-- Stat Pills (non-passive only) --}}
    {{#unless isPassive}}
    <div class="shards-chat-card__section">
      <div class="shards-chat-card__section-header">{{localize "SHARDS.Roll.Parameters"}}</div>
      <div class="shards-skill-card__stats">
        <div class="shards-skill-card__pill">
          <span class="shards-skill-card__pill-label">Timing</span>
          <span class="shards-skill-card__pill-value">{{timingLabel}}</span>
        </div>
        {{#if computedMpCost}}
        <div class="shards-skill-card__pill shards-skill-card__pill--mp">
          <span class="shards-skill-card__pill-label">MP</span>
          <span class="shards-skill-card__pill-value">{{computedMpCost}}</span>
        </div>
        {{/if}}
        {{#if computedPipCost}}
        <div class="shards-skill-card__pill shards-skill-card__pill--pips">
          <span class="shards-skill-card__pill-label">Pips</span>
          <span class="shards-skill-card__pill-value">{{computedPipCost}}</span>
        </div>
        {{/if}}
        <div class="shards-skill-card__pill">
          <span class="shards-skill-card__pill-label">Target</span>
          <span class="shards-skill-card__pill-value">{{targetLabel}}</span>
        </div>
        {{#if range}}
        <div class="shards-skill-card__pill">
          <span class="shards-skill-card__pill-label">Range</span>
          <span class="shards-skill-card__pill-value">{{range}}sq</span>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Combat Numbers --}}
    {{#if (or totalHit totalDamage skillRate)}}
    <div class="shards-skill-card__combat">
      {{#if skillRate}}
      <div class="shards-skill-card__combat-stat">
        <span class="shards-skill-card__combat-value shards-skill-card__combat-value--hit">{{skillRate}}</span>
        <span class="shards-skill-card__combat-label">Rate</span>
      </div>
      {{/if}}
      {{#if totalHit}}
      <div class="shards-skill-card__combat-stat">
        <span class="shards-skill-card__combat-value shards-skill-card__combat-value--hit">{{totalHit}}</span>
        <span class="shards-skill-card__combat-label">Hit</span>
      </div>
      {{/if}}
      {{#if totalDamage}}
      <div class="shards-skill-card__combat-stat">
        <span class="shards-skill-card__combat-value shards-skill-card__combat-value--dmg">{{totalDamage}}</span>
        <span class="shards-skill-card__combat-label">Dmg</span>
      </div>
      {{/if}}
    </div>
    {{/if}}
    {{/unless}}

    {{!-- Passive Label --}}
    {{#if isPassive}}
    <div class="shards-skill-card__passive">
      <i class="fa-solid fa-circle-nodes"></i> Passive
    </div>
    {{/if}}

    {{!-- Condition --}}
    {{#if conditionLabel}}
    <div class="shards-skill-card__condition">
      <i class="fa-solid fa-bolt"></i>
      {{conditionChance}}% chance to apply <strong>{{conditionLabel}}</strong>
    </div>
    {{/if}}

    {{!-- Description --}}
    {{#if enrichedDescription}}
    <div class="shards-skill-card__description">{{{enrichedDescription}}}</div>
    {{/if}}
  </div>
</div>
