<div class="shards-chat-card shards-buff-roll" data-theme="{{actorTheme}}">
  <header class="shards-chat-card__header">
    <img class="shards-chat-card__portrait" src="{{actorImg}}" alt="{{actorName}}" width="36" height="36" />
    <div class="shards-chat-card__title">
      <img class="shards-chat-card__skill-icon" src="{{skillImg}}" alt="" width="20" height="20" />
      <span class="shards-chat-card__actor-name">{{actorName}}</span>
      <span class="shards-chat-card__subtitle">{{skillName}}</span>
    </div>
    <span class="shards-chat-card__element-badge element-buff">{{localize "SHARDS.DamageType.Buff"}}</span>
  </header>

  {{!-- Resource Costs --}}
  {{#unless displayOnly}}
  {{#if (or pipCost mpCost)}}
  <div class="shards-chat-card__costs">
    {{#if pipCost}}<span class="shards-chat-card__cost cost-pips">{{pipCost}} Pips</span>{{/if}}
    {{#if mpCost}}<span class="shards-chat-card__cost cost-mp">{{mpCost}} MP</span>{{/if}}
  </div>
  {{/if}}
  {{/unless}}

  <div class="shards-chat-card__body">
    {{!-- Duration Badge --}}
    <div class="shards-buff-roll__duration">
      <i class="fa-solid fa-hourglass-half"></i>
      <span>{{durationLabel}}</span>
    </div>

    {{#if displayOnly}}
    <div class="shards-chat-card__display-only">
      <em>{{localize "SHARDS.Roll.DisplayOnly"}}</em>
      {{#if (or pipCost mpCost)}}
      <button type="button" class="shards-chat-btn shards-chat-btn--spend"
        data-action="spend-resources"
        data-actor-id="{{actorId}}"
        data-pip-cost="{{pipCost}}"
        data-mp-cost="{{mpCost}}">
        <i class="fa-solid fa-coins"></i>
        {{localize "SHARDS.Roll.SpendResources"}}
        ({{#if pipCost}}{{pipCost}} Pips{{/if}}{{#if (and pipCost mpCost)}} + {{/if}}{{#if mpCost}}{{mpCost}} MP{{/if}})
      </button>
      {{/if}}
    </div>
    {{else}}
    <div class="shards-buff-roll__targets">
      {{#each targets}}
      <div class="shards-buff-roll__target">
        <div class="shards-buff-roll__target-header">
          <i class="fa-solid fa-sparkles"></i>
          <span class="shards-buff-roll__target-name">{{this.targetName}}</span>
          {{#if this.effectCount}}
          <span class="shards-buff-roll__effect-count">({{this.effectCount}})</span>
          {{/if}}
        </div>
        {{#if this.appliedEffects.length}}
        <div class="shards-buff-roll__effects-list">
          {{#each this.appliedEffects}}
          <div class="shards-buff-roll__effect-row">
            <img class="shards-buff-roll__effect-icon" src="{{this.img}}" alt="" width="16" height="16" />
            <span class="shards-buff-roll__effect-name">{{this.name}}</span>
          </div>
          {{/each}}
        </div>
        {{else}}
        <div class="shards-buff-roll__no-effects">
          <em>{{localize "SHARDS.Roll.BuffNoEffects"}}</em>
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}
  </div>
</div>
