<section class="tab quests" data-group="primary" data-tab="quests">
  {{!-- Toolbar --}}
  <div class="quest-toolbar">
    <h3 class="crystal-heading">
      {{localize "SHARDS.Party.QuestLog"}} ({{activeQuestCount}})
    </h3>
    <div class="quest-filters">
      <button type="button" class="quest-filter-btn {{#if (eq questFilter 'all')}}active{{/if}}"
              data-action="filterQuests" data-filter="all">
        {{localize "SHARDS.Party.FilterAll"}}
      </button>
      <button type="button" class="quest-filter-btn {{#if (eq questFilter 'active')}}active{{/if}}"
              data-action="filterQuests" data-filter="active">
        <i class="fa-solid fa-circle-play"></i> {{localize "SHARDS.Party.QuestStatus.Active"}}
      </button>
      <button type="button" class="quest-filter-btn {{#if (eq questFilter 'completed')}}active{{/if}}"
              data-action="filterQuests" data-filter="completed">
        <i class="fa-solid fa-circle-check"></i> {{localize "SHARDS.Party.QuestStatus.Completed"}}
      </button>
      <button type="button" class="quest-filter-btn {{#if (eq questFilter 'failed')}}active{{/if}}"
              data-action="filterQuests" data-filter="failed">
        <i class="fa-solid fa-circle-xmark"></i> {{localize "SHARDS.Party.QuestStatus.Failed"}}
      </button>
    </div>
    <button type="button" class="crystal-btn crystal-btn--small" data-action="addQuest">
      <i class="fa-solid fa-plus"></i> {{localize "SHARDS.Party.AddQuest"}}
    </button>
  </div>

  {{!-- Quest Cards --}}
  {{#if questCards.length}}
  <div class="quest-list">
    {{#each questCards as |quest|}}
    <div class="quest-card {{#if quest.expanded}}expanded{{/if}}" data-quest-id="{{quest.id}}"
         data-status="{{quest.status}}" data-priority="{{quest.priority}}">

      {{!-- Quest Header --}}
      <div class="quest-card__header" data-action="toggleQuestExpand">
        <span class="quest-card__status-icon" style="color: {{quest.statusColor}}">
          <i class="{{quest.statusIcon}}"></i>
        </span>
        <input type="text" class="quest-card__title" name="system.quests.{{quest._index}}.title"
               value="{{quest.title}}" placeholder="{{localize 'SHARDS.Party.QuestTitle'}}"
               onclick="event.stopPropagation()" />
        {{#if quest.objectiveProgress}}
        <span class="quest-card__progress">{{quest.objectiveProgress}}</span>
        {{/if}}
        <select name="system.quests.{{quest._index}}.priority" class="quest-card__priority"
                onclick="event.stopPropagation()">
          <option value="low" {{#if (eq quest.priority "low")}}selected{{/if}}>{{localize "SHARDS.Party.Priority.Low"}}</option>
          <option value="normal" {{#if (eq quest.priority "normal")}}selected{{/if}}>{{localize "SHARDS.Party.Priority.Normal"}}</option>
          <option value="high" {{#if (eq quest.priority "high")}}selected{{/if}}>{{localize "SHARDS.Party.Priority.High"}}</option>
          <option value="critical" {{#if (eq quest.priority "critical")}}selected{{/if}}>{{localize "SHARDS.Party.Priority.Critical"}}</option>
        </select>
        <i class="fa-solid fa-chevron-down quest-card__chevron"></i>
      </div>

      {{!-- Quest Body (Collapsible) --}}
      <div class="quest-card__body">
        {{!-- Description --}}
        <div class="quest-card__description">
          <textarea name="system.quests.{{quest._index}}.description"
                    placeholder="{{localize 'SHARDS.Party.QuestDescPlaceholder'}}"
                    rows="2">{{quest.description}}</textarea>
        </div>

        {{!-- Objectives --}}
        <div class="quest-card__objectives">
          <span class="quest-section-label">{{localize "SHARDS.Party.Objectives"}}</span>
          {{#each quest.objectives as |obj|}}
          <div class="quest-objective" data-objective-index="{{@index}}">
            <button type="button" class="quest-objective__check" data-action="toggleObjective"
                    data-objective-index="{{@index}}">
              <i class="fa-{{#if obj.completed}}solid fa-square-check{{else}}regular fa-square{{/if}}"></i>
            </button>
            <input type="text" class="quest-objective__text {{#if obj.completed}}completed{{/if}}"
                   name="system.quests.{{quest._index}}.objectives.{{@index}}.text"
                   value="{{obj.text}}" placeholder="{{localize 'SHARDS.Party.ObjectivePlaceholder'}}" />
            <button type="button" class="quest-objective__delete" data-action="deleteObjective"
                    data-objective-index="{{@index}}">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
          {{/each}}
          <button type="button" class="crystal-btn crystal-btn--small" data-action="addObjective">
            <i class="fa-solid fa-plus"></i> {{localize "SHARDS.Party.AddObjective"}}
          </button>
        </div>

        {{!-- Rewards --}}
        <div class="quest-card__rewards">
          <span class="quest-section-label">{{localize "SHARDS.Party.Rewards"}}</span>
          <input type="text" name="system.quests.{{quest._index}}.rewards" value="{{quest.rewards}}"
                 placeholder="{{localize 'SHARDS.Party.RewardsPlaceholder'}}" />
        </div>

        {{!-- Status + GM Notes + Delete --}}
        <div class="quest-card__footer">
          <select name="system.quests.{{quest._index}}.status" class="quest-status-select">
            <option value="active" {{#if (eq quest.status "active")}}selected{{/if}}>{{localize "SHARDS.Party.QuestStatus.Active"}}</option>
            <option value="completed" {{#if (eq quest.status "completed")}}selected{{/if}}>{{localize "SHARDS.Party.QuestStatus.Completed"}}</option>
            <option value="failed" {{#if (eq quest.status "failed")}}selected{{/if}}>{{localize "SHARDS.Party.QuestStatus.Failed"}}</option>
          </select>

          {{#if @root.isGM}}
          <textarea name="system.quests.{{quest._index}}.gmNotes"
                    placeholder="{{localize 'SHARDS.Party.GMNotes'}}"
                    class="quest-gm-notes" rows="1">{{quest.gmNotes}}</textarea>
          {{/if}}

          <button type="button" class="quest-card__delete" data-action="deleteQuest"
                  title="{{localize 'SHARDS.Delete'}}">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="party-empty-state">
    <i class="fa-solid fa-scroll party-empty-state__icon"></i>
    <p class="party-empty-state__text">{{localize "SHARDS.Party.NoQuests"}}</p>
  </div>
  {{/if}}
</section>
