<section class="tab members" data-group="primary" data-tab="members">
  {{!-- Toolbar --}}
  <div class="party-toolbar">
    <h3 class="crystal-heading">
      {{localize "SHARDS.Party.Roster"}} ({{memberCount}})
    </h3>
    <button type="button" class="crystal-btn crystal-btn--small" data-action="browseActors">
      <i class="fa-solid fa-magnifying-glass"></i> {{localize "SHARDS.Party.BrowseActors"}}
    </button>
  </div>

  {{!-- Drag-drop hint --}}
  <p class="party-drop-hint">
    <i class="fa-solid fa-hand-pointer"></i> {{localize "SHARDS.Party.DragDropHint"}}
  </p>

  {{!-- Member Roster --}}
  {{#if memberCards.length}}
  <div class="party-roster">
    {{#each memberCards as |member|}}
    <div class="member-card" data-member-index="{{member._index}}"
         {{#if member.roleDef}}data-role="{{member.role}}"{{/if}}>
      {{!-- Portrait --}}
      <button type="button" class="member-card__portrait-btn"
              data-action="openMemberSheet" title="{{localize 'SHARDS.Party.OpenSheet'}}">
        <img class="member-card__portrait" src="{{member.displayImg}}" width="48" height="48" />
      </button>

      {{!-- Info --}}
      <div class="member-card__info">
        <span class="member-card__name">{{member.displayName}}</span>
        <div class="member-card__details">
          {{#if member.level}}
          <span class="member-card__level">Lv.{{member.level}}</span>
          {{/if}}
          {{#if member.activeJobName}}
          <span class="rank-badge" data-rank="{{member.activeJobRank}}">{{member.activeJobRank}}</span>
          <span class="member-card__job">{{member.activeJobName}}</span>
          {{/if}}
        </div>
      </div>

      {{!-- Mini HP/MP bars --}}
      {{#if member.health}}
      <div class="member-card__bars">
        <div class="member-mini-bar health" style="--bar-pct: {{member.healthPct}}%"
             title="HP: {{member.health.value}}/{{member.health.max}}">
          <div class="member-mini-bar__fill"></div>
        </div>
        <div class="member-mini-bar mana" style="--bar-pct: {{member.manaPct}}%"
             title="MP: {{member.mana.value}}/{{member.mana.max}}">
          <div class="member-mini-bar__fill"></div>
        </div>
      </div>
      {{/if}}

      {{!-- Role Select --}}
      <div class="member-card__role">
        <select class="role-select" data-role-index="{{member._index}}">
          <option value="">--</option>
          {{#each @root.roleOptions as |opt|}}
          <option value="{{opt.key}}" {{#if (eq opt.key member.role)}}selected{{/if}}>{{opt.label}}</option>
          {{/each}}
        </select>
      </div>

      {{!-- Controls --}}
      <div class="member-card__controls">
        <button type="button" class="member-card__remove" data-action="removeMember"
                title="{{localize 'SHARDS.Party.RemoveMember'}}">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="party-empty-state">
    <i class="fa-solid fa-users party-empty-state__icon"></i>
    <p class="party-empty-state__text">{{localize "SHARDS.Party.NoMembers"}}</p>
    <p class="party-empty-state__hint">{{localize "SHARDS.Party.NoMembersHint"}}</p>
  </div>
  {{/if}}
</section>
