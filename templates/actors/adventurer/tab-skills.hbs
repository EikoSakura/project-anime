<section class="tab skills" data-group="primary" data-tab="skills">

  {{!-- Skills Header with Count, Sort Controls, and Browse --}}
  <div class="skills-toolbar">
    <div class="skills-sort-bar">
      <span class="skills-sort-label">{{localize "SHARDS.Skill.SortBy"}}:</span>
      <button type="button" class="skills-sort-btn {{#if (eq skillSort 'type')}}active{{/if}}"
              data-action="sortSkills" data-sort="type">
        <i class="fa-solid fa-layer-group"></i> {{localize "SHARDS.Skill.SortType"}}
      </button>
      <button type="button" class="skills-sort-btn {{#if (eq skillSort 'name')}}active{{/if}}"
              data-action="sortSkills" data-sort="name">
        <i class="fa-solid fa-arrow-down-a-z"></i> {{localize "SHARDS.Skill.SortName"}}
      </button>
      <button type="button" class="skills-sort-btn {{#if (eq skillSort 'level')}}active{{/if}}"
              data-action="sortSkills" data-sort="level">
        <i class="fa-solid fa-arrow-down-9-1"></i> {{localize "SHARDS.Skill.SortLevel"}}
      </button>
    </div>
    <button type="button" class="crystal-btn crystal-btn--small" data-action="browseSkills">
      <i class="fa-solid fa-magnifying-glass"></i> {{localize "SHARDS.Browser.Browse"}}
    </button>
    {{#if isGM}}
    <button type="button" class="crystal-btn crystal-btn--small crystal-btn--experience" data-action="grantExperientialSkill">
      <i class="fa-solid fa-hand-sparkles"></i> {{localize "SHARDS.Experience.Grant"}}
    </button>
    {{/if}}
  </div>

  {{!-- Skill Groups --}}
  {{#if skillCards.length}}
    {{#each skillGroups as |group|}}

    {{!-- Category Header (only when grouped by type) --}}
    {{#if group.label}}
    <div class="skill-category-header">
      <i class="{{group.icon}}"></i>
      <span class="skill-category-header__label">{{group.label}}</span>
      <span class="skill-category-header__count">{{group.skills.length}}</span>
      <div class="skill-category-header__line"></div>
    </div>
    {{/if}}

    <div class="adv-skill-grid">
      {{#each group.skills as |sk|}}
      <div class="adv-skill-card collapsible-section" data-item-id="{{sk._id}}">

        {{!-- Card Header --}}
        <div class="adv-skill-card__header">
          {{!-- Image: posts skill to chat --}}
          <button type="button" class="adv-skill-card__icon-btn"
                  data-action="postSkillToChat" title="{{localize 'SHARDS.Skill.PostToChat'}}">
            <img class="adv-skill-card__icon" src="{{sk.img}}" width="32" height="32" />
          </button>
          {{!-- Rest of header: toggles collapse --}}
          <div class="adv-skill-card__header-toggle" data-action="toggleSection">
            <div class="adv-skill-card__title">
              <span class="adv-skill-card__name">{{sk.name}}</span>
              {{#if (gt sk.stackCount 1)}}
              <span class="adv-skill-card__stack">&times;{{sk.stackCount}}</span>
              {{/if}}
              <span class="adv-skill-card__sl">SL {{sk.skillLevel}}</span>
            </div>
            {{#if (eq sk.source "experience")}}
            <span class="adv-skill-card__badge adv-skill-card__badge--experience" title="{{sk.originNote}}">
              <i class="fa-solid fa-seedling"></i>
            </span>
            {{/if}}
            <i class="fa-solid fa-chevron-down adv-skill-card__chevron"></i>
          </div>
        </div>

        {{!-- Collapsible Body --}}
        <div class="adv-skill-card__collapse">
          <div class="adv-skill-card__meta">
            {{#if sk.damageTypeLabel}}
            <span class="adv-skill-card__element">{{sk.damageTypeLabel}}</span>
            {{/if}}
            <span class="adv-skill-card__type">{{sk.skillTypeLabel}}</span>
          </div>

          {{!-- Compact Stat Row --}}
          {{#unless sk.isPassive}}
          <div class="adv-skill-card__stats">
            {{#if sk.totalHit}}
            <span class="adv-skill-card__stat adv-skill-card__stat--hit" title="{{localize 'SHARDS.Skill.HitLabel'}}">
              {{sk.totalHit}} <small>{{localize "SHARDS.Skill.HitLabel"}}</small>
            </span>
            {{/if}}
            {{#if sk.totalDamage}}
            <span class="adv-skill-card__stat adv-skill-card__stat--dmg" title="{{localize 'SHARDS.Skill.DmgLabel'}}">
              {{sk.totalDamage}} <small>{{localize "SHARDS.Skill.DmgLabel"}}</small>
            </span>
            {{/if}}
            {{#if sk.computedMpCost}}
            <span class="adv-skill-card__stat adv-skill-card__stat--mp" title="{{localize 'SHARDS.Mana'}}">
              {{sk.computedMpCost}} <small>{{localize "SHARDS.Mana"}}</small>
            </span>
            {{/if}}
            {{#if sk.computedPipCost}}
            <span class="adv-skill-card__stat adv-skill-card__stat--pips" title="{{localize 'SHARDS.Skill.PipsLabel'}}">
              {{sk.computedPipCost}} <small>{{localize "SHARDS.Skill.PipsLabel"}}</small>
            </span>
            {{/if}}
          </div>
          {{/unless}}

          {{#if sk.isPassive}}
          <div class="adv-skill-card__passive-label">
            <i class="fa-solid fa-circle-nodes"></i> {{localize "SHARDS.Skill.PassiveLabel"}}
          </div>
          {{/if}}

          {{!-- Condition --}}
          {{#if sk.conditionLabel}}
          <div class="adv-skill-card__condition">
            <i class="fa-solid fa-bolt"></i>
            {{sk.conditionChance}}% {{sk.conditionLabel}}
          </div>
          {{/if}}

          {{!-- Skill Level Row --}}
          <div class="adv-skill-card__xp-row">
            {{#if sk.isMaxLevel}}
              <span class="adv-skill-card__xp-max">MAX</span>
            {{else if isGM}}
              <button type="button" class="adv-skill-card__level-btn"
                      data-action="levelSkill"
                      title="{{localize 'SHARDS.Skill.LevelUp'}}">
                <i class="fa-solid fa-arrow-up"></i> {{localize "SHARDS.Skill.LevelUp"}}
              </button>
            {{/if}}
          </div>

          {{!-- Controls --}}
          <div class="adv-skill-card__controls">
            {{#unless sk.isPassive}}
            <button type="button" class="adv-skill-card__use-btn" data-action="useSkill" data-item-id="{{sk._id}}" title="{{localize 'SHARDS.Roll.UseSkill'}}">
              <i class="fa-solid fa-dice-d20"></i>
            </button>
            {{/unless}}
            <button type="button" data-action="editItem" title="{{localize 'SHARDS.Edit'}}">
              <i class="fa-solid fa-pen-to-square"></i>
            </button>
            <button type="button" data-action="deleteItem" title="{{localize 'SHARDS.Delete'}}">
              <i class="fa-solid fa-trash"></i>
            </button>
          </div>
        </div>

      </div>
      {{/each}}
    </div>
    {{/each}}
  {{else}}
  <p class="crystal-empty">{{localize "SHARDS.Skill.NoSkills"}}</p>
  {{/if}}

  {{!-- Manacite Pouch: Unabsorbed Manacite --}}
  <div class="manacite-pouch-section">
    <span class="section-label"><i class="fa-solid fa-gem"></i> {{localize "SHARDS.Skill.ManacitePouch"}}</span>
    {{#if unabsorbedManacite.length}}
    <ol class="crystal-item-list">
      {{#each unabsorbedManacite as |item|}}
      <li class="crystal-item" data-item-id="{{item._id}}">
        <div class="item-name" data-action="editItem">
          <img src="{{item.img}}" width="24" height="24" />
          <span>{{item.name}}</span>
        </div>
        <span class="rank-badge" data-rank="{{item.system.rank}}">{{item.system.rank}}</span>
        {{#if item.system.skillGranted}}
        <span class="item-detail">{{item.system.skillGranted}} SL{{item.system.skillLevel}}</span>
        {{/if}}
        <div class="item-controls">
          <button type="button" class="crystal-btn crystal-btn--small" data-action="absorbManacite" title="{{localize 'SHARDS.Manacite.Absorb'}}">
            <i class="fa-solid fa-hand-sparkles"></i> {{localize "SHARDS.Manacite.Absorb"}}
          </button>
          <button type="button" data-action="editItem" title="{{localize 'SHARDS.Edit'}}">
            <i class="fa-solid fa-pen-to-square"></i>
          </button>
          <button type="button" data-action="deleteItem" title="{{localize 'SHARDS.Delete'}}">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      </li>
      {{/each}}
    </ol>
    {{else}}
    <p class="crystal-empty crystal-empty--small">
      {{localize "SHARDS.Skill.ManacitePouchEmpty"}}
    </p>
    {{/if}}
  </div>

  {{!-- Exposure Tracker (GM Only) --}}
  {{#if isGM}}
  {{#if hasExposureEntries}}
  <span class="section-label"><i class="fa-solid fa-dna"></i> {{localize "SHARDS.Experience.ExposureTracker"}}</span>
  <div class="exposure-tracker">
    {{#each exposureEntries as |entry|}}
    <div class="exposure-entry {{#if entry.reached}}exposure-entry--reached{{/if}}">
      <div class="exposure-entry__label">
        <span class="exposure-entry__condition">{{entry.conditionLabel}}</span>
        <span class="exposure-entry__count">{{entry.count}} / {{entry.threshold}}</span>
      </div>
      <div class="exposure-entry__bar">
        <div class="exposure-entry__fill" style="width: {{entry.pct}}%"></div>
      </div>
      {{#if entry.reached}}
      <div class="exposure-entry__ready">
        <i class="fa-solid fa-sparkles"></i>
        <span>{{localize "SHARDS.Experience.ThresholdReached"}}</span>
      </div>
      {{/if}}
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{/if}}

</section>
