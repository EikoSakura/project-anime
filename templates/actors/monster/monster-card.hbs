<div class="crystal-card" style="display: grid; grid-template-columns: 130px 1fr 1fr; gap: 10px; align-items: start;">

  {{!-- Column 1: Portrait + Identity --}}
  <div style="display: flex; flex-direction: column; align-items: center; gap: 4px;">
    <img class="crystal-portrait" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}" />
    <div class="rank-badge" data-rank="{{system.rank}}">{{system.rank}}</div>
    {{!-- Species Tags --}}
    <div style="display: flex; flex-wrap: wrap; gap: 2px; justify-content: center;">
      {{#each system.speciesTags}}
      <span class="tag-chip">{{this}}</span>
      {{/each}}
    </div>
  </div>

  {{!-- Column 2: Name + Bars + Stats --}}
  <div style="display: flex; flex-direction: column; gap: 4px;">
    <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'SHARDS.Name'}}"
           style="font-family: var(--shards-font-heading); font-size: 1.3em; font-weight: 700; color: var(--shards-accent); background: transparent; border: none; border-bottom: 1px solid transparent; width: 100%; padding: 0;" />

    {{!-- Rank Select --}}
    <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
      <label style="font-size: 0.75em; text-transform: uppercase; color: var(--shards-text-muted); font-weight: 700;">{{localize "SHARDS.Rank"}}</label>
      <select name="system.rank" style="width: 60px;">
        {{selectOptions config.ranks selected=system.rank localize=true}}
      </select>
    </div>

    {{!-- HP / MP --}}
    <div class="crystal-bar health" style="--bar-empty: {{healthClip}}%">
      <span class="crystal-bar__diamond"><i class="fa-solid fa-diamond"></i></span>
      <span class="crystal-bar__label">{{localize "SHARDS.Health"}}</span>
      <div class="crystal-bar__inputs">
        <input type="number" name="system.health.value" value="{{system.health.value}}" data-dtype="Number" />
        <span class="separator">/</span>
        <input type="number" name="system.health.max" value="{{system.health.max}}" data-dtype="Number" />
      </div>
    </div>
    <div class="crystal-bar mana" style="--bar-empty: {{manaClip}}%">
      <span class="crystal-bar__diamond"><i class="fa-solid fa-diamond"></i></span>
      <span class="crystal-bar__label">{{localize "SHARDS.Mana"}}</span>
      <div class="crystal-bar__inputs">
        <input type="number" name="system.mana.value" value="{{system.mana.value}}" data-dtype="Number" />
        <span class="separator">/</span>
        <input type="number" name="system.mana.max" value="{{system.mana.max}}" data-dtype="Number" />
      </div>
    </div>

    {{!-- Stats Grid --}}
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3px; margin-top: 4px;">
      {{#each system.stats as |stat key|}}
      <div class="stat-cell" data-action="rollStat" data-stat="{{key}}" title="{{localize 'SHARDS.RollStat'}}">
        <span class="stat-abbrev">{{key}}</span>
        <span class="stat-value">{{stat.total}}</span>
      </div>
      {{/each}}
    </div>

    {{!-- Pips --}}
    <div style="display: flex; align-items: center; gap: 6px; margin-top: 4px;">
      <span style="font-size: 0.65em; font-weight: 700; text-transform: uppercase; color: var(--shards-accent);">{{localize "SHARDS.Pips"}}</span>
      <div class="pip-dots">
        {{#each pipArray}}
        <span class="pip-dot {{#if this.filled}}filled{{/if}}"></span>
        {{/each}}
      </div>
      <input type="number" name="system.pips.value" value="{{system.pips.value}}" data-dtype="Number" min="0" style="width: 30px; text-align: center;" />
      <span class="separator">/</span>
      <input type="number" name="system.pips.max" value="{{system.pips.max}}" data-dtype="Number" min="0" style="width: 30px; text-align: center;" />
    </div>
  </div>

  {{!-- Column 3: Derived + MOV + Resistances --}}
  <div style="display: flex; flex-direction: column; gap: 6px;">
    {{!-- Derived Stats --}}
    <div class="derived-grid">
      {{#each system.derived as |value key|}}
      <div class="derived-cell">
        <span class="derived-label">{{localize (concat "SHARDS.Derived." key)}}</span>
        <span class="derived-value">{{value}}</span>
      </div>
      {{/each}}
    </div>

    {{!-- Size + MOV --}}
    <div style="display: flex; align-items: center; gap: 12px;">
      <div style="display: flex; align-items: center; gap: 6px;">
        <span style="font-size: 0.7em; font-weight: 700; text-transform: uppercase; color: var(--shards-text-muted);">{{localize "SHARDS.Size"}}</span>
        <span style="font-size: 0.85em; font-weight: 600; color: var(--shards-accent);">{{system.size}}</span>
      </div>
      <div style="display: flex; align-items: center; gap: 6px;">
        <span style="font-size: 0.7em; font-weight: 700; text-transform: uppercase; color: var(--shards-text-muted);">{{localize "SHARDS.Movement.Label"}}</span>
        <input type="number" name="system.mov" value="{{system.mov}}" data-dtype="Number" style="width: 36px; text-align: center;" />
      </div>
    </div>

    {{!-- Element Resistances (tier-based) --}}
    <div class="elements-compact">
      {{#each elementDisplay}}
      <span class="element-chip {{this.category}}" title="{{this.label}}: {{this.categoryLabel}}">
        <span class="element-chip__name">{{this.label}}</span>
        <span class="element-chip__value">{{this.categoryLabel}}</span>
      </span>
      {{/each}}
    </div>
  </div>

</div>
