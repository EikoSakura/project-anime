<section class="tab drops" data-group="primary" data-tab="drops">

  {{!-- Gold Drops --}}
  <h3 class="crystal-heading">{{localize "SHARDS.Drops.Gold"}}</h3>
  <div class="drops-gold-range">
    <label>
      {{localize "SHARDS.Drops.GoldMin"}}
      <input type="number" name="system.goldMin" value="{{system.goldMin}}" data-dtype="Number" min="0" />
    </label>
    <span class="drops-gold-separator">&mdash;</span>
    <label>
      {{localize "SHARDS.Drops.GoldMax"}}
      <input type="number" name="system.goldMax" value="{{system.goldMax}}" data-dtype="Number" min="0" />
    </label>
  </div>

  {{!-- Drop Table --}}
  <h3 class="crystal-heading">{{localize "SHARDS.Drops.Title"}}</h3>
  <div style="margin-bottom: 8px;">
    <button type="button" class="crystal-btn" data-action="addDrop">
      <i class="fa-solid fa-plus"></i> {{localize "SHARDS.Drops.AddDrop"}}
    </button>
  </div>

  {{#if system.dropTable.length}}
  <table class="crystal-table">
    <thead>
      <tr>
        <th>{{localize "SHARDS.ManaciteLabel"}}</th>
        <th>{{localize "SHARDS.Drops.Rank"}}</th>
        <th>{{localize "SHARDS.Monster.DropPercent"}}</th>
        <th>{{localize "SHARDS.Drops.Quantity"}}</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each system.dropTable as |drop idx|}}
      <tr>
        <td>
          <input type="text" name="system.dropTable.{{idx}}.manaciteName" value="{{drop.manaciteName}}" placeholder="Manacite name..." />
        </td>
        <td>
          <select name="system.dropTable.{{idx}}.manaciteRank" style="width: 60px;">
            <option value="" {{#unless drop.manaciteRank}}selected{{/unless}}>{{@root.system.rank}}</option>
            {{#each @root.rankOptions}}
            <option value="{{this.value}}" {{#if (eq this.value drop.manaciteRank)}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </td>
        <td>
          <input type="number" name="system.dropTable.{{idx}}.dropChance" value="{{drop.dropChance}}" data-dtype="Number" min="0" max="100" style="width: 50px; text-align: center;" /> %
        </td>
        <td>
          <input type="number" name="system.dropTable.{{idx}}.quantity" value="{{drop.quantity}}" data-dtype="Number" min="1" style="width: 40px; text-align: center;" />
        </td>
        <td>
          <button type="button" data-action="deleteDrop" data-drop-index="{{idx}}" title="{{localize 'SHARDS.Delete'}}">
            <i class="fa-solid fa-trash" style="color: var(--shards-text-muted);"></i>
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p style="color: var(--shards-text-muted); font-size: 0.85em; font-style: italic;">{{localize "SHARDS.Drops.NoDrops"}}</p>
  {{/if}}

  {{!-- Drop Actions --}}
  <div class="drops-actions" style="margin-top: 12px; display: flex; gap: 8px;">
    <button type="button" class="crystal-btn" data-action="testDrops" title="{{localize 'SHARDS.Drops.TestRoll'}}">
      <i class="fa-solid fa-flask"></i> {{localize "SHARDS.Drops.TestRoll"}}
    </button>
    <button type="button" class="crystal-btn" data-action="rollDrops" title="{{localize 'SHARDS.Drops.RollDrops'}}">
      <i class="fa-solid fa-dice-d20"></i> {{localize "SHARDS.Drops.RollDrops"}}
    </button>
  </div>

  {{!-- Behavior Priority --}}
  <h3 class="crystal-heading" style="margin-top: 16px;">{{localize "SHARDS.Monster.BehaviorPriority"}}</h3>
  <div style="margin-bottom: 8px;">
    <button type="button" class="crystal-btn" data-action="addBehavior">
      <i class="fa-solid fa-plus"></i> {{localize "SHARDS.Monster.AddBehavior"}}
    </button>
  </div>

  {{#if system.behaviorPriority.length}}
  <ol style="list-style: decimal; padding-left: 20px; margin: 0;">
    {{#each system.behaviorPriority as |behavior idx|}}
    <li style="display: flex; align-items: center; gap: 8px; padding: 3px 0; border-bottom: 1px solid rgba(68,68,104,0.4);">
      <input type="text" name="system.behaviorPriority.{{idx}}" value="{{behavior}}" style="flex: 1;" />
      <button type="button" data-action="deleteBehavior" data-behavior-index="{{idx}}" title="{{localize 'SHARDS.Delete'}}">
        <i class="fa-solid fa-trash" style="color: var(--shards-text-muted);"></i>
      </button>
    </li>
    {{/each}}
  </ol>
  {{else}}
  <p style="color: var(--shards-text-muted); font-size: 0.85em; font-style: italic;">{{localize "SHARDS.Monster.NoBehaviors"}}</p>
  {{/if}}

</section>
