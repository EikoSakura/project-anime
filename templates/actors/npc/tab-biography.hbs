<section class="tab biography" data-group="primary" data-tab="biography">
  <div class="editor-container">
    {{editor enrichedBiography target="system.biography" button=true editable=true}}
  </div>

  {{!-- GM Notes --}}
  <h3 class="crystal-heading">{{localize "SHARDS.Npc.GmNotes"}}</h3>
  <div style="margin-top: 4px;">
    <textarea name="system.gmNotes" rows="4" style="width: 100%; background: var(--shards-bg-input); color: var(--shards-text); border: 1px solid var(--shards-border); border-radius: 3px; padding: 6px; font-family: var(--shards-font-body); resize: vertical;">{{system.gmNotes}}</textarea>
  </div>
</section>
