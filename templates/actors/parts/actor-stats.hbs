<section class="tab stats" data-group="primary" data-tab="stats">

  {{!-- Core Stats Table --}}
  <h2>{{localize "SHARDS.CoreStats"}}</h2>
  <table class="stats-table">
    <thead>
      <tr>
        <th>{{localize "SHARDS.Stat"}}</th>
        <th>{{localize "SHARDS.Base"}}</th>
        <th>{{localize "SHARDS.Bonus"}}</th>
        <th>{{localize "SHARDS.Total"}}</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#each system.stats as |stat key|}}
      <tr>
        <td class="stat-label">{{localize (concat "SHARDS.Stats." key)}}</td>
        <td>
          <input type="number" name="system.stats.{{key}}.base"
                 value="{{stat.base}}" data-dtype="Number" />
        </td>
        <td>
          <input type="number" name="system.stats.{{key}}.bonus"
                 value="{{stat.bonus}}" data-dtype="Number" />
        </td>
        <td class="stat-total">{{stat.total}}</td>
        <td>
          <button type="button" class="roll-stat" data-action="rollStat" data-stat="{{key}}"
                  title="{{localize 'SHARDS.RollStat'}}">
            <i class="fa-solid fa-dice-d20"></i>
          </button>
        </td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- Derived Stats --}}
  <h2>{{localize "SHARDS.DerivedStats"}}</h2>
  <div class="derived-stats-grid">
    <div class="derived-stat">
      <span class="label">{{localize "SHARDS.Derived.Acc"}}</span>
      <span class="value">{{system.derived.acc}}</span>
    </div>
    <div class="derived-stat">
      <span class="label">{{localize "SHARDS.Derived.Eva"}}</span>
      <span class="value">{{system.derived.eva}}</span>
    </div>
    <div class="derived-stat">
      <span class="label">{{localize "SHARDS.Derived.PDef"}}</span>
      <span class="value">{{system.derived.pDef}}</span>
    </div>
    <div class="derived-stat">
      <span class="label">{{localize "SHARDS.Derived.MDef"}}</span>
      <span class="value">{{system.derived.mDef}}</span>
    </div>
    <div class="derived-stat">
      <span class="label">{{localize "SHARDS.Derived.Crit"}}</span>
      <span class="value">{{system.derived.crit}}</span>
    </div>
  </div>

  {{!-- Movement --}}
  <div class="movement flexrow">
    <label>{{localize "SHARDS.Movement.Label"}}</label>
    <input type="number" name="system.mov" value="{{system.mov}}" data-dtype="Number" />
    <span>{{localize "SHARDS.Movement.Squares"}}</span>
  </div>

</section>
