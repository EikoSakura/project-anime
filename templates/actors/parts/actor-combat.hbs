<section class="tab combat" data-group="primary" data-tab="combat">

  {{!-- Pips --}}
  <div class="pips-display flexrow">
    <label>{{localize "SHARDS.Pips"}}</label>
    <div class="pip-inputs flexrow">
      <input type="number" name="system.pips.value"
             value="{{system.pips.value}}" data-dtype="Number" min="0" />
      <span class="separator">/</span>
      <input type="number" name="system.pips.max"
             value="{{system.pips.max}}" data-dtype="Number" min="0" />
    </div>
  </div>

  {{!-- Conditions --}}
  <h2>{{localize "SHARDS.ConditionsLabel"}}</h2>
  <div class="conditions-grid">
    {{#each system.conditions as |value key|}}
    <div class="condition {{#if value}}active{{/if}}">
      <label>{{localize (concat "SHARDS.Condition." key)}}</label>
      <input type="number" name="system.conditions.{{key}}"
             value="{{value}}" data-dtype="Number" min="0" />
    </div>
    {{/each}}
  </div>

  {{!-- Skills --}}
  <h2>{{localize "SHARDS.Tabs.Skills"}}</h2>
  <ol class="item-list skill-list">
    {{#each items.skill as |item|}}
    <li class="item flexrow" data-item-id="{{item._id}}">
      <div class="item-name" data-action="editItem">
        <img src="{{item.img}}" width="24" height="24" />
        <span>{{item.name}}</span>
      </div>
      <div class="item-controls flexrow">
        <button type="button" data-action="useItem" title="{{localize 'SHARDS.Use'}}">
          <i class="fa-solid fa-dice-d20"></i>
        </button>
        <button type="button" data-action="deleteItem" title="{{localize 'SHARDS.Delete'}}">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    </li>
    {{/each}}
  </ol>

</section>
