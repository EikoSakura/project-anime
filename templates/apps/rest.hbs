<div class="rest-body">
  <div class="rest-types">
    <button type="button" class="rest-type{{#if isCamp}} active{{/if}}" data-action="pickRest" data-rest="camp">
      <span class="rt-name"><i class="fas fa-campground"></i> {{localize "PROJECTANIME.Rest.camp"}}</span>
    </button>
    <button type="button" class="rest-type{{#if isTown}} active{{/if}}" data-action="pickRest" data-rest="town">
      <span class="rt-name"><i class="fas fa-house-chimney"></i> {{localize "PROJECTANIME.Rest.town"}}</span>
    </button>
  </div>

  {{#if canHQ}}
  <button type="button" class="rest-hq{{#if atHQ}} active{{/if}}" data-action="toggleHQ">
    <i class="fas fa-fort-awesome"></i>
    <span>{{localize "PROJECTANIME.HQ.restHere"}}{{#if atHQ}} — <b>{{hqRankName}}</b>{{#if hqRankUp}} <span class="rest-hq-up">→ {{hqRankUp}}</span>{{/if}}{{/if}}</span>
  </button>
  {{/if}}

  <section class="rest-downtime">
    <h3>
      {{localize "PROJECTANIME.Rest.downtime"}}<span class="rest-tier">{{tierLabel}}</span>
      {{#if isTown}}
      <span class="rest-days">
        {{localize "PROJECTANIME.Rest.days"}}
        <button type="button" class="rd-step" data-action="stepDays" data-delta="-1">−</button><b>{{days}}</b><button type="button" class="rd-step" data-action="stepDays" data-delta="1">＋</button>
        <span class="rd-slots">{{#if single}}{{spent}}/{{/if}}{{slots}} {{localize "PROJECTANIME.Rest.slots"}}</span>
      </span>
      {{/if}}
    </h3>
    {{#if isTown}}
    <div class="rest-actors">
      {{#each actors as |a|}}
      <div class="rest-actor">
        {{#unless @root.single}}
        <div class="ra-head">
          <img src="{{a.img}}" alt="">
          <span class="ra-name">{{a.name}}</span>
          <span class="ra-slots">{{a.spent}}/{{a.slots}}</span>
        </div>
        {{/unless}}
        <div class="dt-list">
          {{#each a.activities as |act|}}
          <div class="dt-item{{#if act.picked}} active{{/if}}">
            <span class="dt-name">{{act.label}}</span>
            {{#if act.note}}<span class="dt-sp">{{act.note}}</span>{{/if}}
            <span class="dt-count">
              <button type="button" data-action="decActivity" data-actor="{{a.id}}" data-key="{{act.key}}" {{#unless act.canSub}}disabled{{/unless}}>−</button>
              <b>{{act.count}}</b>
              <button type="button" data-action="incActivity" data-actor="{{a.id}}" data-key="{{act.key}}" {{#unless act.canAdd}}disabled{{/unless}}>＋</button>
            </span>
          </div>
          {{/each}}
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}
  </section>

  <button type="button" class="rest-complete" data-action="completeRest">
    <i class="fas fa-bed"></i> {{localize "PROJECTANIME.Rest.complete"}}
  </button>
</div>
