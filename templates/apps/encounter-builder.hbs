<div class="encounter-builder-content">

  {{!-- Party Configuration --}}
  <div class="encounter-section">
    <h3 class="encounter-section__title"><i class="fa-solid fa-users"></i> {{localize "SHARDS.Encounter.PartyConfig"}}</h3>
    <div class="encounter-party-config">
      <div class="encounter-field">
        <label>{{localize "SHARDS.Encounter.PartySize"}}</label>
        <input type="number" data-field="partySize" value="{{state.partySize}}" min="1" max="8" />
      </div>
      <div class="encounter-field">
        <label>{{localize "SHARDS.Encounter.PartyRank"}}</label>
        <select data-field="partyRank">
          {{#each rankOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="encounter-field">
        <label>{{localize "SHARDS.Encounter.Difficulty"}}</label>
        <select data-field="difficulty">
          {{#each difficultyOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </div>

  {{!-- Suggestion --}}
  <div class="encounter-section encounter-suggestion">
    <h3 class="encounter-section__title"><i class="fa-solid fa-lightbulb"></i> {{localize "SHARDS.Encounter.Suggestion"}}</h3>
    <p class="encounter-suggestion__text">{{{suggestion}}}</p>
  </div>

  {{!-- Roster --}}
  <div class="encounter-section encounter-roster">
    <div class="encounter-roster-header">
      <h3 class="encounter-section__title"><i class="fa-solid fa-list"></i> {{localize "SHARDS.Encounter.Roster"}} ({{roster.length}})</h3>
      <div class="encounter-roster-actions">
        <button type="button" data-action="addFromBrowser"><i class="fa-solid fa-magnifying-glass"></i> {{localize "SHARDS.Encounter.Browse"}}</button>
        <button type="button" data-action="clearRoster" {{#unless roster.length}}disabled{{/unless}}><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>

    {{!-- Difficulty Assessment --}}
    {{#if roster.length}}
    <div class="encounter-assessment encounter-assessment--{{assessmentClass}}">
      <span class="encounter-assessment__label">{{localize "SHARDS.Encounter.AssessmentLabel"}}:</span>
      <span class="encounter-assessment__value">{{assessmentLabel}}</span>
    </div>
    {{/if}}

    <div class="encounter-roster-list">
      {{#if roster.length}}
        {{#each roster}}
        <div class="encounter-roster-entry">
          <img class="encounter-roster-entry__img" src="{{this.img}}" width="36" height="36" />
          <span class="encounter-roster-entry__name">{{this.name}}</span>
          <span class="encounter-roster-entry__rank rank-badge rank-badge--{{this.rank}}">{{this.rank}}</span>
          <span class="encounter-roster-entry__hp"><i class="fa-solid fa-heart"></i> {{this.hp}}</span>
          <button type="button" class="encounter-roster-entry__remove" data-action="removeMonster" data-index="{{@index}}"><i class="fa-solid fa-xmark"></i></button>
        </div>
        {{/each}}
      {{else}}
        <div class="encounter-roster-empty">
          <i class="fa-solid fa-dragon"></i>
          <p>{{localize "SHARDS.Encounter.EmptyRoster"}}</p>
        </div>
      {{/if}}
    </div>
  </div>

  {{!-- Create Button --}}
  {{#if roster.length}}
  <div class="encounter-create">
    <button type="button" class="encounter-create-btn" data-action="createEncounter">
      <i class="fa-solid fa-plus-circle"></i> {{localize "SHARDS.Encounter.Create"}}
    </button>
  </div>
  {{/if}}

</div>
