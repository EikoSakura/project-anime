{{!-- Project: Anime — encounter tracker (frameless ApplicationV2 part), pinned just left of the
      chat sidebar. SIDE INITIATIVE layout: a header nav bar (GM), the combatant list broken into
      Player / Enemy / Neutral PHASE blocks (the active phase highlighted; a viewer's not-yet-acted
      units in it are pickable — free-pick), and a footer with the round + active phase, the player's
      End Turn (when they control the acting unit), and the collapse toggle. --}}
{{#if show}}
<div class="ct-wrap{{#if collapsed}} collapsed{{/if}}">

  <div class="ct-head">
    {{#if gm}}
      {{#if started}}
      <a class="ct-endcombat" data-action="combatEndCombat">{{localize 'PROJECTANIME.Hud.combat.endEncounter'}}</a>
      <a class="ct-nav" data-action="combatEndTurn" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.advance'}}"><i class="fas fa-arrow-right"></i></a>
      <a class="ct-nav" data-action="combatNextRound" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.nextRound'}}"><i class="fas fa-forward-step"></i></a>
      {{else}}
      <a class="ct-begin" data-action="combatBegin"><i class="fas fa-play"></i> {{localize 'PROJECTANIME.Hud.combat.begin'}}</a>
      {{/if}}
      {{#if threat}}
      <span class="ct-threat" data-band="{{threat.band}}" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.threat'}} · {{threat.label}}"><i class="fas fa-skull"></i> {{threat.total}}/{{threat.party}}</span>
      {{/if}}
    {{else}}
      <span class="ct-title"><i class="fas fa-swords"></i> {{localize 'PROJECTANIME.Hud.combat.title'}}</span>
    {{/if}}
  </div>

  <ol class="ct-list">
    {{#each groups}}
    <li class="ct-phase disp-{{side}}{{#if active}} active{{/if}}">
      <span class="ct-phase-name">{{label}}</span>
    </li>
    {{#each rows}}
    <li class="ct-row disp-{{disp}}{{#if active}} active{{/if}}{{#if acted}} acted{{/if}}{{#if activatable}} pickable{{/if}}{{#if keep}} keep{{/if}}{{#if defeated}} defeated{{/if}}{{#if hidden}} hidden{{/if}}"
        data-combatant-id="{{id}}" data-action="{{#if activatable}}combatActivate{{else}}combatGoto{{/if}}" data-tooltip="{{name}}">
      <div class="ct-av">
        <div class="ct-img" style="background-image:url('{{img}}')"></div>
        {{#if defeated}}<i class="ct-dead fas fa-skull"></i>{{/if}}
        {{#if acted}}<i class="ct-done fas fa-check"></i>{{/if}}
      </div>
      <div class="ct-mid">
        <div class="ct-name">{{name}}</div>
        <div class="ct-ctrls">
          {{#if @root.gm}}
          <a class="ct-c{{#if hidden}} active{{/if}}" data-action="combatToggleHidden" data-tooltip="{{hideLabel}}"><i class="fas {{#if hidden}}fa-eye-slash{{else}}fa-eye{{/if}}"></i></a>
          <a class="ct-c{{#if defeated}} active{{/if}}" data-action="combatToggleDefeated" data-tooltip="{{defeatLabel}}"><i class="fas fa-skull"></i></a>
          {{/if}}
          <a class="ct-c{{#if targeted}} active{{/if}}" data-action="combatTarget" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.target'}}"><i class="fas fa-crosshairs"></i></a>
          <a class="ct-c" data-action="combatPing" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.ping'}}"><i class="fas fa-location-dot"></i></a>
        </div>
      </div>
      <div class="ct-extras">
        {{#if canEndRow}}
        <a class="ct-endrow" data-action="combatEndTurn" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.endTurn'}}"><i class="fas fa-hourglass-end"></i></a>
        {{else}}{{#if activatable}}
        <span class="ct-go" data-tooltip="{{localize 'PROJECTANIME.Hud.combat.activate'}}"><i class="fas fa-play"></i></span>
        {{/if}}{{/if}}
        {{#if seeHP}}
        <div class="ct-hp" style="--hue:{{hp.hue}}" data-tooltip="{{hp.value}}/{{hp.max}}"><span>{{hp.value}}</span><i class="fas fa-heart"></i></div>
        {{else}}{{#if health}}
        <div class="ct-health" style="color:{{health.tint}}" data-tooltip="{{health.label}}">{{health.label}}</div>
        {{/if}}{{/if}}
        {{#if seeEN}}
        <div class="ct-en" data-tooltip="{{en.value}}/{{en.max}}"><span>{{en.value}}</span><i class="fas fa-bolt"></i></div>
        {{/if}}
      </div>
    </li>
    {{/each}}
    {{/each}}
  </ol>

  <div class="ct-foot">
    <div class="ct-foot-l">
      {{#unless gm}}{{#if canEnd}}
      <a class="ct-end" data-action="combatEndTurn"><i class="fas fa-hourglass-end"></i> {{localize 'PROJECTANIME.Hud.combat.endTurn'}}</a>
      {{/if}}{{/unless}}
    </div>
    <span class="ct-round">{{#if started}}{{localize "PROJECTANIME.Hud.combat.round"}} {{round}}{{#if phaseLabel}} · {{phaseLabel}}{{/if}}{{else}}{{localize "PROJECTANIME.Hud.combat.notStarted"}}{{/if}}</span>
    <div class="ct-foot-r">
      <a class="ct-fbtn ct-collapse" data-action="combatToggleCollapse" data-tooltip="{{collapseLabel}}">
        <i class="fas {{#if collapsed}}fa-up-right-and-down-left-from-center{{else}}fa-down-left-and-up-right-to-center{{/if}}"></i>
      </a>
    </div>
  </div>
</div>
{{/if}}
