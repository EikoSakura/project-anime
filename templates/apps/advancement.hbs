{{!-- Advancement — the V2 milestone spender. Every +/− stages one advancement against the
      unspent pool and the option's slot cap; CONFIRM commits the lot. --}}
<div class="lv-body">

  <div class="lv-sp">
    <span class="lv-sp-label">{{localize "PROJECTANIME.Advancement.available"}}</span>
    <span class="lv-sp-right"><i class="lv-dia"></i><span class="lv-sp-val">{{left}}</span></span>
  </div>

  <div class="lv-shd"><span class="lv-dash">&mdash;</span><span class="lv-tt">{{localize "PROJECTANIME.Advancement.optionList"}}</span><span class="lv-ln"></span></div>

  {{!-- Create a Technique --}}
  <div class="lv-row">
    <span class="lv-nm2"><i class="fa-solid fa-wand-sparkles"></i><span>{{technique.label}}<span class="lv-hint">{{technique.slots}}</span></span></span>
    <span class="lv-fill"></span>
    {{#if technique.staged}}<span class="lv-val lv-staged">+1</span>{{/if}}
    <span class="lv-stp">
      <button type="button" data-action="stage" data-kind="technique" data-delta="-1" {{#unless technique.canMinus}}disabled{{/unless}}>&minus;</button>
      <span class="lv-cost">1</span>
      <button type="button" data-action="stage" data-kind="technique" data-delta="1" {{#unless technique.canPlus}}disabled{{/unless}}>+</button>
    </span>
  </div>

  {{!-- +1 Energy Box --}}
  <div class="lv-row">
    <span class="lv-nm2"><i class="fa-solid fa-bolt"></i><span>{{energy.label}}<span class="lv-hint">{{energy.slots}}</span></span></span>
    <span class="lv-val lv-fill">{{energy.value}}{{#if energy.stagedAmount}} <span class="lv-staged">{{energy.stagedAmount}}</span>{{/if}}</span>
    <span class="lv-stp">
      <button type="button" data-action="stage" data-kind="energy" data-delta="-1" {{#unless energy.canMinus}}disabled{{/unless}}>&minus;</button>
      <span class="lv-cost">1</span>
      <button type="button" data-action="stage" data-kind="energy" data-delta="1" {{#unless energy.canPlus}}disabled{{/unless}}>+</button>
    </span>
  </div>

  {{!-- +1 Hit Box --}}
  <div class="lv-row">
    <span class="lv-nm2"><i class="fa-solid fa-heart-circle-plus"></i><span>{{hitBox.label}}<span class="lv-hint">{{hitBox.slots}}</span></span></span>
    <span class="lv-val lv-fill">{{hitBox.value}}{{#if hitBox.stagedAmount}} <span class="lv-staged">{{hitBox.stagedAmount}}</span>{{/if}}</span>
    <span class="lv-stp">
      <button type="button" data-action="stage" data-kind="hitBox" data-delta="-1" {{#unless hitBox.canMinus}}disabled{{/unless}}>&minus;</button>
      <span class="lv-cost">1</span>
      <button type="button" data-action="stage" data-kind="hitBox" data-delta="1" {{#unless hitBox.canPlus}}disabled{{/unless}}>+</button>
    </span>
  </div>

  {{!-- Learn a New Talent --}}
  <div class="lv-row">
    <span class="lv-nm2"><i class="fa-solid fa-graduation-cap"></i><span>{{talent.label}}<span class="lv-hint">{{talent.slots}}</span></span></span>
    <span class="lv-fill"></span>
    <span class="lv-stp">
      <span class="lv-cost">1</span>
      <button type="button" data-action="addTalent" {{#unless talent.canPlus}}disabled{{/unless}}>+</button>
    </span>
  </div>
  {{#each talent.rows as |t|}}
  <div class="lv-row">
    <input type="text" class="adv-talent-name lv-fill" data-index="{{t.index}}" value="{{t.name}}" placeholder="{{localize 'PROJECTANIME.Talent.name'}}" />
    <select class="adv-talent-attr" data-index="{{t.index}}">{{selectOptions @root.attrChoices selected=t.attr}}</select>
    <span class="lv-stp"><button type="button" data-action="removeTalent" data-index="{{t.index}}">&minus;</button></span>
  </div>
  {{/each}}

  {{!-- Rebuild a Technique --}}
  <div class="lv-row">
    <span class="lv-nm2"><i class="fa-solid fa-rotate"></i><span>{{rebuild.label}}<span class="lv-hint">{{rebuild.slots}}</span></span></span>
    <select class="adv-rebuild lv-fill" {{#if rebuild.disabled}}disabled{{/if}}>
      <option value="">{{localize "PROJECTANIME.Advancement.pickTechnique"}}</option>
      {{#each rebuild.options as |o|}}<option value="{{o.id}}" {{#if o.selected}}selected{{/if}}>{{o.name}}</option>{{/each}}
    </select>
    <span class="lv-stp"><span class="lv-cost">1</span></span>
  </div>

  <div class="lv-shd"><span class="lv-dash">&mdash;</span><span class="lv-tt">{{localize "PROJECTANIME.Advancement.attributes"}}</span><span class="lv-ln"></span></div>
  {{#each attributes as |a|}}
  <div class="lv-row">
    <span class="lv-nm">{{#if a.icon}}<i class="{{a.icon}}"></i>{{/if}}<span>{{a.label}}</span></span>
    <span class="lv-track">
      {{#each a.nodes as |n|}}<i class="lv-node {{n.cls}}"></i>{{#unless n.last}}<i class="lv-link {{n.linkCls}}"></i>{{/unless}}{{/each}}
    </span>
    <span class="lv-die{{#if a.staged}} up{{/if}}">{{a.die}}</span>
    <span class="lv-stp">
      <button type="button" data-action="stage" data-kind="attr" data-key="{{a.key}}" data-delta="-1" {{#unless a.canMinus}}disabled{{/unless}}>&minus;</button>
      <span class="lv-cost">1</span>
      <button type="button" data-action="stage" data-kind="attr" data-key="{{a.key}}" data-delta="1" {{#unless a.canPlus}}disabled{{/unless}}>+</button>
    </span>
  </div>
  {{/each}}

  {{#if hasTalents}}
  <div class="lv-shd"><span class="lv-dash">&mdash;</span><span class="lv-tt">{{localize "PROJECTANIME.Advancement.talents"}}</span><span class="lv-ln"></span></div>
  {{#each talentRows as |t|}}
  <div class="lv-row">
    <span class="lv-nm2"><i class="fa-solid fa-graduation-cap"></i><span>{{t.name}}<span class="lv-hint">{{t.attrLabel}}</span></span></span>
    <span class="lv-track">
      {{#each t.nodes as |n|}}<i class="lv-node {{n.cls}}"></i>{{#unless n.last}}<i class="lv-link {{n.linkCls}}"></i>{{/unless}}{{/each}}
    </span>
    <span class="lv-die{{#if t.staged}} up{{/if}}">{{t.die}}</span>
    <span class="lv-stp">
      <button type="button" data-action="stage" data-kind="talentStep" data-key="{{t.id}}" data-delta="-1" {{#unless t.canMinus}}disabled{{/unless}}>&minus;</button>
      <span class="lv-cost">1</span>
      <button type="button" data-action="stage" data-kind="talentStep" data-key="{{t.id}}" data-delta="1" {{#unless t.canPlus}}disabled{{/unless}}>+</button>
    </span>
  </div>
  {{/each}}
  {{/if}}

  <div class="lv-foot">
    <span class="lv-pend">{{#if hasStaged}}<span class="lv-staged">{{stagedTotal}}</span> {{localize "PROJECTANIME.Advancement.staged"}}{{else}}{{localize "PROJECTANIME.Advancement.noStaged"}}{{/if}}</span>
    <button type="button" class="lv-confirm" data-action="confirmAdvance" {{#unless hasStaged}}disabled{{/unless}}>{{localize "PROJECTANIME.Advancement.confirm"}}</button>
  </div>

</div>
