<div class="levelup-growth">

  {{!-- Level header --}}
  <div class="levelup-growth__header">
    <span class="levelup-growth__level-label">{{localize "SHARDS.LevelUp.GainingLevel"}}</span>
    <span class="levelup-growth__level-number">Lv. {{currentLevelTarget}}</span>
    {{#if (gt state.levelsGained 0)}}
    <span class="levelup-growth__sublabel">
      ({{localize "SHARDS.LevelUp.LevelNofTotal" current=(math state.levelsGained "+" 1) total=totalLevelsThisSession}})
    </span>
    {{/if}}
  </div>

  {{#if (eq state.growthRollPhase "pending")}}
  {{!-- Roll button (shown before rolls are made) --}}
  <div class="levelup-growth__roll-prompt">
    <p class="levelup-hint">{{localize "SHARDS.LevelUp.RollPrompt"}}</p>
    <button type="button" class="levelup-growth__roll-btn" data-action="rollGrowth">
      <i class="fa-solid fa-dice-d20"></i> {{localize "SHARDS.LevelUp.Roll"}}
    </button>
  </div>
  {{/if}}

  {{#if (eq state.growthRollPhase "complete")}}
  {{!-- Roll results grid --}}
  <div class="levelup-growth__results">
    {{#each state.currentLevelRolls}}
    <div class="levelup-roll-row {{#if this.passed}}levelup-roll-row--pass{{else}}levelup-roll-row--fail{{/if}}">
      <span class="levelup-roll-row__stat">{{this.label}}</span>
      <span class="levelup-roll-row__dice">{{this.displayRoll}}</span>
      <span class="levelup-roll-row__vs">vs</span>
      <span class="levelup-roll-row__rate">{{this.growthRate}}%</span>
      <span class="levelup-roll-row__result">
        {{#if this.passed}}
        <i class="fa-solid fa-arrow-up"></i> <strong>+1</strong>
        {{else}}
        <i class="fa-solid fa-minus"></i>
        {{/if}}
      </span>
    </div>
    {{/each}}
  </div>

  {{!-- This level's summary --}}
  <div class="levelup-growth__level-summary">
    <span>{{localize "SHARDS.XP.GainsSummary"}}:
      <strong>+{{currentLevelGains}}</strong> {{localize "SHARDS.XP.StatPoints"}}
    </span>
    {{#if currentLevelRankAdvanced}}
    <div class="levelup-growth__rank-advance">
      <i class="fa-solid fa-crown"></i>
      {{localize "SHARDS.XP.RankAdvanced"}}:
      {{currentLevelOldRank}} &rarr; <strong>{{currentLevelNewRank}}</strong>
    </div>
    {{/if}}
  </div>

  {{!-- Action buttons --}}
  <div class="levelup-growth__actions">
    {{#if canLevelAgain}}
    <button type="button" class="levelup-growth__continue-btn" data-action="continueLevel">
      <i class="fa-solid fa-forward"></i>
      {{localize "SHARDS.LevelUp.ContinueLeveling"}}
      ({{state.maxAvailableLevels}} {{localize "SHARDS.LevelUp.Remaining"}})
    </button>
    {{/if}}
    <button type="button" class="levelup-growth__proceed-btn" data-action="nextStep">
      <i class="fa-solid fa-arrow-right"></i> {{localize "SHARDS.LevelUp.ProceedToSummary"}}
    </button>
  </div>
  {{/if}}

</div>
