<div class="levelup-wizard" data-theme="{{sheetTheme}}">

  {{!-- Progress Bar --}}
  <nav class="levelup-progress">
    {{#each steps}}
    <button type="button" class="levelup-progress__step{{#if this.current}} current{{/if}}{{#if this.completed}} completed{{/if}}"
      data-action="goToStep" data-step="{{this.index}}"
      {{#unless this.accessible}}disabled{{/unless}}
      title="{{this.localizedLabel}}">
      <span class="levelup-progress__icon">
        {{#if this.completed}}
        <i class="fa-solid fa-check"></i>
        {{else}}
        <i class="{{this.icon}}"></i>
        {{/if}}
      </span>
      <span class="levelup-progress__label">{{this.localizedLabel}}</span>
    </button>
    {{#unless @last}}
    <span class="levelup-progress__connector{{#if this.completed}} completed{{/if}}"></span>
    {{/unless}}
    {{/each}}
  </nav>

  {{!-- Step Header --}}
  <header class="levelup-step-header">
    <span class="levelup-step-header__number">{{localize "SHARDS.LevelUp.StepOf" step=stepNumber total=totalSteps}}</span>
    <h2 class="levelup-step-header__title">{{currentStepLabel}}</h2>
  </header>

  {{!-- Step Content (scrollable) --}}
  <div class="levelup-step-content">

    {{#if (eq currentStepId "overview")}}
      {{> "systems/shards-of-mana/templates/apps/levelup/step-overview.hbs"}}
    {{else if (eq currentStepId "growth")}}
      {{> "systems/shards-of-mana/templates/apps/levelup/step-growth.hbs"}}
    {{else if (eq currentStepId "summary")}}
      {{> "systems/shards-of-mana/templates/apps/levelup/step-summary.hbs"}}
    {{else if (eq currentStepId "finalize")}}
      {{> "systems/shards-of-mana/templates/apps/levelup/step-finalize.hbs"}}
    {{/if}}

  </div>

  {{!-- Navigation Footer --}}
  <footer class="levelup-nav">
    {{#if showBackButton}}
    <button type="button" class="levelup-nav__btn levelup-nav__btn--back" data-action="prevStep">
      <i class="fa-solid fa-arrow-left"></i> {{localize "SHARDS.LevelUp.Back"}}
    </button>
    {{/if}}
    <div class="levelup-nav__spacer"></div>
    {{#if isFinalizeStep}}
    <button type="button" class="levelup-nav__btn levelup-nav__btn--finish" data-action="finalize">
      <i class="fa-solid fa-sparkles"></i> {{localize "SHARDS.LevelUp.Apply"}}
    </button>
    {{else if isOverviewStep}}
    <button type="button" class="levelup-nav__btn levelup-nav__btn--next" data-action="beginLevelUp"
      {{#unless canBeginLevelUp}}disabled{{/unless}}>
      <i class="fa-solid fa-play"></i> {{localize "SHARDS.LevelUp.Begin"}}
    </button>
    {{else if isSummaryStep}}
    <button type="button" class="levelup-nav__btn levelup-nav__btn--next" data-action="nextStep">
      {{localize "SHARDS.LevelUp.Next"}} <i class="fa-solid fa-arrow-right"></i>
    </button>
    {{/if}}
  </footer>

</div>
