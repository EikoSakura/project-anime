<form class="shards-skill-grant-form" autocomplete="off">

  {{!-- Adventurer Selection --}}
  <div class="form-group">
    <label>
      <i class="fa-solid fa-user"></i>
      {{localize "SHARDS.Experience.SelectAdventurer"}}
    </label>
    <select name="actorId">
      {{#each actors}}
      <option value="{{this.id}}" {{#if (eq this.id ../actorId)}}selected{{/if}}>
        {{this.name}}
      </option>
      {{/each}}
    </select>
  </div>

  {{!-- Skill Selection --}}
  <div class="form-group">
    <label>
      <i class="fa-solid fa-book-sparkles"></i>
      {{localize "SHARDS.Experience.SelectSkill"}}
    </label>
    <select name="skillId">
      <option value="">— {{localize "SHARDS.Experience.SkillNamePlaceholder"}} —</option>
      {{#each skills}}
      <option value="{{#if this.uuid}}{{this.uuid}}{{else}}{{this.id}}{{/if}}"
              {{#if (eq this.name ../skillName)}}selected{{/if}}>
        {{this.name}} ({{this.source}})
      </option>
      {{/each}}
    </select>
  </div>

  {{!-- Free-text Skill Name --}}
  <div class="form-group">
    <label>
      <i class="fa-solid fa-pen"></i>
      {{localize "SHARDS.Experience.SkillNamePlaceholder"}}
    </label>
    <input type="text" name="skillName" value="{{skillName}}"
           placeholder="{{localize 'SHARDS.Experience.SkillNamePlaceholder'}}" />
  </div>

  {{!-- Origin Note --}}
  <div class="form-group">
    <label>
      <i class="fa-solid fa-scroll"></i>
      {{localize "SHARDS.Experience.OriginLabel"}}
    </label>
    <input type="text" name="originNote" value="{{originNote}}"
           placeholder="{{localize 'SHARDS.Experience.OriginPlaceholder'}}" />
  </div>

  {{!-- Grant Button --}}
  <button type="button" class="crystal-btn" data-action="grantSkill">
    <i class="fa-solid fa-hand-sparkles"></i>
    {{localize "SHARDS.Experience.Grant"}}
  </button>

</form>
