{{!-- Structures window — master-detail manager for HQ buildings. Left rail lists facilities under
      "Structures" (tier 0, buildable) over "Built" (tier ≥ 1, active); the right pane shows the
      selected facility's authoring book (GM) or a read-only summary + Build (players). The root
      carries .pa-hq so the Codex's facility/book styling applies verbatim. --}}
<div class="struct-window" style="--acc:{{accent}}">

  {{#if hasResources}}
  <div class="struct-res">
    {{#each resources}}
    <span class="struct-res-chip" title="{{label}}">{{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}} {{amount}}</span>
    {{/each}}
  </div>
  {{/if}}

  <div class="struct-layout">

    {{!-- ===================== RAIL — the two grouped lists ===================== --}}
    <div class="struct-rail">
      {{#if isGM}}<button type="button" class="struct-new" data-action="newStructure"><i class="fas fa-plus"></i> {{localize "PROJECTANIME.HQ.newStructure"}}</button>{{/if}}

      <div class="struct-group-h"><i class="fas fa-helmet-safety"></i> {{localize "PROJECTANIME.HQ.structures"}}{{#if hasStructures}} <span class="nb">{{structures.length}}</span>{{/if}}</div>
      {{#each structures}}
      <button type="button" class="struct-row{{#if sel}} sel{{/if}}{{#if building}} building{{/if}}" data-action="selectStructure" data-recruit-id="{{id}}">
        <span class="struct-row-ic"><i class="fas {{facilityIcon}}"></i></span>
        <span class="struct-row-main">
          <span class="struct-row-nm">{{#if name}}{{name}}{{else}}{{localize "PROJECTANIME.HQ.newStructure"}}{{/if}}</span>
          <span class="struct-row-sub">{{#if building}}<i class="fas fa-hammer fa-fade"></i> {{buildStatus}}{{else}}{{roleLabel}}{{/if}}</span>
        </span>
        {{#unless unlocked}}{{#if @root.isGM}}<i class="fas fa-lock struct-row-lock" title="{{localize 'PROJECTANIME.HQ.unlockedHint'}}"></i>{{/if}}{{/unless}}
      </button>
      {{else}}{{#unless @root.isGM}}<div class="struct-rail-empty">{{localize "PROJECTANIME.HQ.noStructures"}}</div>{{/unless}}{{/each}}

      {{#if hasBuilt}}
      <div class="struct-group-h"><i class="fas fa-chess-rook"></i> {{localize "PROJECTANIME.HQ.built"}} <span class="nb">{{built.length}}</span></div>
      {{#each built}}
      <button type="button" class="struct-row built{{#if sel}} sel{{/if}}" data-action="selectStructure" data-recruit-id="{{id}}">
        <span class="struct-row-ic"><i class="fas {{facilityIcon}}"></i></span>
        <span class="struct-row-main">
          <span class="struct-row-nm">{{#if name}}{{name}}{{else}}{{localize "PROJECTANIME.HQ.newFacility"}}{{/if}}</span>
          <span class="struct-row-sub hq-stars">{{#each tierPips}}<i class="{{#if on}}on{{/if}}">★</i>{{/each}}</span>
        </span>
      </button>
      {{/each}}
      {{/if}}
    </div>

    {{!-- ===================== DETAIL — the selected facility's book ===================== --}}
    <div class="struct-detail-wrap">
      {{#if hasAny}}
      {{#each all}}
      <div class="struct-detail{{#if sel}} active{{/if}}" data-detail="{{id}}">

        <div class="struct-d-head">
          <span class="hq-ric lg"><i class="fas {{facilityIcon}}"></i></span>
          {{#if @root.isGM}}
          <input class="struct-name" data-recruit-id="{{id}}" data-recruit-field="name" value="{{name}}" placeholder="{{#if isBuilt}}{{localize 'PROJECTANIME.HQ.newFacility'}}{{else}}{{localize 'PROJECTANIME.HQ.newStructure'}}{{/if}}">
          {{else}}
          <div class="struct-name ro">{{#if name}}{{name}}{{else}}{{#if isBuilt}}{{localize "PROJECTANIME.HQ.newFacility"}}{{else}}{{localize "PROJECTANIME.HQ.newStructure"}}{{/if}}{{/if}}</div>
          {{/if}}
          <span class="struct-d-tier hq-stars">{{#each tierPips}}<i class="{{#if on}}on{{/if}}">★</i>{{/each}}</span>
        </div>

        {{#if @root.isGM}}
        {{!-- ----- GM authoring ----- --}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.facility"}}</span>
        <div class="m-brief">
          <div class="m-bfield">
            <span class="m-cap">{{localize "PROJECTANIME.HQ.roleField"}}</span>
            <select class="m-rolesel" data-recruit-id="{{id}}" data-recruit-field="role">{{#each roleOptions}}<option value="{{key}}" {{#if sel}}selected{{/if}}>{{label}}</option>{{/each}}</select>
          </div>
          <div class="m-bfield">
            <span class="m-cap">{{localize "PROJECTANIME.HQ.tier"}}</span>
            <div class="m-pips">{{#each tierPips}}<i class="m-pip{{#if on}} on{{/if}}" data-action="setFacilityTier" data-recruit-id="{{../id}}" data-ftier="{{n}}">✦</i>{{/each}}</div>
          </div>
        </div>

        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.buildCost"}}</span>
        <div class="hq-scost-edit">
          {{#each costEdit}}
          <span class="hq-scost-in" title="{{label}}">{{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}}<input type="number" min="0" data-recruit-id="{{../id}}" data-facility-cost="{{key}}" value="{{amount}}"></span>
          {{/each}}
        </div>
        <div class="hq-bopts">
          <label class="hq-bopt" title="{{localize 'PROJECTANIME.HQ.buildTimeHint'}}"><i class="fas fa-hourglass-half"></i> <input type="number" min="0" data-recruit-id="{{id}}" data-recruit-field="buildTime" value="{{buildTime}}"> {{localize "PROJECTANIME.HQ.buildTime"}}</label>
          <label class="hq-bopt cb" title="{{localize 'PROJECTANIME.HQ.unlockedHint'}}"><input type="checkbox" data-recruit-id="{{id}}" data-recruit-field="unlocked" {{#if unlocked}}checked{{/if}}> <i class="fas fa-lock-open"></i> {{localize "PROJECTANIME.HQ.unlocked"}}</label>
        </div>
        <div class="hq-sfoot">
          {{#if building}}
          <span class="hq-sbuilding"><i class="fas fa-hammer fa-fade"></i> {{buildStatus}}</span>
          {{else}}{{#unless maxed}}
          <div class="hq-snext">
            <span class="hq-snext-lbl">{{buildLabel}}:</span>
            {{#if hasNextCost}}{{#each nextCost}}<span class="hq-scost{{#unless enough}} short{{/unless}}" title="{{label}}">{{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}} {{amount}}</span>{{/each}}{{else}}<span class="hq-sfree">{{localize "PROJECTANIME.HQ.free"}}</span>{{/if}}
          </div>
          <button type="button" class="hq-sbuild" data-action="buildFacility" data-recruit-id="{{id}}"{{#unless canBuild}} disabled{{/unless}}><i class="fas fa-hammer"></i> {{buildLabel}}</button>
          {{else}}
          <span class="hq-sbuilt"><i class="fas fa-circle-check"></i> {{localize "PROJECTANIME.HQ.tierMax"}}</span>
          {{/unless}}{{/if}}
        </div>

        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.output"}}</span>
        <div class="m-fields">
          <label class="m-num"><span class="m-num-ic"><i class="fas fa-coins"></i></span><span class="m-num-cap">{{localize "PROJECTANIME.Bond.gold"}}</span><input type="number" min="0" data-recruit-id="{{id}}" data-recruit-field="yieldGold" value="{{yieldGold}}"></label>
          <label class="m-num"><span class="m-num-ic"><i class="fas fa-star"></i></span><span class="m-num-cap">{{localize "PROJECTANIME.Bond.sp"}}</span><input type="number" min="0" data-recruit-id="{{id}}" data-recruit-field="yieldSP" value="{{yieldSP}}"></label>
        </div>
        <div class="m-rew-items drop" data-yield-drop="{{id}}">
          {{#each yieldItems}}
          <div class="rew-item" title="{{name}}"><img src="{{img}}" alt=""><span>{{name}}</span><a class="rew-x" data-action="removeYieldItem" data-recruit-id="{{../id}}" data-yield-item="{{idx}}">✕</a></div>
          {{else}}
          <span class="frew-drop-hint">{{localize "PROJECTANIME.HQ.yieldDropHint"}}</span>
          {{/each}}
        </div>

        {{#if hasResTypes}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.accepts"}}</span>
        <div class="struct-accepts">
          {{#each acceptsEdit}}
          <button type="button" class="struct-acc{{#if on}} on{{/if}}" data-action="toggleAccept" data-recruit-id="{{../id}}" data-accept="{{key}}" title="{{label}}">
            {{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}} <span>{{label}}</span>
          </button>
          {{/each}}
        </div>
        {{/if}}

        {{#if staffCap}}
        {{!-- .struct-staff-sec (display:contents — no box) is the stable anchor StructuresWindow re-renders
              in place on a staff assign/unassign; its inner markup is the shared partial below. --}}
        <div class="struct-staff-sec" data-staff-sec="{{id}}">{{> "systems/project-anime/templates/apps/structures-staff.hbs"}}</div>
        {{/if}}

        {{#if isService}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.serviceField"}}</span>
        <div class="m-objective">
          <i class="fas fa-hand-holding-medical m-obj-ic"></i>
          <select class="m-statsel" data-recruit-id="{{id}}" data-recruit-field="serviceKind">{{#each serviceKindOptions}}<option value="{{key}}" {{#if sel}}selected{{/if}}>{{label}}</option>{{/each}}</select>
        </div>
        {{/if}}
        {{#if isVendor}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.storefront"}}</span>
        <button type="button" class="hq-shop-btn" data-action="visitShop" data-recruit-id="{{id}}"><i class="fa-solid fa-store"></i> {{localize "PROJECTANIME.Shop.visit"}}</button>
        {{/if}}
        {{#if isWorkshop}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.Workshop.title"}}</span>
        <button type="button" class="hq-shop-btn" data-action="visitWorkshop" data-recruit-id="{{id}}"><i class="fa-solid fa-screwdriver-wrench"></i> {{localize "PROJECTANIME.Workshop.visit"}}</button>
        {{/if}}

        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.boons"}}</span>
        {{#if hasBoon}}<div class="hq-bk-entry">{{boonSummary}}</div>{{/if}}
        <button type="button" class="m-boon-add" data-action="editBoon" data-recruit-id="{{id}}"><i class="fas fa-wand-magic-sparkles"></i> {{localize "PROJECTANIME.HQ.editBoon"}}</button>

        {{#if isUpgrade}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.upgrade"}}</span>
        <div class="m-objective">
          <i class="fas fa-arrow-up-right-dots m-obj-ic"></i>
          <select class="m-statsel" data-recruit-id="{{id}}" data-recruit-field="upgradeTarget"><option value="">{{localize "PROJECTANIME.HQ.upgradeNone"}}</option>{{#each targetOptions}}<option value="{{id}}" {{#if sel}}selected{{/if}}>{{name}}</option>{{/each}}</select>
        </div>
        {{/if}}

        <div class="hq-drawer-foot">
          <button type="button" class="rec-btn ghost" data-action="pickStructureImage" data-recruit-id="{{id}}"><i class="fas fa-camera"></i> {{localize "PROJECTANIME.HQ.missionImagePick"}}</button>
          {{#if npcUuid}}<button type="button" class="rec-btn ghost" data-action="openStructureActor" data-recruit-id="{{id}}"><i class="fas fa-up-right-from-square"></i> {{localize "PROJECTANIME.Covenant.openSheet"}}</button>{{/if}}
          <a class="hq-drawer-del" data-action="removeStructure" data-recruit-id="{{id}}" title="{{localize 'PROJECTANIME.Covenant.delete'}}"><i class="fas fa-trash"></i> {{localize "PROJECTANIME.Covenant.delete"}}</a>
        </div>

        {{else}}
        {{!-- ----- player read-only + build ----- --}}
        {{#if isVendor}}<button type="button" class="hq-shop-btn" data-action="visitShop" data-recruit-id="{{id}}"><i class="fa-solid fa-store"></i> {{localize "PROJECTANIME.Shop.visit"}}</button>{{/if}}
        {{#if isWorkshop}}<button type="button" class="hq-shop-btn" data-action="visitWorkshop" data-recruit-id="{{id}}"><i class="fa-solid fa-screwdriver-wrench"></i> {{localize "PROJECTANIME.Workshop.visit"}}</button>{{/if}}
        <span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.facility"}}</span>
        <div class="hq-bk-entry">{{roleLabel}}</div>
        {{#if building}}
        <div class="hq-bk-entry hq-bk-building"><i class="fas fa-hammer fa-fade"></i> {{buildStatus}}</div>
        {{else}}{{#if unlocked}}{{#unless maxed}}
        <div class="hq-sfoot">
          <div class="hq-snext">
            <span class="hq-snext-lbl">{{buildLabel}}:</span>
            {{#if hasNextCost}}{{#each nextCost}}<span class="hq-scost{{#unless enough}} short{{/unless}}" title="{{label}}">{{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}} {{amount}}</span>{{/each}}{{else}}<span class="hq-sfree">{{localize "PROJECTANIME.HQ.free"}}</span>{{/if}}
          </div>
          <button type="button" class="hq-sbuild" data-action="buildFacility" data-recruit-id="{{id}}"{{#unless playerCanBuild}} disabled{{/unless}}><i class="fas fa-hammer"></i> {{buildLabel}}</button>
        </div>
        {{/unless}}{{/if}}{{/if}}
        {{#if staffName}}<div class="hq-bk-entry"><i class="fas fa-user-gear"></i> {{localize "PROJECTANIME.HQ.staffedBy"}} {{staffName}}</div>{{/if}}
        {{#if produces}}<div class="hq-bk-entry"><b>{{localize "PROJECTANIME.HQ.produces"}}</b> · {{producesSummary}}</div>{{/if}}
        {{#if hasBoon}}<div class="hq-bk-entry">{{boonSummary}}</div>{{/if}}
        {{#if upgradeTargetName}}<div class="hq-bk-entry">{{localize "PROJECTANIME.HQ.upgradesLabel"}} {{upgradeTargetName}}</div>{{/if}}
        {{/if}}

      </div>
      {{/each}}
      {{else}}
      <div class="hq-empty"><i class="fas fa-helmet-safety"></i><p>{{#if isGM}}{{localize "PROJECTANIME.HQ.newStructure"}}{{else}}{{localize "PROJECTANIME.HQ.noStructures"}}{{/if}}</p></div>
      {{/if}}
    </div>

  </div>
</div>
