{{!-- Step-by-step Character Creator: Concept → Attributes → Combat Stats → Skills → Gear → Finish. --}}
<div class="cc-body">

  <ol class="cc-steps">
    {{#each steps as |st|}}
    <li class="cc-step-dot{{#if st.active}} active{{/if}}{{#if st.done}} done{{/if}}"
        data-action="gotoStep" data-step="{{st.index}}" title="{{st.label}}">
      <span class="cc-dot-num">{{st.num}}</span>
      <span class="cc-dot-label">{{st.label}}</span>
    </li>
    {{/each}}
  </ol>

  <div class="cc-step-head">
    <span class="cc-step-counter">{{stepLabel}}</span>
    <span class="cc-step-title">{{stepTitle}}</span>
  </div>

  {{!-- ===================== 1 · CONCEPT ===================== --}}
  {{#if onConcept}}
  <section class="cc-step-body cc-concept">
    <div class="cc-id-row">
      <div class="cc-img" data-action="pickImage" title="{{localize 'PROJECTANIME.Creator.pickImage'}}">
        <img src="{{img}}" alt="" />
        <i class="cc-img-edit fas fa-camera"></i>
      </div>
      <label class="cc-field">
        <span class="cc-label">{{localize "Name"}}</span>
        <input type="text" name="name" value="{{name}}" />
      </label>
    </div>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.Creator.conceptField"}}</span>
      <textarea name="system.biography" rows="6">{{biography}}</textarea>
    </label>
  </section>
  {{/if}}

  {{!-- ===================== CHOOSE (Race/Class) ===================== --}}
  {{#if onChoose}}
  <section class="cc-step-body cc-choose">
    {{#each choices as |ch|}}
    <div class="cc-choice-block" data-choice-id="{{ch.id}}">
      <div class="cc-choose-head">
        <span class="cc-choose-label">{{ch.label}}</span>
        {{#if ch.pickN}}<span class="cc-choose-sub muted">{{localize "PROJECTANIME.Creator.choosePick"}} {{ch.chosenCount}}/{{ch.n}}</span>{{/if}}
      </div>
      <div class="cc-choose-grid">
        {{#each ch.options as |o|}}
        <button type="button" class="cc-choose-opt{{#if o.selected}} selected{{/if}}" data-action="chooseOption" data-option-uuid="{{o.uuid}}">
          <img src="{{o.img}}" alt="" />
          <span class="cc-choose-opt-name">{{o.label}}</span>
          {{#if o.selected}}<i class="cc-choose-check fas fa-circle-check"></i>{{/if}}
        </button>
        {{else}}
        <p class="cc-empty muted">{{localize "PROJECTANIME.Empty"}}</p>
        {{/each}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{!-- ===================== 2 · ATTRIBUTES ===================== --}}
  {{#if onAttributes}}
  <section class="cc-step-body cc-attributes">
    <div class="cc-budget-pill{{#if overSpent}} over{{/if}}">
      <span class="cc-label">{{localize "PROJECTANIME.Creator.stepsLeft"}}</span>
      <span class="cc-budget-num">{{stepsLeft}}</span>
      <span class="cc-budget-sub muted">/ {{stepsTotal}}</span>
    </div>
    <div class="cc-attr-grid">
      {{#each attributes as |a|}}
      <div class="cc-attr-card" data-attribute="{{a.key}}">
        <div class="cc-attr-head">
          {{#if a.icon}}<i class="{{a.icon}}"></i>{{/if}}
          <span class="cc-attr-name">{{a.label}}</span>
        </div>
        <div class="cc-attr-die">{{a.die}}</div>
        <div class="cc-attr-ctrl">
          <button type="button" class="cc-step-btn" data-action="lowerAttr" {{#unless a.canLower}}disabled{{/unless}}>
            <i class="fas fa-minus"></i>
          </button>
          <button type="button" class="cc-step-btn" data-action="raiseAttr" {{#unless a.canRaise}}disabled{{/unless}}>
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ===================== 3 · COMBAT STATS ===================== --}}
  {{#if onStats}}
  <section class="cc-step-body cc-stats">
    <div class="cc-vitals-grid">
      <div class="cc-vital hp">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.hp"}}</span>
        <span class="cc-v-val">{{vitals.hp}}</span>
        <span class="cc-v-sub muted">{{localize "PROJECTANIME.Attribute.might.long"}} ×2</span>
      </div>
      <div class="cc-vital energy">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.energy"}}</span>
        <span class="cc-v-val">{{vitals.energy}}</span>
        <span class="cc-v-sub muted">{{localize "PROJECTANIME.Attribute.spirit.long"}} ×2</span>
      </div>
      <div class="cc-vital">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.evasion"}}</span>
        <span class="cc-v-val">{{vitals.evasion}}</span>
      </div>
      <div class="cc-vital">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.movement"}}</span>
        <span class="cc-v-val">{{vitals.movement}}</span>
      </div>
      <div class="cc-vital">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.carryingCapacity"}}</span>
        <span class="cc-v-val">{{vitals.carry}}</span>
      </div>
    </div>
    {{#if vitalsStale}}
    <button type="button" class="cc-mini-btn" data-action="recalcVitals">
      <i class="fas fa-rotate"></i> {{localize "PROJECTANIME.Creator.recalc"}}
    </button>
    {{/if}}

    <div class="cc-luck">
      <div class="cc-luck-head">
        <span class="cc-label">{{localize "PROJECTANIME.Stat.luckDice"}}</span>
        <button type="button" class="cc-mini-btn" data-action="rollLuck">
          <i class="fas fa-dice"></i> {{localize "PROJECTANIME.Creator.rollLuck"}} (3{{charmDie}})
        </button>
      </div>
      <div class="cc-luck-dice">
        {{#each luckDice as |d|}}<span class="cc-luck-die">{{d}}</span>{{else}}<em class="muted">—</em>{{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- ===================== 4 · SKILLS ===================== --}}
  {{#if onSkills}}
  <section class="cc-step-body cc-skills">
    <div class="cc-sp">
      <i class="fas fa-star"></i>
      <span class="cc-label">{{localize "PROJECTANIME.Stat.skillPoints"}}</span>
      <strong class="cc-sp-val">{{sp}}</strong>
    </div>
    <button type="button" class="cc-primary" data-action="openSkillBuilder">
      <i class="fas fa-wand-sparkles"></i> {{localize "PROJECTANIME.Creator.openSkillBuilder"}}
    </button>
    {{#if skills.length}}
    <ul class="cc-skill-list">
      {{#each skills as |s|}}
      <li class="cc-skill-row" data-skill-id="{{s.id}}">
        <img src="{{s.img}}" alt="" />
        <div class="cc-skill-info">
          <span class="cc-skill-name">{{s.name}}</span>
          <span class="cc-skill-sub muted">{{s.stars}} · {{s.actionLabel}}{{#unless s.passive}} · <i class="fas fa-bolt"></i>{{s.energyCost}}{{/unless}} · <i class="fas fa-star"></i>{{s.spCost}}</span>
        </div>
        <button type="button" class="cc-icon-btn" data-action="editSkill" title="{{localize 'PROJECTANIME.Action.edit'}}">
          <i class="fas fa-pen-to-square"></i>
        </button>
        <button type="button" class="cc-icon-btn danger" data-action="removeSkill" title="{{localize 'PROJECTANIME.Creator.removeSkill'}}">
          <i class="fas fa-trash"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.Creator.noSkills"}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 5 · GEAR ===================== --}}
  {{#if onGear}}
  <section class="cc-step-body cc-gear">
    <div class="cc-budget-bar">
      <span class="cc-label">{{localize "PROJECTANIME.Creator.budget"}}</span>
      <span class="cc-budget-num"><i class="fas fa-coins"></i> {{gold}}</span>
      <span class="cc-budget-sub muted">/ {{budget}}G</span>
      <button type="button" class="cc-icon-btn cc-refresh" data-action="refreshShop" title="{{localize 'PROJECTANIME.Creator.refresh'}}">
        <i class="fas fa-rotate"></i>
      </button>
    </div>

    <div class="cc-chips">
      {{#each shopFilters as |f|}}
      <button type="button" class="cc-chip{{#if f.active}} active{{/if}}" data-action="shopFilter" data-type="{{f.key}}">{{f.label}}</button>
      {{/each}}
    </div>

    {{#if shop.length}}
    <div class="cc-shop-grid">
      {{#each shop as |it|}}
      <div class="cc-shop-item{{#unless it.affordable}} unaffordable{{/unless}}" data-uuid="{{it.uuid}}">
        <img src="{{it.img}}" alt="" />
        <div class="cc-shop-info">
          <span class="cc-shop-name">{{it.name}}</span>
          <span class="cc-shop-sub muted">{{it.typeLabel}}</span>
        </div>
        <button type="button" class="cc-buy" data-action="buyItem" {{#unless it.affordable}}disabled{{/unless}}>
          <i class="fas fa-coins"></i> {{it.cost}}
        </button>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.Creator.shopEmpty"}}</p>
    {{/if}}

    {{#if owned.length}}
    <h3 class="cc-subhead">{{localize "PROJECTANIME.Creator.owned"}}</h3>
    <ul class="cc-owned-list">
      {{#each owned as |it|}}
      <li class="cc-owned-row" data-item-id="{{it.id}}">
        <img src="{{it.img}}" alt="" />
        <span class="cc-owned-name">{{it.name}}</span>
        <span class="cc-owned-cost muted"><i class="fas fa-coins"></i> {{it.cost}}</span>
        <button type="button" class="cc-icon-btn" data-action="sellItem" title="{{localize 'PROJECTANIME.Creator.sell'}}">
          <i class="fas fa-rotate-left"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 6 · FINISH ===================== --}}
  {{#if onFinish}}
  <section class="cc-step-body cc-finish">
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.Field.pronouns"}}</span>
      <input type="text" name="system.pronouns" value="{{pronouns}}" />
    </label>
    <div class="cc-detail-grid">
      {{#each bioFields as |f|}}
      <label class="cc-field{{#if f.long}} span-2{{/if}}">
        <span class="cc-label">{{#if f.iconImg}}<img class="cc-field-icon" src="{{f.icon}}" alt="" />{{else if f.icon}}<i class="{{f.icon}}"></i> {{/if}}{{f.label}}</span>
        {{#if f.long}}
        <textarea name="system.details.{{f.key}}" rows="2">{{f.value}}</textarea>
        {{else}}
        <input type="text" name="system.details.{{f.key}}" value="{{f.value}}" />
        {{/if}}
      </label>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ===================== NAV ===================== --}}
  <div class="cc-nav">
    <div class="cc-nav-left">
      {{#unless isFirst}}
      <button type="button" class="cc-back" data-action="stepBack">
        <i class="fas fa-chevron-left"></i> {{localize "PROJECTANIME.SkillBuilder.back"}}
      </button>
      {{/unless}}
    </div>
    <div class="cc-nav-right">
      {{#if isLast}}
      <button type="button" class="cc-finish-btn" data-action="finish">
        <i class="fas fa-check"></i> {{localize "PROJECTANIME.Creator.finish"}}
      </button>
      {{else}}
      <button type="button" class="cc-next" data-action="stepNext">
        {{localize "PROJECTANIME.SkillBuilder.next"}} <i class="fas fa-chevron-right"></i>
      </button>
      {{/if}}
    </div>
  </div>

</div>
