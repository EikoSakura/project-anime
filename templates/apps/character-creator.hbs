{{!-- Step-by-step Character Creator (V2): Attributes → Talents → Weapon → Armor →
      Techniques → Stats → Luck → Name Everything (the optional Choose step leads). --}}
<div class="cc-body">

  <ol class="cc-steps">
    {{#each steps as |st|}}
    <li class="cc-step-dot{{#if st.active}} active{{/if}}{{#if st.done}} done{{/if}}"
        data-action="gotoStep" data-step="{{st.index}}" title="{{st.label}}">
      <span class="cc-dot-num">{{st.num}}</span>
      <span class="cc-dot-label">{{st.label}}</span>
    </li>
    {{/each}}
  </ol>

  <div class="cc-step-head">
    <span class="cc-step-counter">{{stepLabel}}</span>
    <span class="cc-step-title">{{stepTitle}}</span>
  </div>

  {{!-- ===================== CHOOSE (Race/Class) ===================== --}}
  {{#if onChoose}}
  <section class="cc-step-body cc-choose">
    {{#each choices as |ch|}}
    <div class="cc-choice-block" data-choice-id="{{ch.id}}">
      <div class="cc-choose-head">
        <span class="cc-choose-label">{{ch.label}}</span>
        {{#if ch.pickN}}<span class="cc-choose-sub muted">{{localize "PROJECTANIME.Creator.choosePick"}} {{ch.chosenCount}}/{{ch.n}}</span>{{/if}}
      </div>
      <div class="cc-choose-grid">
        {{#each ch.options as |o|}}
        <button type="button" class="cc-choose-opt{{#if o.selected}} selected{{/if}}" data-action="chooseOption" data-option-uuid="{{o.uuid}}">
          <img src="{{o.img}}" alt="" />
          <span class="cc-choose-opt-name">{{o.label}}</span>
          {{#if o.selected}}<i class="cc-choose-check fas fa-circle-check"></i>{{/if}}
        </button>
        {{else}}
        <p class="cc-empty muted">{{localize "PROJECTANIME.Empty"}}</p>
        {{/each}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{!-- ===================== 1 · SET ATTRIBUTES ===================== --}}
  {{#if onAttributes}}
  <section class="cc-step-body cc-attributes">
    <div class="cc-budget-pill{{#if overSpent}} over{{/if}}">
      <span class="cc-label">{{localize "PROJECTANIME.Creator.stepsLeft"}}</span>
      <span class="cc-budget-num">{{stepsLeft}}</span>
      <span class="cc-budget-sub muted">/ {{stepsTotal}}</span>
    </div>
    <div class="cc-attr-grid">
      {{#each attributes as |a|}}
      <div class="cc-attr-card" data-attribute="{{a.key}}">
        <div class="cc-attr-head">
          {{#if a.icon}}<i class="{{a.icon}}"></i>{{/if}}
          <span class="cc-attr-name">{{a.label}}</span>
        </div>
        <div class="cc-attr-die">{{a.die}}</div>
        <div class="cc-attr-ctrl">
          <button type="button" class="cc-step-btn" data-action="lowerAttr" {{#unless a.canLower}}disabled{{/unless}}>
            <i class="fas fa-minus"></i>
          </button>
          <button type="button" class="cc-step-btn" data-action="raiseAttr" {{#unless a.canRaise}}disabled{{/unless}}>
            <i class="fas fa-plus"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ===================== 2 · DEFINE TALENTS ===================== --}}
  {{#if onTalents}}
  <section class="cc-step-body cc-talents">
    {{#each talentSlots as |t|}}
    <div class="cc-id-row">
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.Talent.name"}}</span>
        <input type="text" name="talentName.{{t.index}}" value="{{t.name}}" />
      </label>
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.Talent.primaryAttribute"}}</span>
        <select name="talentAttr.{{t.index}}">{{selectOptions @root.attrChoices selected=t.attr}}</select>
      </label>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{!-- ===================== 3 · CHOOSE WEAPON STYLE ===================== --}}
  {{#if onWeapon}}
  <section class="cc-step-body cc-weapon">
    <div class="cc-choose-grid">
      {{#each weaponStyles as |w|}}
      <button type="button" class="cc-choose-opt cc-style-opt{{#if w.selected}} selected{{/if}}" data-action="pickWeaponStyle" data-style="{{w.key}}" data-tooltip="{{w.tooltip}}" data-tooltip-class="pa-tooltip">
        <img class="cc-style-icon" src="{{w.icon}}" alt="{{w.label}}" />
        <span class="cc-choose-opt-name">{{w.label}}</span>
        {{#if w.selected}}<i class="cc-choose-check fas fa-circle-check"></i>{{/if}}
      </button>
      {{/each}}
    </div>
    <div class="cc-id-row">
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.Creator.weaponName"}}</span>
        <input type="text" name="weaponName" value="{{weapon.name}}" />
      </label>
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.Creator.pairedAttribute"}}</span>
        <select name="weaponAttrA">{{selectOptions @root.attrChoices selected=weapon.attrA}}</select>
      </label>
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.Creator.pairedWith"}}</span>
        <select name="weaponPair">
          <option value=""></option>
          {{selectOptions pairChoices selected=weaponPair}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}

  {{!-- ===================== 4 · CHOOSE ARMOR STYLE ===================== --}}
  {{#if onArmor}}
  <section class="cc-step-body cc-armor">
    <div class="cc-choose-grid">
      {{#each armorStyles as |a|}}
      <button type="button" class="cc-choose-opt cc-style-opt{{#if a.selected}} selected{{/if}}" data-action="pickArmorStyle" data-style="{{a.key}}" data-tooltip="{{a.tooltip}}" data-tooltip-class="pa-tooltip">
        <img class="cc-style-icon" src="{{a.icon}}" alt="{{a.label}}" />
        <span class="cc-choose-opt-name">{{a.label}}</span>
        {{#if a.selected}}<i class="cc-choose-check fas fa-circle-check"></i>{{/if}}
      </button>
      {{/each}}
    </div>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.Creator.armorName"}}</span>
      <input type="text" name="armorName" value="{{armor.name}}" />
    </label>
  </section>
  {{/if}}

  {{!-- ===================== 5 · BUILD TECHNIQUES ===================== --}}
  {{#if onTechniques}}
  <section class="cc-step-body cc-skills">
    <div class="cc-sp">
      <i class="fas fa-wand-sparkles"></i>
      <span class="cc-label">{{localize "PROJECTANIME.Creator.step.techniques"}}</span>
      <strong class="cc-sp-val">{{skills.length}} / {{techniqueMax}}</strong>
    </div>
    {{#if canBuild}}
    <button type="button" class="cc-primary" data-action="openSkillBuilder">
      <i class="fas fa-wand-sparkles"></i> {{localize "PROJECTANIME.Creator.openTechniqueBuilder"}}
    </button>
    {{/if}}
    {{#if skills.length}}
    <ul class="cc-skill-list">
      {{#each skills as |s|}}
      <li class="cc-skill-row" data-skill-id="{{s.id}}">
        <img src="{{s.img}}" alt="" />
        <div class="cc-skill-info">
          <span class="cc-skill-name">{{s.name}}</span>
          <span class="cc-skill-sub muted">{{s.actionLabel}}{{#unless s.passive}} · <i class="fas fa-bolt"></i>{{s.energyCost}}{{/unless}}</span>
        </div>
        <button type="button" class="cc-icon-btn" data-action="editSkill" title="{{localize 'PROJECTANIME.Action.edit'}}">
          <i class="fas fa-pen-to-square"></i>
        </button>
        <button type="button" class="cc-icon-btn danger" data-action="removeSkill" title="{{localize 'PROJECTANIME.Action.delete'}}">
          <i class="fas fa-trash"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.Empty"}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 6 · SET STATS ===================== --}}
  {{#if onStats}}
  <section class="cc-step-body cc-stats">
    <div class="cc-vitals-grid">
      <div class="cc-vital hp">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.hitBoxes"}}</span>
        <span class="cc-v-val">{{stats.hp}}</span>
      </div>
      <div class="cc-vital energy">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.energyBoxes"}}</span>
        <span class="cc-v-val">{{stats.energy}}</span>
      </div>
      <div class="cc-vital">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.guard"}}</span>
        <span class="cc-v-val">{{stats.guard}}</span>
      </div>
      <div class="cc-vital">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.movement"}}</span>
        <span class="cc-v-val">{{stats.movement}}</span>
      </div>
      <div class="cc-vital">
        <span class="cc-v-label">{{localize "PROJECTANIME.Stat.energyRegen"}}</span>
        <span class="cc-v-val">{{stats.regen}}</span>
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- ===================== 7 · ROLL LUCK DICE ===================== --}}
  {{#if onLuck}}
  <section class="cc-step-body cc-luckstep">
    <div class="cc-luck">
      <div class="cc-luck-head">
        <span class="cc-label">{{localize "PROJECTANIME.Stat.luckDice"}}</span>
        {{#if luckRolled}}
        <span class="cc-luck-lock"><i class="fas fa-lock"></i> {{localize "PROJECTANIME.Creator.luckLocked"}}</span>
        {{else}}
        <button type="button" class="cc-mini-btn" data-action="rollLuck">
          <i class="fas fa-dice"></i> {{localize "PROJECTANIME.Creator.rollLuck"}} ({{luckFormula}})
        </button>
        {{/if}}
      </div>
      <div class="cc-luck-dice {{#if luckRolled}}locked{{/if}}">
        {{#each luckDice as |d|}}<span class="cc-luck-die">{{d}}</span>{{else}}<em class="muted">—</em>{{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  {{!-- ===================== 8 · NAME EVERYTHING ===================== --}}
  {{#if onFinish}}
  <section class="cc-step-body cc-finish">
    <div class="cc-id-row">
      <div class="cc-img" data-action="pickImage" title="{{localize 'PROJECTANIME.Creator.pickImage'}}">
        <img src="{{img}}" alt="" />
        <i class="cc-img-edit fas fa-camera"></i>
      </div>
      <label class="cc-field">
        <span class="cc-label">{{localize "Name"}}</span>
        <input type="text" name="name" value="{{name}}" />
      </label>
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.Field.pronouns"}}</span>
        <input type="text" name="system.pronouns" value="{{pronouns}}" />
      </label>
    </div>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.Creator.conceptField"}}</span>
      <textarea name="system.biography" rows="4">{{biography}}</textarea>
    </label>
    <div class="cc-detail-grid">
      {{#each bioFields as |f|}}
      <label class="cc-field{{#if f.long}} span-2{{/if}}">
        <span class="cc-label">{{#if f.iconImg}}<img class="cc-field-icon" src="{{f.icon}}" alt="" />{{else if f.icon}}<i class="{{f.icon}}"></i> {{/if}}{{f.label}}</span>
        {{#if f.long}}
        <textarea name="system.details.{{f.key}}" rows="2">{{f.value}}</textarea>
        {{else}}
        <input type="text" name="system.details.{{f.key}}" value="{{f.value}}" />
        {{/if}}
      </label>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ===================== NAV ===================== --}}
  <div class="cc-nav">
    <div class="cc-nav-left">
      {{#unless isFirst}}
      <button type="button" class="cc-back" data-action="stepBack">
        <i class="fas fa-chevron-left"></i> {{localize "PROJECTANIME.SkillBuilder.back"}}
      </button>
      {{/unless}}
    </div>
    <div class="cc-nav-right">
      {{#if isLast}}
      <button type="button" class="cc-finish-btn" data-action="finish">
        <i class="fas fa-check"></i> {{localize "PROJECTANIME.Creator.finish"}}
      </button>
      {{else}}
      <button type="button" class="cc-next" data-action="stepNext">
        {{localize "PROJECTANIME.SkillBuilder.next"}} <i class="fas fa-chevron-right"></i>
      </button>
      {{/if}}
    </div>
  </div>

</div>
