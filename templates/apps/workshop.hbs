{{!-- Workshop — opened from a workshop-role HQ facility. Craft items from recipes: spend the HQ resource
      pool and a finished item lands in the party stash after the craft time. The GM authors recipes here
      (drop an output, set cost / tier / required facilities / time); everyone with access crafts. --}}
<section class="pa-workshop-body">
{{#if gone}}
  <div class="wk-gone"><i class="fa-solid fa-screwdriver-wrench"></i><p>{{localize "PROJECTANIME.Workshop.gone"}}</p></div>
{{else}}

  <header class="wk-bar">
    <div class="wk-vendor"><img src="{{workshop.img}}" alt=""><span>{{workshop.name}}</span></div>
    <span class="wk-tier">{{#each tierPips}}<i class="wk-star{{#if on}} on{{/if}}">★</i>{{/each}}</span>
  </header>

  {{#if notBuilt}}<div class="wk-note"><i class="fa-solid fa-triangle-exclamation"></i> {{localize "PROJECTANIME.Workshop.needBuilt"}}</div>{{/if}}

  {{#if hasJobs}}
  <div class="wk-progress">
    <h4 class="wk-h"><i class="fa-solid fa-hourglass-half"></i> {{localize "PROJECTANIME.Workshop.inProgress"}}</h4>
    <div class="wk-jobs">
      {{#each jobs}}
      <div class="wk-job" title="{{name}}"><img src="{{img}}" alt=""><span class="wk-job-nm">{{name}}</span><span class="wk-job-left">{{readyLabel}}</span></div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{#if isGM}}<button type="button" class="wk-add" data-action="addRecipe"><i class="fa-solid fa-plus"></i> {{localize "PROJECTANIME.Workshop.addRecipe"}}</button>{{/if}}

  <div class="wk-list">
    {{#if hasRecipes}}
    {{#each recipes}}
    <div class="wk-recipe{{#unless canCraft}} locked{{/unless}}" data-recipe-id="{{id}}">

      <div class="wk-rhead">
        {{#if @root.isGM}}
        <button type="button" class="wk-ric" data-action="pickRecipeImage" data-recipe-id="{{id}}" title="{{localize 'PROJECTANIME.HQ.missionImagePick'}}"><img src="{{img}}" alt=""></button>
        {{else}}
        <span class="wk-ric"><img src="{{img}}" alt=""></span>
        {{/if}}
        <div class="wk-rmeta">
          {{#if @root.isGM}}
          <input class="wk-rname" data-recipe-id="{{id}}" data-recipe-field="name" value="{{name}}" placeholder="{{localize 'PROJECTANIME.Workshop.recipeName'}}">
          {{else}}
          <span class="wk-rname ro">{{#if name}}{{name}}{{else}}{{localize "PROJECTANIME.Workshop.recipeUntitled"}}{{/if}}</span>
          {{/if}}
          {{#if hasOutput}}<span class="wk-rout"><i class="fa-solid fa-arrow-right-long"></i> {{output.name}}{{#if output.typeLabel}} <em>{{output.typeLabel}}</em>{{/if}}</span>{{/if}}
        </div>
        {{#if @root.isGM}}<a class="wk-x" data-action="removeRecipe" data-recipe-id="{{id}}" title="{{localize 'PROJECTANIME.Workshop.removeRecipe'}}">✕</a>{{/if}}
      </div>

      {{#if @root.isGM}}
      <div class="wk-author">
        <div class="wk-out-drop" data-output-drop="{{id}}">
          {{#if hasOutput}}<img src="{{output.img}}" alt=""><span>{{output.name}}</span>{{else}}<i class="fa-solid fa-plus"></i> <span>{{localize "PROJECTANIME.Workshop.outputDrop"}}</span>{{/if}}
        </div>
        <div class="wk-cap">{{localize "PROJECTANIME.Workshop.cost"}}</div>
        <div class="wk-cost-edit">
          {{#each costEdit}}
          <span class="wk-cost-in" title="{{label}}">{{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}}<input type="number" min="0" data-recipe-id="{{../id}}" data-recipe-cost="{{key}}" value="{{amount}}"></span>
          {{/each}}
        </div>
        <div class="wk-opts">
          <label class="wk-opt" title="{{localize 'PROJECTANIME.Workshop.minTierHint'}}"><i class="fa-solid fa-star"></i> {{localize "PROJECTANIME.Workshop.minTier"}}
            <select data-recipe-id="{{id}}" data-recipe-field="minTier">{{#each minTierOptions}}<option value="{{n}}" {{#if sel}}selected{{/if}}>{{n}}</option>{{/each}}</select>
          </label>
          <label class="wk-opt" title="{{localize 'PROJECTANIME.Workshop.craftTimeHint'}}"><i class="fa-solid fa-hourglass-half"></i> {{localize "PROJECTANIME.Workshop.craftTime"}}
            <input type="number" min="1" data-recipe-id="{{id}}" data-recipe-field="craftTime" value="{{craftTime}}">
          </label>
        </div>
        <div class="wk-cap">{{localize "PROJECTANIME.Workshop.requires"}}</div>
        <div class="wk-reqs">
          {{#each requires}}
          <div class="wk-req">
            <select data-recipe-id="{{../id}}" data-require-idx="{{idx}}" data-require-field="facilityId">{{#each facilityOptions}}<option value="{{id}}" {{#if sel}}selected{{/if}}>{{name}}</option>{{/each}}</select>
            <select class="wk-req-tier" data-recipe-id="{{../id}}" data-require-idx="{{idx}}" data-require-field="tier">{{#each tierOptions}}<option value="{{n}}" {{#if sel}}selected{{/if}}>★{{n}}</option>{{/each}}</select>
            <a class="wk-req-x" data-action="removeRequire" data-recipe-id="{{../id}}" data-require-idx="{{idx}}" title="{{localize 'PROJECTANIME.Workshop.removeRecipe'}}">✕</a>
          </div>
          {{else}}
          <span class="wk-req-none">{{localize "PROJECTANIME.Workshop.requiresNone"}}</span>
          {{/each}}
          {{#if @root.hasFacilityOptions}}<button type="button" class="wk-req-add" data-action="addRequire" data-recipe-id="{{id}}"><i class="fa-solid fa-plus"></i> {{localize "PROJECTANIME.Workshop.requiresAdd"}}</button>{{/if}}
        </div>
      </div>
      {{/if}}

      <div class="wk-rfoot">
        <div class="wk-cost">
          {{#if hasCost}}{{#each costChips}}<span class="wk-chip{{#unless enough}} short{{/unless}}" title="{{label}} — {{have}}/{{amount}}">{{#if iconImg}}<img src="{{icon}}" alt="">{{else}}<i class="{{icon}}"></i>{{/if}} {{amount}}</span>{{/each}}{{else}}<span class="wk-freecost">{{localize "PROJECTANIME.HQ.free"}}</span>{{/if}}
        </div>
        {{#if canCraft}}
        <button type="button" class="wk-craft" data-action="craftItem" data-recipe-id="{{id}}"><i class="fa-solid fa-hammer"></i> {{localize "PROJECTANIME.Workshop.craftBtn"}}</button>
        {{else}}
        <span class="wk-lock"><i class="fa-solid fa-lock"></i> {{lockReason}}</span>
        {{/if}}
      </div>

    </div>
    {{/each}}
    {{else}}
    <div class="wk-empty">{{localize "PROJECTANIME.Workshop.noRecipes"}}</div>
    {{/if}}
  </div>

{{/if}}
</section>
