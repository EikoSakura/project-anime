{{!-- Choice Set editor for items. Each choice set is a small card. --}}
<div class="ec-choice-sets">
  {{#each choiceSets}}
  <div class="ec-cs-card" data-cs-id="{{this.id}}">
    <div class="ec-cs-card__header">
      <i class="fa-solid fa-list-check ec-cs-card__icon"></i>
      <input type="text" class="ec-cs-label-input"
             value="{{this.label}}"
             data-field="cs-label" data-cs-id="{{this.id}}"
             placeholder="{{localize 'SHARDS.ChoiceSet.LabelHint'}}" />
      <button type="button" class="ec-cs-delete" data-action="removeChoiceSet" data-cs-id="{{this.id}}"
              data-tooltip="{{localize 'SHARDS.EffectCreator.CtxDelete'}}">
        <i class="fa-solid fa-trash"></i>
      </button>
    </div>
    <div class="ec-cs-card__body">
      {{!-- Source Type --}}
      <div class="ec-cs-row">
        <label>{{localize "SHARDS.ChoiceSet.SourceType"}}</label>
        <select data-field="cs-type" data-cs-id="{{this.id}}">
          <option value="preset" {{#if this.isPreset}}selected{{/if}}>{{localize "SHARDS.ChoiceSet.Preset"}}</option>
          <option value="custom" {{#if this.isCustom}}selected{{/if}}>{{localize "SHARDS.ChoiceSet.Custom"}}</option>
        </select>
      </div>

      {{!-- Preset Type (only shown when type=preset) --}}
      {{#if this.isPreset}}
      <div class="ec-cs-row">
        <label>{{localize "SHARDS.ChoiceSet.PresetType"}}</label>
        <select data-field="cs-presetType" data-cs-id="{{this.id}}">
          {{#each this.presetTypeOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      {{!-- Custom Options (only shown when type=custom) --}}
      {{#if this.isCustom}}
      <div class="ec-cs-custom-options">
        <label class="ec-cs-section-label">{{localize "SHARDS.ChoiceSet.Options"}}</label>
        {{#each this.customOptions}}
        <div class="ec-cs-option-row" data-option-index="{{@index}}">
          <input type="text" value="{{this.label}}" data-field="cs-opt-label"
                 data-cs-id="{{../id}}" data-option-index="{{@index}}"
                 placeholder="{{localize 'SHARDS.ChoiceSet.OptionLabel'}}" />
          <input type="text" value="{{this.value}}" data-field="cs-opt-value"
                 data-cs-id="{{../id}}" data-option-index="{{@index}}"
                 placeholder="{{localize 'SHARDS.ChoiceSet.OptionValue'}}" />
          <button type="button" data-action="removeCustomOption"
                  data-cs-id="{{../id}}" data-option-index="{{@index}}"
                  data-tooltip="{{localize 'SHARDS.EffectCreator.RemoveHint'}}">
            <i class="fa-solid fa-minus"></i>
          </button>
        </div>
        {{/each}}
        <button type="button" class="ec-cs-add-option" data-action="addCustomOption" data-cs-id="{{this.id}}">
          <i class="fa-solid fa-plus"></i> {{localize "SHARDS.ChoiceSet.AddOption"}}
        </button>
      </div>
      {{/if}}

      {{!-- Required Toggle --}}
      <label class="ec-cs-checkbox">
        <input type="checkbox" data-field="cs-required" data-cs-id="{{this.id}}" {{#if this.required}}checked{{/if}} />
        {{localize "SHARDS.ChoiceSet.Required"}}
      </label>

      {{!-- Item Data Update --}}
      <div class="ec-cs-effect-section">
        <label class="ec-cs-checkbox">
          <input type="checkbox" data-field="cs-hasItemUpdate" data-cs-id="{{this.id}}" {{#if this.hasItemUpdate}}checked{{/if}} />
          {{localize "SHARDS.ChoiceSet.UpdateItem"}}
        </label>
        {{#if this.hasItemUpdate}}
        <div class="ec-cs-effect-fields">
          <div class="ec-cs-row">
            <label>{{localize "SHARDS.ChoiceSet.UpdateKey"}}</label>
            <input type="text" data-field="cs-itemUpdateKey" data-cs-id="{{this.id}}"
                   value="{{this.itemUpdateKey}}"
                   placeholder="system.damageType" />
          </div>
          <div class="ec-cs-row">
            <label>{{localize "SHARDS.ChoiceSet.UpdateValue"}}</label>
            <input type="text" data-field="cs-itemUpdateValue" data-cs-id="{{this.id}}"
                   value="{{this.itemUpdateValue}}"
                   placeholder="{CHOICE_VALUE}" />
          </div>
          <p class="ec-cs-hint">{{localize "SHARDS.ChoiceSet.UpdateHint"}}</p>
        </div>
        {{/if}}
      </div>

      {{!-- Effect Template --}}
      <div class="ec-cs-effect-section">
        <label class="ec-cs-checkbox">
          <input type="checkbox" data-field="cs-hasEffect" data-cs-id="{{this.id}}" {{#if this.hasEffect}}checked{{/if}} />
          {{localize "SHARDS.ChoiceSet.CreateEffect"}}
        </label>
        {{#if this.hasEffect}}
        <div class="ec-cs-effect-fields">
          <div class="ec-cs-row">
            <label>{{localize "SHARDS.ChoiceSet.EffectName"}}</label>
            <input type="text" data-field="cs-effectName" data-cs-id="{{this.id}}"
                   value="{{this.effectNamePattern}}"
                   placeholder="{CHOICE} Resistance" />
          </div>
          <div class="ec-cs-row">
            <label>{{localize "SHARDS.ChoiceSet.ChangeKey"}}</label>
            <input type="text" data-field="cs-changeKey" data-cs-id="{{this.id}}"
                   value="{{this.changeKey}}"
                   placeholder="system.elementResistances.{CHOICE}" />
          </div>
          <div class="ec-cs-row">
            <label>{{localize "SHARDS.ChoiceSet.ChangeMode"}}</label>
            <select data-field="cs-changeMode" data-cs-id="{{this.id}}">
              <option value="2" {{#if this.modeIsAdd}}selected{{/if}}>{{localize "SHARDS.EffectCreator.ModeAdd"}}</option>
              <option value="5" {{#if this.modeIsOverride}}selected{{/if}}>{{localize "SHARDS.EffectCreator.ModeOverride"}}</option>
            </select>
          </div>
          <div class="ec-cs-row">
            <label>{{localize "SHARDS.ChoiceSet.ChangeValue"}}</label>
            <input type="text" data-field="cs-changeValue" data-cs-id="{{this.id}}"
                   value="{{this.changeValue}}"
                   placeholder="1" />
          </div>
          <p class="ec-cs-hint">{{localize "SHARDS.ChoiceSet.PlaceholderHint"}}</p>
        </div>
        {{/if}}
      </div>
    </div>
  </div>
  {{/each}}

  {{#unless choiceSets.length}}
  <p class="ec-cs-empty">{{localize "SHARDS.ChoiceSet.Empty"}}</p>
  {{/unless}}

  <button type="button" class="ec-cs-add-btn" data-action="addChoiceSet">
    <i class="fa-solid fa-plus"></i> {{localize "SHARDS.ChoiceSet.Add"}}
  </button>
</div>
