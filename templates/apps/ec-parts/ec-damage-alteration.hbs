{{!-- Damage Alteration editor for items. Each alteration is a card. --}}
<div class="ec-alterations">
  {{#each damageAlterations}}
  <div class="ec-alt-card" data-alt-id="{{this.id}}">
    <div class="ec-alt-card__header">
      <i class="fa-solid fa-burst ec-alt-card__icon"></i>
      <span class="ec-alt-card__name">{{this.typeLabel}}</span>
      <button type="button" class="ec-alt-delete" data-action="removeAlteration" data-alt-id="{{this.id}}"
              data-tooltip="{{localize 'SHARDS.EffectCreator.CtxDelete'}}">
        <i class="fa-solid fa-trash"></i>
      </button>
    </div>
    <div class="ec-alt-card__body">
      {{!-- Alteration Type --}}
      <div class="ec-alt-row">
        <label>{{localize "SHARDS.DmgAlt.Type"}}</label>
        <select data-field="alt-type" data-alt-id="{{this.id}}">
          <option value="changeElement" {{#if this.isChangeElement}}selected{{/if}}>{{localize "SHARDS.DmgAlt.ChangeElement"}}</option>
          <option value="bonusDamage" {{#if this.isBonusDamage}}selected{{/if}}>{{localize "SHARDS.DmgAlt.BonusDamage"}}</option>
          <option value="addPierce" {{#if this.isAddPierce}}selected{{/if}}>{{localize "SHARDS.DmgAlt.AddPierce"}}</option>
          <option value="changeDefenseType" {{#if this.isChangeDefense}}selected{{/if}}>{{localize "SHARDS.DmgAlt.ChangeDefense"}}</option>
        </select>
      </div>

      {{!-- Type-specific fields --}}
      {{#if this.isChangeElement}}
      <div class="ec-alt-row">
        <label>{{localize "SHARDS.DmgAlt.NewElement"}}</label>
        <select data-field="alt-newElement" data-alt-id="{{this.id}}">
          {{#each this.elementOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      {{#if this.isBonusDamage}}
      <div class="ec-alt-row">
        <label>{{localize "SHARDS.DmgAlt.BonusFormula"}}</label>
        <input type="text" data-field="alt-bonusFormula" data-alt-id="{{this.id}}"
               value="{{this.bonusFormula}}" placeholder="SL * 2" />
      </div>
      {{/if}}

      {{#if this.isChangeDefense}}
      <div class="ec-alt-row">
        <label>{{localize "SHARDS.DmgAlt.NewDefense"}}</label>
        <select data-field="alt-newDefenseType" data-alt-id="{{this.id}}">
          <option value="physical" {{#if this.defIsPhysical}}selected{{/if}}>{{localize "SHARDS.DmgAlt.Physical"}}</option>
          <option value="magical" {{#if this.defIsMagical}}selected{{/if}}>{{localize "SHARDS.DmgAlt.Magical"}}</option>
          <option value="none" {{#if this.defIsNone}}selected{{/if}}>{{localize "SHARDS.DmgAlt.None"}}</option>
        </select>
      </div>
      {{/if}}

      {{!-- Filter --}}
      <div class="ec-alt-filter">
        <label class="ec-alt-filter-label">{{localize "SHARDS.DmgAlt.AppliesTo"}}</label>
        <div class="ec-alt-row">
          <label>{{localize "SHARDS.DmgAlt.Scope"}}</label>
          <select data-field="alt-scope" data-alt-id="{{this.id}}">
            <option value="all" {{#if this.scopeIsAll}}selected{{/if}}>{{localize "SHARDS.DmgAlt.ScopeAll"}}</option>
            <option value="weaponGroup" {{#if this.scopeIsWeaponGroup}}selected{{/if}}>{{localize "SHARDS.DmgAlt.ScopeWeaponGroup"}}</option>
            <option value="skillType" {{#if this.scopeIsSkillType}}selected{{/if}}>{{localize "SHARDS.DmgAlt.ScopeSkillType"}}</option>
          </select>
        </div>

        {{#if this.scopeIsWeaponGroup}}
        <div class="ec-alt-row">
          <label>{{localize "SHARDS.DmgAlt.WeaponGroup"}}</label>
          <select data-field="alt-weaponGroup" data-alt-id="{{this.id}}">
            {{#each this.weaponGroupOptions}}
            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
        {{/if}}

        {{#if this.scopeIsSkillType}}
        <div class="ec-alt-row">
          <label>{{localize "SHARDS.DmgAlt.SkillType"}}</label>
          <select data-field="alt-skillType" data-alt-id="{{this.id}}">
            {{#each this.skillTypeOptions}}
            <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        </div>
        {{/if}}
      </div>
    </div>
  </div>
  {{/each}}

  {{#unless damageAlterations.length}}
  <p class="ec-alt-empty">{{localize "SHARDS.DmgAlt.Empty"}}</p>
  {{/unless}}

  <button type="button" class="ec-alt-add-btn" data-action="addAlteration">
    <i class="fa-solid fa-plus"></i> {{localize "SHARDS.DmgAlt.Add"}}
  </button>
</div>
