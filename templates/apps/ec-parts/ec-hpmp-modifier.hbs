{{!-- HP/MP/Pips Modifier category: 3 target buttons + builder controls --}}
<div class="ec-button-grid ec-button-grid--hpmp">
  {{#each hpmpTargets}}
  <button type="button"
          class="ec-pick-btn {{#if this.selected}}selected{{/if}}"
          data-action="pickTarget"
          data-category="hpmp"
          data-target-key="{{this.key}}"
          data-tooltip="{{this.label}}">
    <i class="{{this.icon}}"></i>
    <span class="ec-pick-btn__label">{{this.label}}</span>
  </button>
  {{/each}}
</div>

{{> "systems/shards-of-mana/templates/apps/ec-parts/ec-builder-controls.hbs" categoryId="hpmp"}}
