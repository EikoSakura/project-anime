{{!-- ================================================================ --}}
{{!--  Quick Effect Creator — PF2e-style dropdown + builder panel     --}}
{{!-- ================================================================ --}}

<div class="ec-wrapper">
<div class="ec-scroll-area">

  {{!-- ==================== EXISTING EFFECTS LIST ==================== --}}
  <section class="ec-section">
    <div class="ec-section-header">
      <i class="fa-solid fa-sparkles ec-section-header__icon"></i>
      <span class="ec-section-header__label">{{localize "SHARDS.EffectCreator.ExistingEffects"}}</span>
      {{#if existingEffects.length}}
      <span class="ec-section-header__badge">{{existingEffects.length}}</span>
      {{/if}}
    </div>

    {{#if existingEffects.length}}
    <div class="ec-effects-list">
      {{#each existingEffects}}
      <div class="ec-effect-card {{#if this.disabled}}is-disabled{{/if}} {{#if this.isCriticalHp}}is-critical{{/if}} {{#if this.isConditional}}is-conditional{{/if}}"
           data-effect-id="{{this.effectId}}">
        <img class="ec-effect-card__img" src="{{this.img}}" width="24" height="24" alt="" />
        <div class="ec-effect-card__info">
          <span class="ec-effect-card__name">{{this.name}}</span>
          {{#if this.conditionalLabel}}
          <span class="ec-effect-card__condition">{{this.conditionalLabel}}</span>
          {{/if}}
        </div>
        {{#if this.badge}}
        <span class="ec-effect-card__badge {{this.badgeCss}}">{{this.badge}}</span>
        {{/if}}
        <div class="ec-effect-card__btns">
          <button type="button" data-action="toggleExistingEffect" data-effect-id="{{this.effectId}}"
                  data-tooltip="{{#if this.disabled}}{{localize 'SHARDS.EffectCreator.CtxEnable'}}{{else}}{{localize 'SHARDS.EffectCreator.CtxDisable'}}{{/if}}">
            <i class="fa-solid {{#if this.disabled}}fa-eye-slash{{else}}fa-eye{{/if}}"></i>
          </button>
          <button type="button" data-action="editExistingEffect" data-effect-id="{{this.effectId}}"
                  data-tooltip="{{localize 'SHARDS.EffectCreator.CtxEdit'}}">
            <i class="fa-solid fa-pen-to-square"></i>
          </button>
          <button type="button" data-action="deleteExistingEffect" data-effect-id="{{this.effectId}}"
                  data-tooltip="{{localize 'SHARDS.EffectCreator.CtxDelete'}}">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      </div>
      {{/each}}
    </div>
    {{else}}
    <p class="ec-empty-msg">{{localize "SHARDS.EffectCreator.NoEffects"}}</p>
    {{/if}}
  </section>

  {{!-- ==================== ITEM FLAGS: CHOICE SETS ==================== --}}
  {{#unless isActor}}
  {{#if hasChoiceSets}}
  <section class="ec-section">
    <div class="ec-section-header">
      <i class="fa-solid fa-list-check ec-section-header__icon"></i>
      <span class="ec-section-header__label">{{localize "SHARDS.EffectCreator.CatChoiceSet"}}</span>
      <span class="ec-section-header__badge">{{choiceSetCount}}</span>
    </div>
    {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-choice-set.hbs"}}
  </section>
  {{/if}}

  {{!-- ==================== ITEM FLAGS: GRANTS ==================== --}}
  {{#if hasGrants}}
  <section class="ec-section">
    <div class="ec-section-header">
      <i class="fa-solid fa-gift ec-section-header__icon"></i>
      <span class="ec-section-header__label">{{localize "SHARDS.EffectCreator.CatGrants"}}</span>
      <span class="ec-section-header__badge">{{grantCount}}</span>
    </div>
    {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-grant-item.hbs"}}
  </section>
  {{/if}}

  {{!-- ==================== ITEM FLAGS: DAMAGE ALTERATIONS ==================== --}}
  {{#if hasDmgAlts}}
  <section class="ec-section">
    <div class="ec-section-header">
      <i class="fa-solid fa-burst ec-section-header__icon"></i>
      <span class="ec-section-header__label">{{localize "SHARDS.EffectCreator.CatDmgAlt"}}</span>
      <span class="ec-section-header__badge">{{dmgAltCount}}</span>
    </div>
    {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-damage-alteration.hbs"}}
  </section>
  {{/if}}
  {{/unless}}

  {{!-- ==================== ACTIVE BUILDER PANEL ==================== --}}
  {{#if activeBuilder}}
  <section class="ec-builder-panel">
    <div class="ec-builder-panel__header">
      <i class="fa-solid fa-wand-sparkles ec-builder-panel__icon"></i>
      <span class="ec-builder-panel__title">{{activeBuilderLabel}}</span>
      <button type="button" class="ec-builder-panel__close" data-action="cancelBuilder"
              data-tooltip="Cancel">
        <i class="fa-solid fa-times"></i>
      </button>
    </div>
    <div class="ec-builder-panel__body">

      {{!-- Stat Modifier --}}
      {{#if builderIsStat}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-stat-modifier.hbs" stats=statButtons}}
      {{/if}}

      {{!-- Derived Stat Modifier --}}
      {{#if builderIsDerived}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-derived-modifier.hbs" derivedStats=derivedButtons}}
      {{/if}}

      {{!-- HP/MP/Pips --}}
      {{#if builderIsHpmp}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-hpmp-modifier.hbs" hpmpTargets=hpmpButtons}}
      {{/if}}

      {{!-- Growth Rate --}}
      {{#if builderIsGrowthRate}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-growth-rate.hbs" stats=statButtons}}
      {{/if}}

      {{!-- Movement/Size --}}
      {{#if builderIsMovement}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-movement-speed.hbs"}}
      {{/if}}

      {{!-- Element Resistance Toggles --}}
      {{#if builderIsElementRes}}
      <div class="ec-flag-grid ec-flag-grid--elements">
        {{#each elementResistances}}
        <button type="button"
                class="ec-elem-btn {{#if this.active}}active {{this.tierCss}}{{else if this.disabled}}exists disabled-effect{{/if}}"
                data-action="toggleElementResistance"
                data-element-key="{{this.key}}"
                data-effect-id="{{this.effectId}}"
                data-tooltip="{{this.label}}{{#if this.tierLabel}}: {{this.tierLabel}}{{/if}}">
          <span class="ec-elem-btn__label">{{this.label}}</span>
          {{#if this.tierLabel}}
          <span class="ec-elem-btn__tier">{{this.tierLabel}}</span>
          {{/if}}
          {{#if this.disabled}}
          <i class="fa-solid fa-eye-slash ec-elem-btn__check"></i>
          {{/if}}
        </button>
        {{/each}}
      </div>
      {{/if}}

      {{!-- Condition Immunity Toggles --}}
      {{#if builderIsCondImmunity}}
      <div class="ec-flag-grid">
        {{#each condImmunityFlags}}
        <button type="button"
                class="ec-flag-btn {{#if this.active}}active{{else if this.disabled}}exists disabled-effect{{/if}}"
                data-action="toggleFlag"
                data-flag-key="{{this.key}}"
                data-effect-id="{{this.effectId}}"
                data-tooltip="{{this.desc}}">
          <img src="{{this.img}}" width="20" height="20" alt="" />
          <span class="ec-flag-btn__label">{{this.label}}</span>
          {{#if this.active}}
          <i class="fa-solid fa-check ec-flag-btn__check"></i>
          {{else if this.disabled}}
          <i class="fa-solid fa-eye-slash ec-flag-btn__check"></i>
          {{/if}}
        </button>
        {{/each}}
      </div>
      {{/if}}

      {{!-- Conditions Toggles --}}
      {{#if builderIsConditions}}
      {{#each conditionGroups}}
      <div class="ec-flag-group">
        <span class="ec-flag-group__label {{this.colorClass}}">{{this.group}}</span>
        <div class="ec-flag-grid">
          {{#each this.conditions}}
          <button type="button"
                  class="ec-flag-btn ec-flag-btn--cond {{#if this.active}}active {{../colorClass}}{{else if this.disabled}}exists disabled-effect{{/if}}"
                  data-action="toggleCondition"
                  data-condition-id="{{this.id}}"
                  data-effect-id="{{this.effectId}}"
                  data-tooltip="{{this.desc}}">
            <img src="{{this.img}}" width="20" height="20" alt="" />
            <span class="ec-flag-btn__label">{{this.label}}</span>
            {{#if this.active}}
            <i class="fa-solid fa-check ec-flag-btn__check"></i>
            {{else if this.disabled}}
            <i class="fa-solid fa-eye-slash ec-flag-btn__check"></i>
            {{/if}}
          </button>
          {{/each}}
        </div>
      </div>
      {{/each}}
      {{/if}}

      {{!-- Movement Mode Toggles --}}
      {{#if builderIsMovementModes}}
      <div class="ec-flag-grid">
        {{#each movementModeFlags}}
        <button type="button"
                class="ec-flag-btn {{#if this.active}}active{{else if this.disabled}}exists disabled-effect{{/if}}"
                data-action="toggleFlag"
                data-flag-key="{{this.key}}"
                data-effect-id="{{this.effectId}}"
                data-tooltip="{{this.desc}}">
          <img src="{{this.img}}" width="20" height="20" alt="" />
          <span class="ec-flag-btn__label">{{this.label}}</span>
          {{#if this.active}}
          <i class="fa-solid fa-check ec-flag-btn__check"></i>
          {{else if this.disabled}}
          <i class="fa-solid fa-eye-slash ec-flag-btn__check"></i>
          {{/if}}
        </button>
        {{/each}}
      </div>
      {{/if}}

      {{!-- Special Flags Toggles --}}
      {{#if builderIsSpecial}}
      <div class="ec-flag-grid">
        {{#each specialFlags}}
        <button type="button"
                class="ec-flag-btn {{#if this.active}}active{{else if this.disabled}}exists disabled-effect{{/if}}"
                data-action="toggleFlag"
                data-flag-key="{{this.key}}"
                data-effect-id="{{this.effectId}}"
                data-tooltip="{{this.desc}}">
          <img src="{{this.img}}" width="20" height="20" alt="" />
          <span class="ec-flag-btn__label">{{this.label}}</span>
          {{#if this.active}}
          <i class="fa-solid fa-check ec-flag-btn__check"></i>
          {{else if this.disabled}}
          <i class="fa-solid fa-eye-slash ec-flag-btn__check"></i>
          {{/if}}
        </button>
        {{/each}}
      </div>
      {{/if}}

      {{!-- Critical HP --}}
      {{#if builderIsCriticalHp}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-critical-hp.hbs"}}
      {{/if}}

      {{!-- Choice-Linked Effect --}}
      {{#if builderIsChoiceLinked}}
      {{> "systems/shards-of-mana/templates/apps/ec-parts/ec-choice-linked.hbs" choiceLinked=choiceLinked}}
      {{/if}}

    </div>
  </section>
  {{/if}}

</div>

{{!-- ==================== FIXED FOOTER ==================== --}}
<div class="ec-footer">
  <div class="ec-add-row">
    <select class="ec-type-select" data-field="add-type">
      <optgroup label="{{localize 'SHARDS.EffectCreator.GroupModifiers'}}">
        <option value="stat">{{localize "SHARDS.EffectCreator.CatStat"}}</option>
        <option value="derived">{{localize "SHARDS.EffectCreator.CatDerived"}}</option>
        <option value="hpmp">{{localize "SHARDS.EffectCreator.CatHpMp"}}</option>
        <option value="growthRate">{{localize "SHARDS.EffectCreator.CatGrowthRate"}}</option>
        <option value="movement">{{localize "SHARDS.EffectCreator.CatMovement"}}</option>
      </optgroup>
      <optgroup label="{{localize 'SHARDS.EffectCreator.GroupToggles'}}">
        <option value="elementRes">{{localize "SHARDS.EffectCreator.FlagGroupElementRes"}}</option>
        <option value="condImmunity">{{localize "SHARDS.EffectCreator.FlagGroupCondImmunity"}}</option>
        <option value="conditions">{{localize "SHARDS.EffectCreator.Conditions"}}</option>
        <option value="movementModes">{{localize "SHARDS.EffectCreator.FlagGroupMovementModes"}}</option>
        <option value="special">{{localize "SHARDS.EffectCreator.FlagGroupSpecial"}}</option>
      </optgroup>
      {{#unless isActor}}
      <optgroup label="{{localize 'SHARDS.EffectCreator.GroupItemRules'}}">
        <option value="choiceSet">{{localize "SHARDS.EffectCreator.CatChoiceSet"}}</option>
        {{#if hasChoiceSets}}
        <option value="choiceLinked">{{localize "SHARDS.EffectCreator.CatChoiceLinked"}}</option>
        {{/if}}
        <option value="grants">{{localize "SHARDS.EffectCreator.CatGrants"}}</option>
        <option value="dmgAlt">{{localize "SHARDS.EffectCreator.CatDmgAlt"}}</option>
      </optgroup>
      {{/unless}}
      <optgroup label="{{localize 'SHARDS.EffectCreator.GroupSpecial'}}">
        <option value="criticalHp">{{localize "SHARDS.EffectCreator.CatCriticalHp"}}</option>
      </optgroup>
    </select>
    <button type="button" class="ec-add-btn" data-action="showBuilder">
      <i class="fa-solid fa-plus"></i>
      {{localize "SHARDS.EffectCreator.NewEffect"}}
    </button>
  </div>
  <div class="ec-footer-btns">
    <button type="button" class="ec-advanced-btn" data-action="openAdvanced">
      <i class="fa-solid fa-sliders"></i>
      {{localize "SHARDS.EffectCreator.Advanced"}}
    </button>
    <button type="button" class="ec-save-close-btn" data-action="saveAndClose">
      <i class="fa-solid fa-check"></i>
      {{localize "SHARDS.EffectCreator.SaveClose"}}
    </button>
  </div>
</div>
</div>
