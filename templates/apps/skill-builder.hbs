{{!-- In-game Skill Builder: hub / build wizard / advance (improve). --}}
<div class="sb-body">

  {{!-- A standalone (world/compendium) Skill has no SP balance to show. --}}
  {{#unless isStandalone}}
  <div class="sb-sp" title="{{localize 'PROJECTANIME.Stat.skillPoints'}}">
    <i class="fas fa-star"></i>
    <span class="sb-sp-label">{{localize "PROJECTANIME.Stat.skillPoints"}}</span>
    <span class="sb-sp-val">{{sp}}</span>
  </div>
  {{/unless}}

  {{!-- ============================ HUB ============================ --}}
  {{#if isHub}}
  <div class="sb-hub">
    <button type="button" class="sb-build-new" data-action="buildNew">
      <i class="fas fa-plus"></i> {{localize "PROJECTANIME.SkillBuilder.buildNew"}}
    </button>

    {{#if skills.length}}
    <h3 class="sb-section-title">{{localize "PROJECTANIME.SkillBuilder.improveTitle"}}</h3>
    <ul class="sb-skill-list">
      {{#each skills as |s|}}
      <li class="sb-skill-row" data-skill-id="{{s.id}}">
        <img src="{{s.img}}" alt="{{s.name}}" />
        <div class="sb-skill-info">
          <span class="sb-skill-name">{{s.name}}</span>
          <span class="sb-skill-sub">{{s.stars}} · {{s.actionLabel}}{{#unless s.passive}} · <i class="fas fa-bolt"></i>{{s.energyCost}}{{/unless}}</span>
        </div>
        <button type="button" class="sb-improve sb-effects" data-action="editEffects">
          <i class="fas fa-wand-magic-sparkles"></i> {{localize "PROJECTANIME.SkillBuilder.editEffects"}}
        </button>
        <button type="button" class="sb-improve" data-action="improveSkill">
          <i class="fas fa-arrow-up-right-dots"></i> {{localize "PROJECTANIME.SkillBuilder.improve"}}
        </button>
      </li>
      {{/each}}
    </ul>
    {{/if}}
  </div>
  {{/if}}

  {{!-- ========================== BUILD ============================ --}}
  {{#if isBuild}}
  <div class="sb-wizard">
    <ol class="sb-steps">
      {{#each steps as |st|}}
      <li class="sb-step-dot{{#if st.active}} active{{/if}}{{#if st.done}} done{{/if}}" data-action="gotoStep" data-step="{{st.index}}" title="{{st.label}}">
        <span class="sb-dot-num">{{st.num}}</span>
        <span class="sb-dot-label">{{st.label}}</span>
      </li>
      {{/each}}
    </ol>

    <div class="sb-step-head">
      <span class="sb-step-counter">{{stepLabel}}</span>
      <span class="sb-step-title">{{stepTitle}}</span>
    </div>

    {{#if onConcept}}
    <section class="sb-step-body sb-concept">
      <div class="sb-id-row">
        <div class="sb-img" data-action="pickImage" title="{{localize 'PROJECTANIME.SkillBuilder.pickImage'}}">
          <img src="{{draft.img}}" alt="" />
        </div>
        <div class="sb-id-fields">
          <label class="sb-field">
            <span class="sb-label">{{localize "PROJECTANIME.SkillBuilder.skillName"}}</span>
            <input type="text" name="name" value="{{draft.name}}" />
          </label>
          <label class="sb-field">
            <span class="sb-label">{{localize "PROJECTANIME.Skill.field.actionType"}}</span>
            <select name="actionType">{{selectOptions actionTypeChoices selected=draft.actionType localize=true}}</select>
          </label>
        </div>
      </div>
      {{#if isReact}}
      <label class="sb-field{{#unless draft.trigger}} sb-needs{{/unless}}">
        <span class="sb-label">{{localize "PROJECTANIME.Skill.field.trigger"}}</span>
        <select name="trigger">{{selectOptions triggerChoices selected=draft.trigger localize=true blank=""}}</select>
      </label>
      {{/if}}
      <label class="sb-field">
        <span class="sb-label">{{localize "PROJECTANIME.Section.details"}}</span>
        <textarea name="description" rows="3">{{draft.description}}</textarea>
      </label>
    </section>
    {{/if}}

    {{#if onRank}}
    <section class="sb-step-body sb-rank">
      <div class="sb-rank-grid">
        {{#each rankCards as |rc|}}
        <button type="button" class="sb-rank-card{{#if rc.selected}} selected{{/if}}{{#unless rc.affordable}} unaffordable{{/unless}}"
                data-action="pickRank" data-rank="{{rc.rank}}" {{#unless rc.affordable}}disabled{{/unless}}>
          <span class="sb-rank-stars">{{rc.stars}}</span>
          <span class="sb-rank-name">{{rc.label}}</span>
          <span class="sb-rank-cost"><i class="fas fa-star"></i> {{rc.sp}} {{localize "PROJECTANIME.Stat.skillPointsAbbr"}}</span>
          <span class="sb-rank-meta"><i class="fas fa-bolt"></i> {{rc.energy}} · <i class="fas fa-sliders"></i> {{rc.maxModifiers}}</span>
        </button>
        {{/each}}
      </div>
    </section>
    {{/if}}

    {{#if onRoll}}
    <section class="sb-step-body sb-roll">
      <div class="sb-field-grid">
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.attrA"}}</span>
          <select name="attrA">{{selectOptions attributeChoices selected=draft.attrA localize=true}}</select>
        </label>
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.attrB"}}</span>
          <select name="attrB">{{selectOptions attributeChoices selected=draft.attrB localize=true}}</select>
        </label>
      </div>
      <label class="sb-field">
        <span class="sb-label">{{localize "PROJECTANIME.Skill.field.effect"}}</span>
        <select name="effect">
          {{#each effectChoices}}
          <option value="{{key}}" {{#if selected}}selected{{/if}}{{#if gated}} disabled{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </label>
      <p class="sb-effect-desc">{{effectDesc}}</p>
      {{#if skillEvasionPair}}
      <div class="sb-field-grid">
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.skillEvasionA"}}</span>
          <select disabled><option selected>{{skillEvasionPair.a}}</option></select>
        </label>
        {{#if skillEvasionPair.b}}
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.skillEvasionB"}}</span>
          <select disabled><option selected>{{skillEvasionPair.b}}</option></select>
        </label>
        {{/if}}
      </div>
      {{/if}}
      {{#if showEffectExtras}}
      <div class="sb-field-grid">
        {{#if showDamageDie}}
        <label class="sb-field">
          <span class="sb-label">{{localize damageDieLabel}}</span>
          <select name="damageAttr">{{selectOptions damageDieChoices selected=draft.damageAttr}}</select>
        </label>
        {{/if}}
        {{#if showDamageType}}
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.damageType"}}</span>
          <select name="damageType">{{selectOptions damageTypeChoices selected=draft.damageType blank=""}}</select>
        </label>
        {{/if}}
        {{#if showControlElement}}
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.controlElement"}}</span>
          <input type="text" name="controlElement" value="{{draft.controlElement}}" />
        </label>
        {{/if}}
        {{#if showDamagePool}}
        <label class="sb-field">
          <span class="sb-label">{{localize poolLabel}}</span>
          <select name="damagePool">{{selectOptions damagePoolChoices selected=draft.damagePool localize=true}}</select>
        </label>
        {{/if}}
      </div>
      {{/if}}
      {{#if isAttrEffect}}
      <div class="sb-bh">
        <div class="sb-bh-group">
          <span class="sb-bh-label">{{#if isHinder}}{{localize "PROJECTANIME.SkillBuilder.lowerAttrs"}}{{else}}{{localize "PROJECTANIME.SkillBuilder.raiseAttrs"}}{{/if}}</span>
          <div class="sb-field-grid">
            {{#each effectAttrPickers as |p|}}
            <label class="sb-field">
              <select name="effectAttr{{p.index}}">{{selectOptions ../attributeChoices selected=p.value localize=true blank=""}}</select>
            </label>
            {{/each}}
          </div>
        </div>
      </div>
      {{/if}}
    </section>
    {{/if}}

    {{#if onRange}}
    <section class="sb-step-body sb-range">
      <div class="sb-field-grid">
        <label class="sb-field{{#unless rangeHasTiles}} span-2{{/unless}}">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.range"}}</span>
          <select name="rangeScope">{{selectOptions rangeChoices selected=draft.range.scope localize=true}}</select>
        </label>
        {{#if rangeHasTiles}}
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.tiles"}} <span class="sb-cap">({{localize "PROJECTANIME.SkillBuilder.upTo"}} {{rangeRec}})</span></span>
          <input type="number" name="rangeTiles" value="{{draft.range.tiles}}" min="0" step="1" />
        </label>
        {{/if}}
      </div>
      {{#if showTargetDuration}}
      <div class="sb-field-grid">
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.target"}}</span>
          {{#if targetLocked}}
          <select name="target" disabled><option selected>{{localize "PROJECTANIME.Skill.target.self"}}</option></select>
          {{else}}
          <select name="target">{{selectOptions targetChoices selected=draft.target localize=true}}</select>
          {{/if}}
        </label>
        {{#if showDurationField}}
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.duration"}}</span>
          {{#if durationLocked}}
          <select name="duration" disabled><option selected>{{durationLocked}}</option></select>
          {{else}}
          <select name="duration">{{selectOptions durationChoices selected=draft.duration localize=true}}</select>
          {{/if}}
        </label>
        {{/if}}
        {{#if showDurationTurns}}
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.effectDuration"}}</span>
          <input type="number" name="effectDuration" value="{{draft.effectDuration}}" min="1" placeholder="2" />
        </label>
        {{/if}}
      </div>
      {{/if}}
    </section>
    {{/if}}

    {{#if onModifiers}}
    <section class="sb-step-body sb-modifiers">
      <div class="sb-mod-budget{{#if modOver}} over{{/if}}">
        {{localize "PROJECTANIME.Skill.field.modifiers"}}: <strong>{{modUsed}} / {{modMax}}</strong>
      </div>
      <ul class="sb-mod-list">
        {{#each modifierList as |mod|}}
        <li class="sb-mod-row{{#if mod.selected}} selected{{/if}}{{#if mod.blocked}} blocked{{/if}}"
            data-action="toggleModifier" data-modifier="{{mod.key}}">
          <i class="fas {{#if mod.selected}}fa-square-check{{else}}fa-square{{/if}}"></i>
          <span class="sb-mod-name">{{mod.label}}{{#if mod.heavy}} <span class="heavy-badge">{{localize "PROJECTANIME.Skill.heavy"}}</span>{{/if}}</span>
          <span class="sb-mod-desc">{{mod.desc}}</span>
          {{#if mod.selected}}
          {{#if mod.isCustom}}
          <span class="sb-mod-opts">
            <span class="sb-mod-opt{{#if mod.customHeavy}} on{{/if}}" data-action="toggleCustomHeavy">{{localize "PROJECTANIME.Skill.heavy"}}</span>
          </span>
          {{/if}}
          {{#if mod.isReequip}}
          <span class="sb-mod-opts">
            <span class="sb-mod-opt{{#if mod.reequipHeavy}} on{{/if}}" data-action="toggleReequipHeavy">{{localize "PROJECTANIME.Skill.heavy"}}</span>
          </span>
          {{/if}}
          {{/if}}
          {{#if mod.hasConfig}}
          <div class="sb-mod-config">
            {{#if mod.showInflict}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.inflictStatus"}}</span>
              <select name="inflictStatus">{{selectOptions ../conditionChoices selected=../draft.inflictStatus blank=""}}</select>
            </label>
            {{#if ../inflictLingering}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.decayType"}}</span>
              <select name="decayType">{{selectOptions ../damageTypeChoices selected=../draft.decayType blank=""}}</select>
            </label>
            {{/if}}
            {{#if ../inflictHasPool}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.inflictPool"}}</span>
              <select name="inflictPool">{{selectOptions ../config.damagePools selected=../draft.inflictPool localize=true}}</select>
            </label>
            {{/if}}
            {{/if}}
            {{#if mod.showAffinityDamage}}
            {{#each mod.affinityDamageTakes as |t|}}
            <div class="sb-take">
              <label class="sb-field">
                <span class="sb-label">{{localize "PROJECTANIME.Skill.field.affinityType"}}</span>
                <select name="affinityType{{t.index}}">{{selectOptions ../../damageTypeChoices selected=t.type blank=""}}</select>
              </label>
              <label class="sb-field">
                <span class="sb-label">{{localize "PROJECTANIME.Skill.field.affinityLevel"}}</span>
                <select name="affinityLevel{{t.index}}">{{selectOptions ../../affinityLevelChoices selected=t.level}}</select>
              </label>
              {{#if t.removable}}<span class="sb-mod-opt sb-take-x" data-action="removeModifierTake" data-take="{{t.index}}" data-tooltip="{{localize 'PROJECTANIME.SkillBuilder.takeRemove'}}"><i class="fas fa-xmark"></i></span>{{/if}}
            </div>
            {{/each}}
            {{/if}}
            {{#if mod.showAffinityStatus}}
            {{#each mod.affinityStatusTakes as |t|}}
            <div class="sb-take">
              <label class="sb-field">
                <span class="sb-label">{{localize "PROJECTANIME.Skill.field.affinityStatusId"}}</span>
                <select name="affinityStatusId{{t.index}}">{{selectOptions ../../conditionChoices selected=t.id blank=""}}</select>
              </label>
              {{#if t.removable}}<span class="sb-mod-opt sb-take-x" data-action="removeModifierTake" data-take="{{t.index}}" data-tooltip="{{localize 'PROJECTANIME.SkillBuilder.takeRemove'}}"><i class="fas fa-xmark"></i></span>{{/if}}
            </div>
            {{/each}}
            {{/if}}
            {{#if mod.showAnalyze}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.analyzeCategory"}}</span>
              <select name="analyzeCategory">{{selectOptions ../analyzeChoices selected=../draft.analyzeCategory}}</select>
            </label>
            {{/if}}
            {{#if mod.showInfuse}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.infuseKind"}}</span>
              <select name="infuseKind">{{selectOptions ../infuseKindChoices selected=../draft.infuseKind}}</select>
            </label>
            {{#if ../infuseIsStatus}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.infuseStatus"}}</span>
              <select name="infuseStatus">{{selectOptions ../conditionChoices selected=../draft.infuseStatus blank=""}}</select>
            </label>
            {{else}}
            <label class="sb-field">
              <span class="sb-label">{{localize "PROJECTANIME.Skill.field.infuseElement"}}</span>
              <select name="infuseElement">{{selectOptions ../damageTypeChoices selected=../draft.infuseElement blank=""}}</select>
            </label>
            {{/if}}
            {{/if}}
            {{#if mod.canTakeAgain}}
            <span class="sb-mod-opt sb-take-add" data-action="addModifierTake" data-tooltip="{{localize 'PROJECTANIME.SkillBuilder.takeAdd'}}"><i class="fas fa-plus"></i></span>
            {{/if}}
          </div>
          {{/if}}
        </li>
        {{/each}}
      </ul>
      {{#if secondaryActive}}
      <div class="sb-secondary-effect">
        <label class="sb-field">
          <span class="sb-label">{{localize "PROJECTANIME.Skill.field.secondaryEffect"}}</span>
          <select name="secondaryEffect">
            {{#each secondaryEffectChoices}}
            <option value="{{key}}" {{#if selected}}selected{{/if}}{{#if gated}} disabled{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </label>
        <p class="sb-effect-desc">{{secondaryEffectDesc}}</p>
        {{#if showSecondaryExtras}}
        <div class="sb-field-grid">
          {{#if showSecondaryDie}}
          <label class="sb-field">
            <span class="sb-label">{{localize secondaryDieLabel}}</span>
            <select name="secondaryDamageAttr">{{selectOptions damageDieChoices selected=draft.secondaryDamageAttr}}</select>
          </label>
          {{/if}}
          {{#if showSecondaryType}}
          <label class="sb-field">
            <span class="sb-label">{{localize "PROJECTANIME.Skill.field.damageType"}}</span>
            <select name="secondaryDamageType">{{selectOptions damageTypeChoices selected=draft.secondaryDamageType blank=""}}</select>
          </label>
          {{/if}}
          {{#if showSecondaryControlElement}}
          <label class="sb-field">
            <span class="sb-label">{{localize "PROJECTANIME.Skill.field.controlElement"}}</span>
            <input type="text" name="controlElement" value="{{draft.controlElement}}" />
          </label>
          {{/if}}
          {{#if showSecondaryPool}}
          <label class="sb-field">
            <span class="sb-label">{{localize secondaryPoolLabel}}</span>
            <select name="secondaryDamagePool">{{selectOptions damagePoolChoices selected=draft.secondaryDamagePool localize=true}}</select>
          </label>
          {{/if}}
        </div>
        {{/if}}
      </div>
      {{/if}}
    </section>
    {{/if}}

    {{#if onReview}}
    <section class="sb-step-body sb-review">
      <div class="sb-review-head">
        <img src="{{review.img}}" alt="" />
        <div class="sb-review-id">
          <div class="sb-review-name">{{review.name}}</div>
          <div class="sb-review-sub">{{review.stars}} {{review.rankLabel}} · {{review.actionType}}</div>
        </div>
      </div>
      <dl class="sb-review-list">
        <div><dt>{{localize "PROJECTANIME.Skill.field.effect"}}</dt><dd>{{review.effect}}</dd></div>
        {{#if review.secondaryEffect}}<div><dt>{{localize "PROJECTANIME.Skill.field.secondaryEffect"}}</dt><dd>{{review.secondaryEffect}}</dd></div>{{/if}}
        <div><dt>{{localize "PROJECTANIME.Skill.field.target"}}</dt><dd>{{review.target}}</dd></div>
        {{#if review.duration}}<div><dt>{{localize "PROJECTANIME.Skill.field.duration"}}</dt><dd>{{review.duration}}</dd></div>{{/if}}
        {{#if review.skillEvasion}}<div><dt>{{localize "PROJECTANIME.Skill.field.skillEvasion"}}</dt><dd>{{review.skillEvasion}}</dd></div>{{/if}}
        {{#if review.affinityDamage}}<div><dt>{{localize "PROJECTANIME.Skill.modifier.affinityDamage"}}</dt><dd>{{review.affinityDamage}}</dd></div>{{/if}}
        {{#if review.affinityStatus}}<div><dt>{{localize "PROJECTANIME.Skill.modifier.affinityStatus"}}</dt><dd>{{review.affinityStatus}}</dd></div>{{/if}}
        {{#if review.inflict}}<div><dt>{{localize "PROJECTANIME.Skill.field.inflictStatus"}}</dt><dd>{{review.inflict}}</dd></div>{{/if}}
        {{#if review.analyze}}<div><dt>{{localize "PROJECTANIME.Skill.modifier.analyze"}}</dt><dd>{{review.analyze}}</dd></div>{{/if}}
        {{#if review.infuse}}<div><dt>{{localize "PROJECTANIME.Skill.modifier.infuse"}}</dt><dd>{{review.infuse}}</dd></div>{{/if}}
        <div><dt>{{localize "PROJECTANIME.SkillBuilder.attributes"}}</dt><dd>{{review.attrA}} + {{review.attrB}}</dd></div>
        {{#if review.effectAttrs.length}}<div><dt>{{#if review.isHinder}}{{localize "PROJECTANIME.SkillBuilder.lowerAttrs"}}{{else}}{{localize "PROJECTANIME.SkillBuilder.raiseAttrs"}}{{/if}}</dt><dd>{{#each review.effectAttrs as |a|}}{{a}}{{#unless @last}}, {{/unless}}{{/each}}</dd></div>{{/if}}
        {{#if review.damageDie}}<div><dt>{{localize damageDieLabel}}</dt><dd>{{review.damageDie}}</dd></div>{{/if}}
        <div><dt>{{localize "PROJECTANIME.Skill.field.range"}}</dt><dd>{{review.range}}</dd></div>
        {{#if review.damageType}}<div><dt>{{localize "PROJECTANIME.Skill.field.damageType"}}</dt><dd>{{review.damageType}}</dd></div>{{/if}}
        {{#if review.controlElement}}<div><dt>{{localize "PROJECTANIME.Skill.field.controlElement"}}</dt><dd>{{review.controlElement}}</dd></div>{{/if}}
        {{#if review.damagePool}}<div><dt>{{localize poolLabel}}</dt><dd>{{review.damagePool}}</dd></div>{{/if}}
        {{#if review.trigger}}<div><dt>{{localize "PROJECTANIME.Skill.field.trigger"}}</dt><dd>{{review.trigger}}</dd></div>{{/if}}
        {{#if review.modifiers.length}}<div><dt>{{localize "PROJECTANIME.Skill.field.modifiers"}}</dt><dd>{{#each review.modifiers as |m|}}{{m}}{{#unless @last}}, {{/unless}}{{/each}}</dd></div>{{/if}}
        {{#if review.energyCost}}<div><dt>{{localize "PROJECTANIME.Skill.field.energyCost"}}</dt><dd><i class="fas fa-bolt"></i> {{review.energyCost}}</dd></div>{{/if}}
        {{#if review.passive}}<div><dt>{{localize "PROJECTANIME.Skill.field.energyTax"}}</dt><dd><i class="fas fa-bolt"></i> −{{review.passiveEnergyTax}}</dd></div>{{/if}}
      </dl>
      <div class="sb-cost-line{{#unless affordable}} unaffordable{{/unless}}">
        {{localize "PROJECTANIME.SkillBuilder.cost"}}: <strong><i class="fas fa-star"></i> {{review.spCost}} {{localize "PROJECTANIME.Stat.skillPointsAbbr"}}</strong>
      </div>
    </section>
    {{/if}}

    <div class="sb-nav">
      <div class="sb-nav-left">
        <button type="button" class="sb-cancel" data-action="backToHub"><i class="fas fa-xmark"></i> {{localize "Cancel"}}</button>
        {{!-- Standalone mode: the plain sheet's Effects tab is gone, so the wizard carries
              the hub's Edit Mechanical Effects entry itself. --}}
        {{#if isStandalone}}
        <button type="button" class="sb-fx" data-action="editEffects"><i class="fas fa-wand-magic-sparkles"></i> {{localize "PROJECTANIME.SkillBuilder.editEffects"}}</button>
        {{/if}}
      </div>
      <div class="sb-nav-right">
        {{#unless isFirst}}<button type="button" class="sb-back" data-action="stepBack"><i class="fas fa-chevron-left"></i> {{localize "PROJECTANIME.SkillBuilder.back"}}</button>{{/unless}}
        {{#if isLast}}
        <button type="button" class="sb-finish" data-action="finishBuild" {{#unless affordable}}disabled{{/unless}}>
          <i class="fas fa-check"></i> {{finishLabel}}{{#if netCostLabel}} ({{netCostLabel}}){{/if}}
        </button>
        {{else}}
        <button type="button" class="sb-next" data-action="stepNext">{{localize "PROJECTANIME.SkillBuilder.next"}} <i class="fas fa-chevron-right"></i></button>
        {{/if}}
      </div>
    </div>
  </div>
  {{/if}}

  {{!-- ========================= ADVANCE ========================== --}}
  {{#if isAdvance}}
  <div class="sb-advance">
    <div class="sb-adv-head">
      <img src="{{skill.img}}" alt="{{skill.name}}" />
      <div class="sb-adv-id">
        <div class="sb-adv-name">{{skill.name}}</div>
        <div class="sb-adv-sub">{{skill.stars}} {{skill.rankLabel}} · {{skill.actionLabel}} · {{skill.effectLabel}}</div>
      </div>
    </div>

    <dl class="sb-adv-stats">
      <div><dt>{{localize "PROJECTANIME.SkillBuilder.attributes"}}</dt><dd>{{skill.attrA}} + {{skill.attrB}}</dd></div>
      <div><dt>{{localize "PROJECTANIME.Skill.field.range"}}</dt><dd>{{skill.rangeLabel}}</dd></div>
      {{#if skill.energyCost}}<div><dt>{{localize "PROJECTANIME.Skill.field.energyCost"}}</dt><dd><i class="fas fa-bolt"></i> {{skill.energyCost}}</dd></div>{{/if}}
      {{#if skill.passive}}<div><dt>{{localize "PROJECTANIME.Skill.field.energyTax"}}</dt><dd><i class="fas fa-bolt"></i> −{{skill.passiveEnergyTax}}</dd></div>{{/if}}
      <div><dt>{{localize "PROJECTANIME.Skill.field.accuracyMod"}}</dt><dd>+{{skill.accuracyMod}}</dd></div>
      <div class="span-2"><dt>{{localize "PROJECTANIME.Skill.field.modifiers"}}</dt><dd>{{skill.modUsed}} / {{skill.modMax}}{{#if skill.modifiers.length}} — {{#each skill.modifiers as |m|}}{{m}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</dd></div>
    </dl>

    <h3 class="sb-section-title">{{localize "PROJECTANIME.SkillBuilder.improvements"}}</h3>
    <div class="sb-imp-grid">
      <button type="button" class="sb-imp" data-action="raiseRank" {{#if improvements.raiseRank.disabled}}disabled{{/if}}>
        <span class="sb-imp-name">{{localize "PROJECTANIME.SkillBuilder.raiseRank"}}</span>
        <span class="sb-imp-detail">{{#if improvements.raiseRank.atMax}}{{localize "PROJECTANIME.SkillBuilder.atMax"}}{{else}}{{skill.stars}} → {{improvements.raiseRank.next}}{{/if}}</span>
        <span class="sb-imp-cost"><i class="fas fa-star"></i> {{improvements.raiseRank.cost}}</span>
      </button>
      {{#if improvements.sharpenAccuracy.applies}}
      <button type="button" class="sb-imp" data-action="sharpenAccuracy" {{#if improvements.sharpenAccuracy.disabled}}disabled{{/if}}>
        <span class="sb-imp-name">{{localize "PROJECTANIME.SkillBuilder.sharpen"}}</span>
        <span class="sb-imp-detail">{{#if improvements.sharpenAccuracy.atMax}}{{localize "PROJECTANIME.SkillBuilder.atMax"}}{{else}}+{{improvements.sharpenAccuracy.cur}} → +{{improvements.sharpenAccuracy.next}}{{/if}}</span>
        <span class="sb-imp-cost"><i class="fas fa-star"></i> {{improvements.sharpenAccuracy.cost}}</span>
      </button>
      {{/if}}
      {{#if improvements.sharpenDamage.applies}}
      <button type="button" class="sb-imp" data-action="sharpenDamage" {{#if improvements.sharpenDamage.disabled}}disabled{{/if}}>
        <span class="sb-imp-name">{{#if improvements.sharpenDamage.isHeal}}{{localize "PROJECTANIME.SkillBuilder.sharpenHealing"}}{{else}}{{localize "PROJECTANIME.SkillBuilder.sharpenDamage"}}{{/if}}</span>
        <span class="sb-imp-detail">{{#if improvements.sharpenDamage.atMax}}{{localize "PROJECTANIME.SkillBuilder.atMax"}}{{else}}+{{improvements.sharpenDamage.cur}} → +{{improvements.sharpenDamage.next}}{{/if}}</span>
        <span class="sb-imp-cost"><i class="fas fa-star"></i> {{improvements.sharpenDamage.cost}}</span>
      </button>
      {{/if}}
      {{#unless skill.passive}}
      <button type="button" class="sb-imp" data-action="lowerEnergy" {{#if improvements.lowerEnergy.disabled}}disabled{{/if}}>
        <span class="sb-imp-name">{{localize "PROJECTANIME.SkillBuilder.lowerEnergy"}}</span>
        <span class="sb-imp-detail">{{#if improvements.lowerEnergy.atMin}}{{localize "PROJECTANIME.SkillBuilder.atMin"}}{{else}}<i class="fas fa-bolt"></i> {{improvements.lowerEnergy.cur}} → {{improvements.lowerEnergy.next}}{{/if}}</span>
        <span class="sb-imp-cost"><i class="fas fa-star"></i> {{improvements.lowerEnergy.cost}}</span>
      </button>
      {{/unless}}
      <button type="button" class="sb-imp" data-action="raiseRange" {{#if improvements.raiseRange.disabled}}disabled{{/if}}>
        <span class="sb-imp-name">{{localize "PROJECTANIME.SkillBuilder.raiseRange"}}</span>
        <span class="sb-imp-detail">{{#if improvements.raiseRange.hasTiles}}{{improvements.raiseRange.cur}} → {{improvements.raiseRange.next}} {{localize "PROJECTANIME.Skill.tiles"}}{{else}}—{{/if}}</span>
        <span class="sb-imp-cost"><i class="fas fa-star"></i> {{improvements.raiseRange.cost}}</span>
      </button>
    </div>

    <h3 class="sb-section-title sb-addmod-title">
      {{localize "PROJECTANIME.SkillBuilder.addModifier"}}
      <span class="sb-imp-cost"><i class="fas fa-star"></i> 1</span>
    </h3>
    {{#if improvements.addModifier.full}}
    <p class="sb-note">{{localize "PROJECTANIME.SkillBuilder.modBudgetFull"}}</p>
    {{else}}
    <ul class="sb-add-mod-list">
      {{#each addableModifiers as |mod|}}
      <li class="sb-add-mod-row{{#if mod.blocked}} blocked{{/if}}" data-modifier="{{mod.key}}">
        <div class="sb-add-mod-text">
          <span class="sb-mod-name">{{mod.label}}{{#if mod.heavy}} <span class="heavy-badge">{{localize "PROJECTANIME.Skill.heavy"}}</span>{{/if}}</span>
          <span class="sb-mod-desc">{{mod.desc}}</span>
        </div>
        <button type="button" class="sb-add-mod" data-action="addModifier" title="{{localize 'PROJECTANIME.SkillBuilder.addModifier'}}" {{#if mod.disabled}}disabled{{/if}}>
          <i class="fas fa-plus"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{/if}}

    {{#if growableMods.length}}
    <h3 class="sb-section-title sb-grow-title">
      {{localize "PROJECTANIME.SkillBuilder.turnModifier"}}
      <span class="sb-imp-cost"><i class="fas fa-star"></i> 1</span>
    </h3>
    <ul class="sb-add-mod-list">
      {{#each growableMods as |g|}}
      <li class="sb-add-mod-row" data-modifier="{{g.key}}">
        <div class="sb-add-mod-text">
          <span class="sb-mod-name">{{g.label}}</span>
          <span class="sb-mod-desc">{{g.current}} → {{g.next}} {{g.unit}}{{#if g.growth}} ({{localize "PROJECTANIME.SkillBuilder.base"}} {{g.base}} +{{g.growth}}){{/if}}</span>
        </div>
        <button type="button" class="sb-add-mod" data-action="turnModifier" title="{{localize 'PROJECTANIME.SkillBuilder.turnModifier'}}" {{#if g.disabled}}disabled{{/if}}>
          <i class="fas fa-plus"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{/if}}

    <div class="sb-nav">
      <button type="button" class="sb-cancel" data-action="backToHub"><i class="fas fa-chevron-left"></i> {{localize "PROJECTANIME.SkillBuilder.backToSkills"}}</button>
    </div>
  </div>
  {{/if}}

</div>
