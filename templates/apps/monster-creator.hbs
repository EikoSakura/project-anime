{{!-- Step-by-step Monster Creator (v0.03): Concept → Frame (Role · Tier) → Tune (Build Your Own) →
      Abilities (Twists) → Gear → Review. --}}
<div class="cc-body">

  <ol class="cc-steps">
    {{#each steps as |st|}}
    <li class="cc-step-dot{{#if st.active}} active{{/if}}{{#if st.done}} done{{/if}}"
        data-action="gotoStep" data-step="{{st.index}}" title="{{st.label}}">
      <span class="cc-dot-num">{{st.num}}</span>
      <span class="cc-dot-label">{{st.label}}</span>
    </li>
    {{/each}}
  </ol>

  <div class="cc-step-head">
    <span class="cc-step-counter">{{stepLabel}}</span>
    <span class="cc-step-title">{{stepTitle}}</span>
  </div>

  {{!-- ===================== 1 · CONCEPT ===================== --}}
  {{#if onConcept}}
  <section class="cc-step-body cc-concept">
    <div class="cc-id-row">
      <div class="cc-img" data-action="pickImage" title="{{localize 'PROJECTANIME.MonsterCreator.pickImage'}}">
        <img src="{{img}}" alt="" />
        <i class="cc-img-edit fas fa-camera"></i>
      </div>
      <label class="cc-field">
        <span class="cc-label">{{localize "Name"}}</span>
        <input type="text" name="name" value="{{name}}" />
      </label>
    </div>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.disposition"}}</span>
      <select name="system.disposition">{{selectOptions config.dispositions selected=disposition localize=true}}</select>
    </label>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.conceptField"}}</span>
      <textarea name="system.biography" rows="5">{{biography}}</textarea>
    </label>
  </section>
  {{/if}}

  {{!-- ===================== 2 · FRAME (path · Role · Tier → statblock) ===================== --}}
  {{#if onFrame}}
  <section class="cc-step-body cc-frame">
    <div class="cc-path-row" role="radiogroup">
      {{#each paths as |p|}}
      <button type="button" class="cc-path{{#if p.selected}} selected{{/if}}" data-action="pickPath" data-path="{{p.key}}">{{p.label}}</button>
      {{/each}}
    </div>

    <div class="cc-role-grid">
      {{#each roles as |r|}}
      <button type="button" class="cc-role-card{{#if r.selected}} selected{{/if}}" style="--tier-color: {{r.color}}"
              data-action="pickRole" data-role="{{r.key}}">
        <div class="cc-role-head">
          <i class="{{r.icon}}"></i>
          <span class="cc-role-name">{{r.label}}</span>
          <span class="cc-role-threat" title="{{localize 'PROJECTANIME.Threat.label'}}"><i class="fas fa-skull"></i>{{r.threat}}</span>
        </div>
        <div class="cc-role-strong">
          {{#if r.anyThree}}<span class="cc-strong-any">{{localize "PROJECTANIME.EnemyRole.strongShort"}} ×3</span>
          {{else}}{{#each r.strong as |s|}}<span class="cc-strong-chip">{{s}}</span>{{/each}}{{/if}}
        </div>
      </button>
      {{/each}}
    </div>

    <div class="cc-tier-row" role="radiogroup">
      <span class="cc-label">{{localize "PROJECTANIME.EnemyTier.label"}}</span>
      {{#each tiers as |t|}}
      <button type="button" class="cc-tier-btn{{#if t.selected}} selected{{/if}}" data-action="pickTier" data-tier="{{t.key}}"
              title="{{localize 'PROJECTANIME.EnemyRole.strongShort'}} {{t.strong}} · {{localize 'PROJECTANIME.EnemyRole.weakShort'}} {{t.weak}}">
        <span class="cc-tier-num">{{t.numeral}}</span>
        <span class="cc-tier-dice muted">{{t.strong}}/{{t.weak}}</span>
      </button>
      {{/each}}
    </div>

    <div class="cc-flag-row">
      <label class="cc-flag{{#if rival}} on{{/if}}"><input type="checkbox" data-action="toggleRival" {{#if rival}}checked{{/if}} /> <i class="fas fa-chess-king"></i> {{localize "PROJECTANIME.Rival.label"}}</label>
      <label class="cc-flag{{#if boss}} on{{/if}}"><input type="checkbox" data-action="toggleBoss" {{#if boss}}checked{{/if}} /> <i class="fas fa-crown"></i> {{localize "PROJECTANIME.Boss.label"}}</label>
    </div>

    {{#if framed}}
    {{> "systems/project-anime/templates/apps/monster-statblock.hbs"}}
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 3 · TUNE (Build Your Own — trade + Four Rails) ===================== --}}
  {{#if onTune}}
  <section class="cc-step-body cc-tune">
    {{#if picksStrong}}
    <div class="cc-strong-pick">
      <span class="cc-label">{{localize "PROJECTANIME.EnemyRole.strongPick"}}</span>
      <div class="cc-strong-grid">
        {{#each strongPicks as |s|}}
        <button type="button" class="cc-strong-opt{{#if s.on}} on{{/if}}" data-action="pickStrong" data-attr="{{s.key}}">
          {{#if s.icon}}<i class="{{s.icon}}"></i>{{/if}} {{s.label}}
        </button>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{> "systems/project-anime/templates/apps/monster-statblock.hbs"}}

    {{#if pathCustom}}
    <div class="cc-trade-grid">
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.hpShort"}}</span><input type="number" name="system.hp.max" value="{{stat.hp}}" min="1" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.energyShort"}}</span><input type="number" name="system.energy.max" value="{{stat.energy}}" min="0" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.atkShort"}}</span><input type="number" name="system.atk.bonus" value="{{system.atk.bonus}}" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.defShort"}}</span><input type="number" name="system.defense.bonus" value="{{system.defense.bonus}}" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.resShort"}}</span><input type="number" name="system.res.bonus" value="{{system.res.bonus}}" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.evaShort"}}</span><input type="number" name="system.evasion.bonus" value="{{system.evasion.bonus}}" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.asShort"}}</span><input type="number" name="system.as.bonus" value="{{system.as.bonus}}" /></label>
      <label class="cc-trade"><span>{{localize "PROJECTANIME.Stat.movShort"}}</span><input type="number" name="system.movement.bonus" value="{{system.movement.bonus}}" /></label>
    </div>
    {{/if}}

    {{#if rails}}
    <div class="cc-rails">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.rails"}}</span>
      <ul class="cc-rail-list">
        {{#each rails as |r|}}
        <li class="cc-rail{{#if r.ok}} ok{{else}} bad{{/if}}">
          <i class="fas {{#if r.ok}}fa-check{{else}}fa-xmark{{/if}}"></i>
          <span class="cc-rail-label">{{r.label}}</span>
          <span class="cc-rail-val">{{r.actual}} {{#if r.exempt}}<em class="muted">{{localize "PROJECTANIME.MonsterCreator.railExempt"}}</em>{{else}}≤ {{r.limit}}{{/if}}</span>
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}

    {{#if vitalsStale}}
    <button type="button" class="cc-mini-btn" data-action="recalcVitals">
      <i class="fas fa-rotate"></i> {{localize "PROJECTANIME.MonsterCreator.recalc"}}
    </button>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 4 · ABILITIES ===================== --}}
  {{#if onAbilities}}
  <section class="cc-step-body cc-skills">

    {{!-- Basic Attacks — natural weapons. Strike with an equipped weapon: costs NO Energy
          and NO Skill Points (rules: "A Basic Attack costs no Energy"). --}}
    <h4 class="cc-subhead">{{localize "PROJECTANIME.MonsterCreator.basicAttacks"}}</h4>
    <button type="button" class="cc-primary" data-action="addAttack">
      <i class="fas fa-plus"></i> {{localize "PROJECTANIME.MonsterCreator.addBasicAttack"}}
    </button>
    {{#if attacks.length}}
    <ul class="cc-skill-list cc-attack-list">
      {{#each attacks as |atk|}}
      <li class="cc-skill-row cc-attack-row" data-attack-id="{{atk.id}}">
        <img src="{{atk.img}}" alt="" />
        <div class="cc-skill-info">
          <input type="text" class="cc-attack-name" value="{{atk.name}}" autocomplete="off" />
          <span class="cc-skill-sub muted">{{atk.summary}}</span>
        </div>
        <button type="button" class="cc-icon-btn" data-action="editAttack" title="{{localize 'PROJECTANIME.MonsterCreator.editAttack'}}">
          <i class="fas fa-pen"></i>
        </button>
        <button type="button" class="cc-icon-btn danger" data-action="removeAttack" title="{{localize 'PROJECTANIME.MonsterCreator.removeAttack'}}">
          <i class="fas fa-trash"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.MonsterCreator.noAttacks"}}</p>
    {{/if}}

    {{!-- Skills — the Skill Browser (world/compendium bag, incl. the preset Twists) and the Skill
          Builder for custom powers. Enemies have no Skill Points; EP fuels active Skills. --}}
    <h4 class="cc-subhead cc-skills-head">
      <span class="cc-head-title">{{localize "PROJECTANIME.MonsterCreator.skillsHeading"}} <span class="cc-count muted">{{skillCount}}</span></span>
      <span class="cc-head-actions">
        <button type="button" class="cc-mini-btn" data-action="browseSkills"><i class="fas fa-book-open"></i> {{localize "PROJECTANIME.MonsterCreator.browseSkills"}}</button>
        <button type="button" class="cc-mini-btn" data-action="openSkillBuilder"><i class="fas fa-wand-sparkles"></i> {{localize "PROJECTANIME.MonsterCreator.openSkillBuilder"}}</button>
      </span>
    </h4>
    {{#if skills.length}}
    <ul class="cc-skill-list">
      {{#each skills as |s|}}
      <li class="cc-skill-row{{#if s.twist}} is-twist{{/if}}" data-skill-id="{{s.id}}">
        <img src="{{s.img}}" alt="" />
        <div class="cc-skill-info">
          <span class="cc-skill-name">{{s.name}}{{#if s.twist}} <i class="fas fa-wand-magic-sparkles cc-twist-tag" title="{{localize 'PROJECTANIME.Twist.heading'}}"></i>{{/if}}</span>
          <span class="cc-skill-sub muted">{{s.actionLabel}} · {{s.cost}}</span>
        </div>
        <button type="button" class="cc-icon-btn danger" data-action="removeSkill" title="{{localize 'PROJECTANIME.MonsterCreator.removeSkill'}}">
          <i class="fas fa-trash"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.MonsterCreator.noSkills"}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 5 · GEAR ===================== --}}
  {{#if onGear}}
  <section class="cc-step-body cc-gear">
    <div class="cc-vitals-grid cc-gear-stats">
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.Stat.defense"}}</span><span class="cc-v-val">{{defense}}</span></div>
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.Stat.evasion"}}</span><span class="cc-v-val">{{evasion}}</span></div>
    </div>
    {{> "systems/project-anime/templates/actor/gear-body.hbs"}}
  </section>
  {{/if}}

  {{!-- ===================== 6 · REVIEW ===================== --}}
  {{#if onFinish}}
  <section class="cc-step-body cc-review">
    <div class="cc-review-id">
      <img class="cc-review-img" src="{{img}}" alt="" />
      <div class="cc-review-head">
        <span class="cc-review-name">{{name}}</span>
        <div class="cc-review-badges">
          {{#if reviewBadge}}
          <span class="cc-tier-badge" style="--tier-color: {{reviewBadge.color}}">
            <i class="{{reviewBadge.icon}}"></i> {{reviewBadge.label}}{{#if reviewBadge.tierNumeral}} · {{localize "PROJECTANIME.EnemyTier.tier"}} {{reviewBadge.tierNumeral}}{{/if}}
          </span>
          {{#if reviewBadge.rival}}<span class="cc-tier-badge rival"><i class="fas fa-chess-king"></i> {{localize "PROJECTANIME.Rival.badge"}}</span>{{/if}}
          {{#if reviewBadge.boss}}<span class="cc-tier-badge boss"><i class="fas fa-crown"></i> {{localize "PROJECTANIME.Boss.badge"}}</span>{{/if}}
          <span class="cc-tier-badge threat"><i class="fas fa-skull"></i> {{reviewBadge.threat}}</span>
          {{/if}}
        </div>
      </div>
    </div>
    {{> "systems/project-anime/templates/apps/monster-statblock.hbs"}}
    <div class="cc-vitals-grid">
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.MonsterCreator.reviewAttacks"}}</span><span class="cc-v-val">{{attackCount}}</span></div>
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.MonsterCreator.reviewAbilities"}}</span><span class="cc-v-val">{{skillCount}}</span></div>
    </div>
  </section>
  {{/if}}

  {{!-- ===================== NAV ===================== --}}
  <div class="cc-nav">
    <div class="cc-nav-left">
      {{#unless isFirst}}
      <button type="button" class="cc-back" data-action="stepBack">
        <i class="fas fa-chevron-left"></i> {{localize "PROJECTANIME.SkillBuilder.back"}}
      </button>
      {{/unless}}
    </div>
    <div class="cc-nav-right">
      {{#if isLast}}
      <button type="button" class="cc-finish-btn" data-action="finish">
        <i class="fas fa-check"></i> {{localize "PROJECTANIME.MonsterCreator.finish"}}
      </button>
      {{else}}
      <button type="button" class="cc-next" data-action="stepNext">
        {{localize "PROJECTANIME.SkillBuilder.next"}} <i class="fas fa-chevron-right"></i>
      </button>
      {{/if}}
    </div>
  </div>

</div>
