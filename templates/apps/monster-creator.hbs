{{!-- Step-by-step Monster Creator (V2): Concept → Type (stat line · Rival · Boss) → Attributes →
      Talents → Techniques → Review. --}}
<div class="cc-body">

  <ol class="cc-steps">
    {{#each steps as |st|}}
    <li class="cc-step-dot{{#if st.active}} active{{/if}}{{#if st.done}} done{{/if}}"
        data-action="gotoStep" data-step="{{st.index}}" title="{{st.label}}">
      <span class="cc-dot-num">{{st.num}}</span>
      <span class="cc-dot-label">{{st.label}}</span>
    </li>
    {{/each}}
  </ol>

  <div class="cc-step-head">
    <span class="cc-step-counter">{{stepLabel}}</span>
    <span class="cc-step-title">{{stepTitle}}</span>
  </div>

  {{!-- ===================== 1 · CONCEPT ===================== --}}
  {{#if onConcept}}
  <section class="cc-step-body cc-concept">
    <div class="cc-id-row">
      <div class="cc-img" data-action="pickImage" title="{{localize 'PROJECTANIME.MonsterCreator.pickImage'}}">
        <img src="{{img}}" alt="" />
        <i class="cc-img-edit fas fa-camera"></i>
      </div>
      <label class="cc-field">
        <span class="cc-label">{{localize "Name"}}</span>
        <input type="text" name="name" value="{{name}}" />
      </label>
    </div>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.disposition"}}</span>
      <select name="system.disposition">{{selectOptions config.dispositions selected=disposition localize=true}}</select>
    </label>
    <label class="cc-field">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.conceptField"}}</span>
      <textarea name="system.biography" rows="5">{{biography}}</textarea>
    </label>
  </section>
  {{/if}}

  {{!-- ===================== 2 · TYPE (stat line · Rival · Boss) ===================== --}}
  {{#if onType}}
  <section class="cc-step-body cc-frame">
    <div class="cc-choose-grid">
      {{#each types as |t|}}
      <button type="button" class="cc-choose-opt cc-style-opt{{#if t.selected}} selected{{/if}}" style="--tier-color: {{t.color}}"
              data-action="pickType" data-type="{{t.key}}" data-tooltip="{{t.tooltip}}" data-tooltip-class="pa-tooltip">
        <span class="cc-style-icon cc-type-glyph"><i class="{{t.icon}}"></i></span>
        <span class="cc-choose-opt-name">{{t.label}}</span>
        {{#if t.selected}}<i class="cc-choose-check fas fa-circle-check"></i>{{/if}}
      </button>
      {{/each}}
    </div>

    <div class="cc-flag-row">
      <label class="cc-flag{{#if rival}} on{{/if}}"><input type="checkbox" data-action="toggleRival" {{#if rival}}checked{{/if}} /> <i class="fas fa-chess-king"></i> {{localize "PROJECTANIME.Rival.label"}}</label>
      <label class="cc-flag{{#if boss}} on{{/if}}"><input type="checkbox" data-action="toggleBoss" {{#if boss}}checked{{/if}} /> <i class="fas fa-crown"></i> {{localize "PROJECTANIME.Boss.label"}}</label>
    </div>

    {{#if bossBars}}
    <div class="cc-flag-row">
      <label class="cc-field">
        <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.partySize"}}</span>
        <input type="number" class="mc-party-size" value="{{bossBars.partySize}}" min="1" step="1" />
      </label>
    </div>
    {{/if}}

    {{#if framed}}
    {{> "systems/project-anime/templates/apps/monster-statblock.hbs"}}
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 3 · ATTRIBUTES (assign the budget dice · attack accuracy) ===================== --}}
  {{#if onAttributes}}
  <section class="cc-step-body cc-attributes">
    {{#if attrBudget}}
    <div class="cc-budget-pill{{#if attrBudgetOff}} over{{/if}}">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.attrBudget"}}</span>
      {{#each attrBudget as |b|}}
      <span class="cc-strong-chip">{{b.die}} {{b.used}}/{{b.need}}</span>
      {{/each}}
    </div>
    {{/if}}

    <div class="cc-attr-grid">
      {{#each attributes as |a|}}
      <div class="cc-attr-card" data-attribute="{{a.key}}">
        <div class="cc-attr-head">
          {{#if a.icon}}<i class="{{a.icon}}"></i>{{/if}}
          <span class="cc-attr-name">{{a.label}}</span>
        </div>
        <select class="mc-attr-select">
          {{#each a.options as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
        </select>
      </div>
      {{/each}}
    </div>

    {{!-- Basic Attacks — pick the two accuracy Attributes (the same one may be chosen twice) or
          link a Talent, which replaces one die and adds the Trained Edge. --}}
    <h4 class="cc-subhead cc-skills-head">
      <span class="cc-head-title">{{localize "PROJECTANIME.MonsterCreator.basicAttacks"}} <span class="cc-count muted">{{attackCount}}</span></span>
      <span class="cc-head-actions">
        <button type="button" class="cc-mini-btn" data-action="addAttack"><i class="fas fa-plus"></i> {{localize "PROJECTANIME.MonsterCreator.addBasicAttack"}}</button>
      </span>
    </h4>
    {{#if attacks.length}}
    <ul class="cc-skill-list cc-attack-list">
      {{#each attacks as |atk|}}
      <li class="cc-skill-row cc-attack-row" data-attack-id="{{atk.id}}">
        <img src="{{atk.img}}" alt="" />
        <div class="cc-skill-info">
          <input type="text" class="cc-attack-name" value="{{atk.name}}" autocomplete="off" />
          <span class="cc-skill-sub muted">{{localize "PROJECTANIME.Stat.dmgShort"}} {{atk.damage}} · {{localize "PROJECTANIME.Stat.thrShort"}} {{atk.threshold}}</span>
        </div>
        <select class="mc-attack-sel" data-field="attrA" title="{{localize 'PROJECTANIME.Roll.attrA'}}">
          {{#each atk.attrA as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
        </select>
        <select class="mc-attack-sel" data-field="attrB" title="{{localize 'PROJECTANIME.Roll.attrB'}}">
          {{#each atk.attrB as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
        </select>
        <select class="mc-attack-sel" data-field="talent" title="{{localize 'PROJECTANIME.MonsterCreator.step.talents'}}">
          <option value="">{{localize "PROJECTANIME.MonsterCreator.noTalent"}}</option>
          {{#each atk.talentOptions as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
        </select>
        <button type="button" class="cc-icon-btn" data-action="editAttack" title="{{localize 'PROJECTANIME.MonsterCreator.editAttack'}}">
          <i class="fas fa-pen"></i>
        </button>
        {{#unless atk.natural}}
        <button type="button" class="cc-icon-btn danger" data-action="removeAttack" title="{{localize 'PROJECTANIME.MonsterCreator.removeAttack'}}">
          <i class="fas fa-trash"></i>
        </button>
        {{/unless}}
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.MonsterCreator.noAttacks"}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 4 · TALENTS ===================== --}}
  {{#if onTalents}}
  <section class="cc-step-body cc-talents">
    {{#if talentBudget.length}}
    <div class="cc-budget-pill">
      <span class="cc-label">{{localize "PROJECTANIME.MonsterCreator.talentBudget"}}</span>
      {{#each talentBudget as |b|}}
      <span class="cc-strong-chip">{{b}}</span>
      {{/each}}
    </div>
    {{/if}}

    <div class="cc-flag-row">
      {{#each talentAdds as |t|}}
      <button type="button" class="cc-mini-btn" data-action="addTalent" data-die="{{t.die}}"><i class="fas fa-plus"></i> {{t.label}}</button>
      {{/each}}
    </div>

    {{#if talents.length}}
    <ul class="cc-skill-list cc-attack-list">
      {{#each talents as |t|}}
      <li class="cc-skill-row cc-attack-row" data-talent-id="{{t.id}}">
        <i class="fas fa-graduation-cap cc-talent-glyph"></i>
        <div class="cc-skill-info">
          <input type="text" class="cc-attack-name mc-talent-name" data-field="name" value="{{t.name}}" autocomplete="off" />
        </div>
        <select class="mc-talent-sel" data-field="die" title="{{localize 'PROJECTANIME.Roll.die'}}">
          {{#each t.dieOptions as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
        </select>
        <select class="mc-talent-sel" data-field="attribute" title="{{localize 'PROJECTANIME.MonsterCreator.talentAttr'}}">
          {{#each t.attrOptions as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
        </select>
        <button type="button" class="cc-icon-btn danger" data-action="removeTalent" title="{{localize 'PROJECTANIME.MonsterCreator.removeTalent'}}">
          <i class="fas fa-trash"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.MonsterCreator.noTalents"}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 5 · TECHNIQUES ===================== --}}
  {{#if onTechniques}}
  <section class="cc-step-body cc-skills">
    <h4 class="cc-subhead cc-skills-head">
      <span class="cc-head-title">
        {{localize "PROJECTANIME.MonsterCreator.step.techniques"}}
        <span class="cc-count muted">{{skillCount}}{{#if techBudget}} / {{techBudget}}{{/if}}</span>
      </span>
      <span class="cc-head-actions">
        <button type="button" class="cc-mini-btn" data-action="browseSkills"><i class="fas fa-book-open"></i> {{localize "PROJECTANIME.MonsterCreator.browseSkills"}}</button>
        <button type="button" class="cc-mini-btn" data-action="openSkillBuilder"><i class="fas fa-wand-sparkles"></i> {{localize "PROJECTANIME.MonsterCreator.openSkillBuilder"}}</button>
      </span>
    </h4>
    {{#if supportNote}}
    <div class="cc-flag-row"><span class="cc-strong-chip">{{localize "PROJECTANIME.MonsterCreator.supportNote"}}</span></div>
    {{/if}}
    {{#if boss}}
    <div class="cc-flag-row">
      <span class="cc-strong-chip">{{localize "PROJECTANIME.Boss.techniquesPerBar"}}</span>
      <span class="cc-strong-chip">{{localize "PROJECTANIME.Boss.breakUnlocks"}}</span>
    </div>
    {{/if}}
    {{#if skills.length}}
    <ul class="cc-skill-list">
      {{#each skills as |s|}}
      <li class="cc-skill-row" data-skill-id="{{s.id}}">
        <img src="{{s.img}}" alt="" />
        <div class="cc-skill-info">
          <span class="cc-skill-name">{{s.name}}</span>
          <span class="cc-skill-sub muted">{{s.actionLabel}} · {{s.cost}}</span>
        </div>
        <button type="button" class="cc-icon-btn danger" data-action="removeSkill" title="{{localize 'PROJECTANIME.MonsterCreator.removeSkill'}}">
          <i class="fas fa-trash"></i>
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="cc-empty muted">{{localize "PROJECTANIME.MonsterCreator.noSkills"}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- ===================== 6 · REVIEW ===================== --}}
  {{#if onFinish}}
  <section class="cc-step-body cc-review">
    <div class="cc-review-id">
      <img class="cc-review-img" src="{{img}}" alt="" />
      <div class="cc-review-head">
        <span class="cc-review-name">{{name}}</span>
        <div class="cc-review-badges">
          {{#if reviewBadge}}
          {{#if reviewBadge.label}}
          <span class="cc-tier-badge" style="--tier-color: {{reviewBadge.color}}">
            <i class="{{reviewBadge.icon}}"></i> {{reviewBadge.label}}
          </span>
          {{/if}}
          {{#if reviewBadge.rival}}<span class="cc-tier-badge rival"><i class="fas fa-chess-king"></i> {{localize "PROJECTANIME.Rival.badge"}}</span>{{/if}}
          {{#if reviewBadge.boss}}<span class="cc-tier-badge boss"><i class="fas fa-crown"></i> {{localize "PROJECTANIME.Boss.badge"}}</span>{{/if}}
          <span class="cc-tier-badge threat"><i class="fas fa-skull"></i> {{reviewBadge.threat}}</span>
          {{/if}}
        </div>
      </div>
    </div>
    {{> "systems/project-anime/templates/apps/monster-statblock.hbs"}}
    <div class="cc-vitals-grid">
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.MonsterCreator.reviewAttacks"}}</span><span class="cc-v-val">{{attackCount}}</span></div>
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.MonsterCreator.step.talents"}}</span><span class="cc-v-val">{{talentCount}}</span></div>
      <div class="cc-vital"><span class="cc-v-label">{{localize "PROJECTANIME.MonsterCreator.step.techniques"}}</span><span class="cc-v-val">{{skillCount}}</span></div>
    </div>
  </section>
  {{/if}}

  {{!-- ===================== NAV ===================== --}}
  <div class="cc-nav">
    <div class="cc-nav-left">
      {{#unless isFirst}}
      <button type="button" class="cc-back" data-action="stepBack">
        <i class="fas fa-chevron-left"></i> {{localize "PROJECTANIME.SkillBuilder.back"}}
      </button>
      {{/unless}}
    </div>
    <div class="cc-nav-right">
      {{#if isLast}}
      <button type="button" class="cc-finish-btn" data-action="finish">
        <i class="fas fa-check"></i> {{localize "PROJECTANIME.MonsterCreator.finish"}}
      </button>
      {{else}}
      <button type="button" class="cc-next" data-action="stepNext">
        {{localize "PROJECTANIME.SkillBuilder.next"}} <i class="fas fa-chevron-right"></i>
      </button>
      {{/if}}
    </div>
  </div>

</div>
