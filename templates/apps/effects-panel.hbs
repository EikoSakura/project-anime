{{!-- Floating Effects Panel — an icon-only column (PF2e-style). The name, remaining
      duration and rule summary all live in the hover tooltip (data-tooltip-html, themed by
      the .pa-tooltip class — same as the sheet's item tooltips). Single root <div>. The app
      adds `.empty` to its own root when there are no effects, hiding the whole panel. --}}
<div class="ep-body">
  <ul class="ep-list">
    {{#each effects as |e|}}
    <li class="ep-effect" data-effect-uuid="{{e.uuid}}" data-action="openEffect"
        data-tooltip-html="{{e.tooltip}}" data-tooltip-direction="LEFT" data-tooltip-class="pa-tooltip">
      <img class="ep-icon" src="{{e.img}}" alt="{{e.name}}" />
    </li>
    {{/each}}
  </ul>
</div>
