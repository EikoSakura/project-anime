{{!-- Resident staffing section for ONE facility (its VM is the root context). Extracted from
      structures.hbs so a staff assign/unassign can re-render every facility's section in place (the idle
      pool spans all panes) without a window flash — see StructuresWindow #patchStaffEverywhere. The
      wrapper .struct-staff-sec[data-staff-sec] lives in structures.hbs; this is its inner content. --}}
<span class="hq-bk-sec">{{localize "PROJECTANIME.HQ.residents"}} <span class="struct-cap">{{staffCount}}/{{staffCap}}</span></span>
<div class="struct-slots">
  {{#each staff}}
  <div class="struct-slot filled{{#unless present}} away{{/unless}}" title="{{name}}">
    <span class="struct-av">{{#if img}}<img src="{{img}}" alt="">{{else}}{{initial}}{{/if}}</span>
    <a class="struct-slot-x" data-action="unassignStaff" data-person-id="{{id}}" title="{{localize 'PROJECTANIME.HQ.unassign'}}"><i class="fas fa-xmark"></i></a>
  </div>
  {{/each}}
  {{#each emptySlots}}
  {{#if ../canAssign}}
  <button type="button" class="struct-slot empty" data-action="openPool" title="{{localize 'PROJECTANIME.HQ.addResident'}}"><i class="fas fa-plus"></i></button>
  {{else}}
  <span class="struct-slot empty disabled"><i class="fas fa-plus"></i></span>
  {{/if}}
  {{/each}}
</div>
{{#if hasGathered}}<div class="struct-staff-note"><i class="fas fa-arrow-trend-up"></i> {{#each gathered}}+{{amount}} {{label}}{{#unless @last}} · {{/unless}}{{/each}}</div>{{/if}}
{{#if canAssign}}
<div class="struct-pool">
  {{#each staffPool}}
  <button type="button" class="struct-pcard" data-action="assignStaff" data-recruit-id="{{../id}}" data-person-id="{{id}}" title="{{name}}">
    <span class="struct-pav">{{#if img}}<img src="{{img}}" alt="">{{else}}{{initial}}{{/if}}</span>
  </button>
  {{/each}}
</div>
{{/if}}
