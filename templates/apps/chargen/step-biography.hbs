<div class="chargen-biography">

  <p class="chargen-hint">{{localize "SHARDS.CharGen.Biography.Hint"}}</p>

  <div class="chargen-field chargen-field--full">
    <label>{{localize "SHARDS.CharGen.Biography.Appearance"}}</label>
    <textarea data-chargen-textarea="appearance" rows="4" placeholder="{{localize "SHARDS.CharGen.Biography.AppearancePlaceholder"}}">{{state.appearance}}</textarea>
  </div>

  <div class="chargen-field chargen-field--full">
    <label>{{localize "SHARDS.CharGen.Biography.Personality"}}</label>
    <textarea data-chargen-textarea="personality" rows="4" placeholder="{{localize "SHARDS.CharGen.Biography.PersonalityPlaceholder"}}">{{state.personality}}</textarea>
  </div>

  <div class="chargen-field chargen-field--full">
    <label>{{localize "SHARDS.CharGen.Biography.Backstory"}}</label>
    <textarea data-chargen-textarea="biography" rows="6" placeholder="{{localize "SHARDS.CharGen.Biography.BackstoryPlaceholder"}}">{{state.biography}}</textarea>
  </div>

</div>
