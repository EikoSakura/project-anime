<div class="ec-body">

  <div class="ec-head">
    <span class="ec-h-preview"></span>
    <span>{{localize "PROJECTANIME.Settings.materialCategories.icon"}}</span>
    <span>{{localize "PROJECTANIME.Settings.materialCategories.categoryName"}}</span>
    <span>{{localize "PROJECTANIME.Settings.materialCategories.key"}}</span>
    <span class="ec-h-del"></span>
  </div>

  <div class="ec-rows">
    {{#each rows as |row i|}}
    <div class="ec-row">
      <a class="ec-pick" data-action="pickIcon" data-index="{{i}}"
         title="{{localize 'PROJECTANIME.Settings.materialCategories.pick'}}">
        {{#if row.iconImg}}<img src="{{row.icon}}" alt="" />{{else}}<i class="{{row.icon}}"></i>{{/if}}
      </a>
      <input type="text" class="ec-icon" name="materialCategories.{{i}}.icon" value="{{row.icon}}" placeholder="fa-solid fa-cube" />
      <input type="text" class="ec-label" name="materialCategories.{{i}}.label" value="{{row.label}}"
             placeholder="{{localize 'PROJECTANIME.Settings.materialCategories.categoryName'}}" />
      <input type="text" class="ec-key" name="materialCategories.{{i}}.key" value="{{row.key}}" placeholder="key" />
      <a class="ec-del" data-action="deleteRow" data-index="{{i}}"
         title="{{localize 'PROJECTANIME.Settings.materialCategories.remove'}}"><i class="fa-solid fa-trash"></i></a>
    </div>
    {{else}}
    <p class="ec-empty muted">{{localize "PROJECTANIME.Settings.materialCategories.empty"}}</p>
    {{/each}}
  </div>

  <div class="ec-add">
    <button type="button" data-action="addRow"><i class="fa-solid fa-plus"></i> {{localize "PROJECTANIME.Settings.materialCategories.add"}}</button>
    <button type="button" data-action="restoreList"><i class="fa-solid fa-rotate-left"></i> {{localize "PROJECTANIME.Settings.materialCategories.restore"}}</button>
  </div>

  <footer class="ec-footer">
    <button type="submit" class="ec-save"><i class="fa-solid fa-floppy-disk"></i> {{localize "PROJECTANIME.Settings.materialCategories.save"}}</button>
  </footer>
</div>
