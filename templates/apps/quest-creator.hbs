<div class="quest-creator-content">
  {{!-- Title & Rank --}}
  <div class="quest-section">
    <div class="quest-row">
      <div class="quest-field quest-field--title">
        <label>{{localize "SHARDS.Quest.Title"}}</label>
        <input type="text" data-field="title" value="{{state.title}}" placeholder="{{localize 'SHARDS.Quest.TitlePlaceholder'}}" />
      </div>
      <div class="quest-field quest-field--rank">
        <label>{{localize "SHARDS.Quest.QuestRank"}}</label>
        <select data-field="rank">
          {{#each rankOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    <div class="quest-row">
      <div class="quest-field">
        <label>{{localize "SHARDS.Quest.StatusLabel"}}</label>
        <select data-field="status">
          {{#each statusOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="quest-field">
        <label>{{localize "SHARDS.Quest.PriorityLabel"}}</label>
        <select data-field="priority">
          {{#each priorityOptions}}
          <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </div>

  {{!-- Description --}}
  <div class="quest-section">
    <label class="quest-section__label">{{localize "SHARDS.Quest.Description"}}</label>
    <textarea data-field="description" rows="3">{{state.description}}</textarea>
  </div>

  {{!-- Objectives --}}
  <div class="quest-section">
    <div class="quest-objectives-header">
      <label class="quest-section__label">{{localize "SHARDS.Quest.Objectives"}}</label>
      <button type="button" data-action="addObjective" class="quest-add-btn"><i class="fa-solid fa-plus"></i></button>
    </div>
    <div class="quest-objectives-list">
      {{#each state.objectives}}
      <div class="quest-objective-row" data-index="{{@index}}">
        <input type="text" class="quest-objective-text" data-obj-index="{{@index}}" value="{{this.text}}" placeholder="{{localize 'SHARDS.Quest.ObjectivePlaceholder'}}" />
        <button type="button" data-action="removeObjective" data-index="{{@index}}" class="quest-remove-btn"><i class="fa-solid fa-xmark"></i></button>
      </div>
      {{/each}}
    </div>
  </div>

  {{!-- Rewards --}}
  <div class="quest-section">
    <label class="quest-section__label">{{localize "SHARDS.Quest.Rewards"}}</label>
    <textarea data-field="rewards" rows="2">{{state.rewards}}</textarea>
  </div>

  {{!-- GM Notes --}}
  <div class="quest-section">
    <label class="quest-section__label">{{localize "SHARDS.Quest.GmNotes"}}</label>
    <textarea data-field="gmNotes" rows="2">{{state.gmNotes}}</textarea>
  </div>

  {{!-- Output Mode --}}
  <div class="quest-section quest-output">
    <label class="quest-section__label">{{localize "SHARDS.Quest.OutputMode"}}</label>
    <div class="quest-output-options">
      <label class="quest-output-option">
        <input type="radio" name="output" value="party" data-field="output" {{#if (eq state.output "party")}}checked{{/if}} />
        <span>{{localize "SHARDS.Quest.OutputParty"}}</span>
      </label>
      {{#if partyActors.length}}
      <select data-field="partyActorId" class="quest-party-select" {{#unless (eq state.output "party")}}disabled{{/unless}}>
        {{#each partyActors}}
        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
      {{else}}
      <span class="quest-no-party">{{localize "SHARDS.Quest.NoPartyActors"}}</span>
      {{/if}}
      <label class="quest-output-option">
        <input type="radio" name="output" value="journal" data-field="output" {{#if (eq state.output "journal")}}checked{{/if}} />
        <span>{{localize "SHARDS.Quest.OutputJournal"}}</span>
      </label>
    </div>
  </div>

  {{!-- Create Button --}}
  <div class="quest-create">
    <button type="button" class="quest-create-btn" data-action="create">
      <i class="fa-solid fa-scroll"></i> {{localize "SHARDS.Quest.Create"}}
    </button>
  </div>
</div>
