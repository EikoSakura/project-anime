{{!-- Token Dossier (right-click inspect): portrait + HP/Energy + reveal-gated deeper layers.
      Single root <div> (AppV2 part contract). Each deeper section renders only when the
      viewer's Reveal effects (or ownership / GM) unlock that category. --}}
<div class="td-body">
  {{#if show}}
  <div class="td-head">
    <img class="td-img" src="{{img}}" alt="{{name}}" />
    <div class="td-id">
      <div class="td-name">{{name}}</div>
      <div class="td-badge">{{badge}}</div>
    </div>
  </div>

  <div class="td-resources">
    <div class="resource hp">
      <div class="resource-top">
        <label>{{localize "PROJECTANIME.Stat.hp"}}</label>
        <span class="resource-vals"><span class="num">{{hp.value}}</span><span class="sep">/</span><span class="num">{{hp.max}}</span></span>
      </div>
      <div class="bar"><div class="fill hp-fill" style="width: {{hp.pct}}%"></div></div>
    </div>
    <div class="resource energy">
      <div class="resource-top">
        <label>{{localize "PROJECTANIME.Stat.energy"}}</label>
        <span class="resource-vals"><span class="num">{{energy.value}}</span><span class="sep">/</span><span class="num">{{energy.max}}</span></span>
      </div>
      <div class="bar"><div class="fill energy-fill" style="width: {{energy.pct}}%"></div></div>
    </div>
    {{#if sp.show}}
    <div class="ti-stat"><span class="k">{{localize "PROJECTANIME.Stat.skillPoints"}}</span><span class="v">{{sp.value}}</span></div>
    {{/if}}
  </div>

  {{#if attributes}}
  <section class="td-section">
    <h4 class="td-title">{{localize "PROJECTANIME.Effect.reveal.attributes"}}</h4>
    <div class="td-attrs">
      {{#each attributes}}
      <div class="td-attr"><span class="k">{{this.label}}</span><span class="v">{{this.die}}</span></div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if combat}}
  <section class="td-section">
    <h4 class="td-title">{{localize "PROJECTANIME.Effect.reveal.combatStats"}}</h4>
    <div class="td-combat">
      <div class="td-stat"><span class="k">{{localize "PROJECTANIME.Stat.evasion"}}</span><span class="v">{{combat.evasion}}</span></div>
      <div class="td-stat"><span class="k">{{localize "PROJECTANIME.Stat.defense"}}</span><span class="v">{{combat.defense}}</span></div>
      <div class="td-stat"><span class="k">{{localize "PROJECTANIME.Stat.movement"}}</span><span class="v">{{combat.movement}}</span></div>
    </div>
  </section>
  {{/if}}

  {{#if affinities.length}}
  <section class="td-section">
    <h4 class="td-title">{{localize "PROJECTANIME.Effect.reveal.affinities"}}</h4>
    <div class="td-affs">
      {{#each affinities}}
      <span class="td-aff aff-{{this.level}}">{{this.label}} · {{this.levelLabel}}</span>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if skills.length}}
  <section class="td-section">
    <h4 class="td-title">{{localize "PROJECTANIME.Effect.reveal.skills"}}</h4>
    <div class="td-skills">
      {{#each skills}}
      <details class="td-skill" data-skill="{{this.name}}" {{#if this.open}}open{{/if}}>
        <summary><span class="s-name">{{this.name}}</span><span class="s-rank">{{this.stars}}</span></summary>
        <div class="td-skill-body">
          {{#if this.meta.length}}<div class="td-skill-meta">{{#each this.meta}}<span>{{this}}</span>{{/each}}</div>{{/if}}
          {{#if this.description}}<div class="td-skill-desc">{{{this.description}}}</div>{{/if}}
        </div>
      </details>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{#if customFields.length}}
  <section class="td-section">
    <h4 class="td-title">{{localize "PROJECTANIME.Dossier.details"}}</h4>
    <div class="td-details">
      {{#each customFields}}
      <div class="ti-stat"><span class="k">{{this.label}}</span><span class="v">{{this.value}}</span></div>
      {{/each}}
    </div>
  </section>
  {{/if}}
  {{/if}}
</div>
